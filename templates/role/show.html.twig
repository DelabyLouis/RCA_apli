{% extends 'base.html.twig' %}

{% block title %}{{ role.libelle }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-user-tag me-2"></i>{{ role.libelle }}</h1>
                <div>
                    <a href="{{ path('app_role_index') }}" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                    </a>
                    <a href="{{ path('app_role_edit', {'id_role': role.idRole}) }}" class="btn btn-warning">
                        <i class="fas fa-edit me-1"></i>Modifier
                    </a>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-info-circle me-2"></i>Informations du rôle
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th class="text-muted" style="width: 30%;">ID :</th>
                                    <td><span class="badge bg-primary">{{ role.idRole }}</span></td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Libellé :</th>
                                    <td><strong>{{ role.libelle }}</strong></td>
                                </tr>
                                {% if role.description %}
                                <tr>
                                    <th class="text-muted">Description :</th>
                                    <td>{{ role.description }}</td>
                                </tr>
                                {% endif %}
                            </table>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="d-flex flex-column gap-3 sticky-top px-5" style="top: 20px;">
                                <h6 class="text-muted mb-0">Actions rapides</h6>
                                <a href="{{ path('app_role_edit', {'id_role': role.idRole}) }}" class="btn btn-warning btn-lg py-3" style="margin: 0 3rem;">
                                    <i class="fas fa-edit me-2"></i>Modifier
                                </a>
                                <a href="{{ path('app_role_index') }}" class="btn btn-secondary btn-lg py-3" style="margin: 0 3rem;">
                                    <i class="fas fa-arrow-left me-2"></i>Retour à la liste
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}