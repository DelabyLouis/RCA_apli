{% extends 'base.html.twig' %}

{% block title %}Modifier {{ role.libelle }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <h1 class="mb-4">
        <i class="fas fa-edit me-2 text-warning"></i>Modifier le rôle : {{ role.libelle }}
    </h1>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Modifier le rôle</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                    
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.libelle, 'Libellé') }}
                                {{ form_widget(form.libelle, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.libelle) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.hierarchy_level, 'Niveau hiérarchique') }}
                                {{ form_widget(form.hierarchy_level) }}
                                {{ form_errors(form.hierarchy_level) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.description, 'Description') }}
                                {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.description) }}
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-12">
                            <div class="mb-3">
                                {{ form_label(form.permissions) }}
                                
                                {% if role.hierarchyLevel >= 100 %}
                                <div class="alert alert-info mb-3">
                                    <i class="fas fa-shield-alt me-2"></i>
                                    <strong>Protection Administrateur :</strong> 
                                    Les administrateurs (niveau 100+) ont <strong>toujours accès à toutes les fonctionnalités</strong>, 
                                    indépendamment des permissions cochées ci-dessous. Cette protection évite le verrouillage accidentel.
                                </div>
                                {% endif %}
                                
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted">{{ form_help(form.permissions) }}</small>
                                    <div>
                                        <button type="button" class="btn btn-sm btn-outline-success" onclick="toggleAllPermissions(true)">
                                            Tout sélectionner
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="toggleAllPermissions(false)">
                                            Tout désélectionner
                                        </button>
                                    </div>
                                </div>
                                <div class="checkbox-container border rounded p-3" style="max-height: 400px; overflow-y: auto;">
                                    <div class="row">
                                        {% for permission in form.permissions %}
                                            <div class="col-md-6 col-lg-4 mb-2">
                                                <div class="form-check p-2 border rounded bg-light">
                                                    {{ form_widget(permission, {'attr': {'class': 'form-check-input me-2'}}) }}
                                                    {{ form_label(permission, null, {'label_attr': {'class': 'form-check-label small'}}) }}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                                {{ form_errors(form.permissions) }}
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <div>
                            <a href="{{ path('app_role_index') }}" class="btn btn-outline-secondary btn-lg me-2">
                                <i class="fas fa-list me-2"></i>Liste
                            </a>
                            <a href="{{ path('app_role_show', {'id_role': role.idRole}) }}" class="btn btn-outline-info btn-lg">
                                <i class="fas fa-eye me-2"></i>Affichage
                            </a>
                        </div>
                        <div>
                            <button type="submit" class="btn btn-warning btn-lg">
                                <i class="fas fa-save me-2"></i>Mettre à jour
                            </button>
                        </div>
                    </div>

                    {{ form_rest(form) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function toggleAllPermissions(selectAll) {
    const checkboxes = document.querySelectorAll('.checkbox-container input[type="checkbox"]');
    checkboxes.forEach(checkbox => {
        checkbox.checked = selectAll;
    });
}
</script>
{% endblock %}