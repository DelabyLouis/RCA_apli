{% extends 'base.html.twig' %}

{% block title %}Modifier {{ role.libelle }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <h1 class="mb-4">
        <i class="fas fa-edit me-2 text-warning"></i>Modifier le rôle : {{ role.libelle }}
    </h1>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Modifier le rôle</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                    
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.libelle, 'Libellé') }}
                                {{ form_widget(form.libelle, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.libelle) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.hierarchy_level, 'Niveau hiérarchique') }}
                                {{ form_widget(form.hierarchy_level) }}
                                {{ form_errors(form.hierarchy_level) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.description, 'Description') }}
                                {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.description) }}
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-12">
                            <div class="mb-3">
                                {{ form_label(form.permissions, 'Permissions accordées', {'label_attr': {'class': 'form-label'}}) }}
                                
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted">Sélectionnez les permissions pour ce rôle</small>
                                    <div>
                                        <button type="button" class="btn btn-sm btn-outline-success" onclick="toggleAllPermissions(true)">
                                            Tout sélectionner
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="toggleAllPermissions(false)">
                                            Tout désélectionner
                                        </button>
                                    </div>
                                </div>
                                
                                <div class="border rounded p-3" style="max-height: 400px; overflow-y: auto;">
                                    <div class="permissions-container">
                                        {% set frenchLabels = {
                                            'user_view': 'Voir les utilisateurs',
                                            'user_modify': 'Modifier les utilisateurs',
                                            'role_view': 'Voir les rôles',
                                            'role_modify': 'Modifier les rôles',
                                            'finance_management_view': 'Voir finances (exercices, transactions, types, modes)',
                                            'finance_management_modify': 'Modifier finances (exercices, transactions, types, modes)',
                                            'personne_view': 'Voir les personnes',
                                            'personne_modify': 'Modifier les personnes',
                                            'entreprise_view': 'Voir les entreprises',
                                            'entreprise_modify': 'Modifier les entreprises',
                                            'livret_view': 'Voir le livret',
                                            'livret_modify': 'Modifier le livret',
                                            'attestation_view': 'Voir les attestations',
                                            'attestation_modify': 'Modifier les attestations',
                                            'import_export_view': 'Voir import/export',
                                            'import_export_modify': 'Modifier import/export',
                                            'reports_view': 'Voir les rapports',
                                            'reports_modify': 'Modifier les rapports',
                                            'admin_system_view': 'Voir administration/permissions/RGPD',
                                            'admin_system_modify': 'Modifier administration/permissions/RGPD'
                                        } %}
                                        
                                        {% for permission in form.permissions %}
                                            <div class="permission-item">
                                                {{ form_widget(permission, {'attr': {'class': 'form-check-input'}}) }}
                                                <label for="{{ permission.vars.id }}" class="permission-label">
                                                    {{ frenchLabels[permission.vars.name] ?? permission.vars.label }}
                                                </label>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                                {{ form_errors(form.permissions) }}
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <div>
                            <a href="{{ path('app_role_index') }}" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-list me-2"></i>Liste
                            </a>
                            <a href="{{ path('app_role_show', {'id_role': role.idRole}) }}" class="btn btn-outline-info btn-lg">
                                <i class="fas fa-eye me-2"></i>Voir
                            </a>
                        </div>
                        <div>
                            <button type="submit" class="btn btn-warning btn-lg">
                                <i class="fas fa-save me-2"></i>Modifier
                            </button>
                        </div>
                    </div>

                    {{ form_rest(form) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function toggleAllPermissions(selectAll) {
    const checkboxes = document.querySelectorAll('input[type="checkbox"]');
    checkboxes.forEach(checkbox => {
        checkbox.checked = selectAll;
    });
}
</script>

<style>
.permissions-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
}

.permission-item {
    display: flex;
    align-items: center;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 5px;
}

.permission-item input[type="checkbox"] {
    width: 16px;
    height: 16px;
    margin-right: 8px;
    cursor: pointer;
}

.permission-label {
    font-weight: 600;
    color: white;
    font-size: 14px;
    margin: 0;
    cursor: pointer;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
}
</style>
{% endblock %}