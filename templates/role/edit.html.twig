{% extends 'base.html.twig' %}{% extends 'base.html.twig' %}



{% block title %}Modifier {{ role.libelle }}{% endblock %}{% block title %}Modifier {{ role.libelle }}{% endblock %}



{% block body %}{% block body %}

<div class="container-fluid"><div class="container-fluid">

    <div class="row">    <div class="row">

        <div class="col-12">        <div class="col-12">

            <div class="d-flex justify-content-between align-items-center mb-4">            <div class="card shadow-sm">

                <h1><i class="fas fa-edit me-2"></i>Modifier {{ role.libelle }}</h1>                <div class="card-header bg-warning text-dark">

                <a href="{{ path('app_role_index') }}" class="btn btn-secondary">                    <div class="d-flex justify-content-between align-items-center">

                    <i class="fas fa-arrow-left me-1"></i>Retour à la liste                        <h5 class="mb-0">

                </a>                            <i class="fas fa-edit me-2"></i>Modifier {{ role.libelle }}

            </div>                        </h5>

                        <div class="btn-group">

            {% if form.vars.errors|length > 0 %}                            <a href="{{ path('app_role_show', {'id_role': role.idRole}) }}" class="btn btn-info btn-sm">

                <div class="alert alert-danger alert-dismissible fade show" role="alert">                                <i class="fas fa-eye me-1"></i>Voir

                    <i class="fas fa-exclamation-triangle me-2"></i><strong>Erreurs de validation :</strong>                            </a>

                    <ul class="mb-0 mt-2">                            <a href="{{ path('app_role_index') }}" class="btn btn-light btn-sm">

                        {% for error in form.vars.errors %}                                <i class="fas fa-arrow-left me-1"></i>Retour à la liste

                            <li>{{ error.message }}</li>                            </a>

                        {% endfor %}                        </div>

                    </ul>                    </div>

                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>                </div>

                </div>                <div class="card-body">

            {% endif %}                    {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}

                    {{ form_rest(form) }}

            <div class="card shadow-sm">                    

                <div class="card-body">                    <div class="col-12">

                    <div class="row">                        <div class="d-flex gap-2">

                        <div class="col-lg-6">                            <button type="submit" class="btn btn-warning">

                            {{ form_start(form, {'attr': {'novalidate': false, 'id': 'role_edit_form'}}) }}                                <i class="fas fa-save me-1"></i>Mettre à jour

                                                        </button>

                            <div class="mb-3">                            <a href="{{ path('app_role_show', {'id_role': role.idRole}) }}" class="btn btn-info">

                                {{ form_label(form.libelle, 'Libellé', {'label_attr': {'class': 'form-label'}}) }}                                <i class="fas fa-eye me-1"></i>Voir

                                {{ form_widget(form.libelle, {'attr': {'class': 'form-control' ~ (form.libelle.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}                            </a>

                                {% if form.libelle.vars.errors|length > 0 %}                            <a href="{{ path('app_role_index') }}" class="btn btn-secondary">

                                    <div class="invalid-feedback">                                <i class="fas fa-times me-1"></i>Annuler

                                        {% for error in form.libelle.vars.errors %}                            </a>

                                            {{ error.message }}                        </div>

                                        {% endfor %}                    </div>

                                    </div>                    

                                {% endif %}                    {{ form_end(form) }}

                                {{ form_errors(form.libelle) }}                </div>

                            </div>            </div>

                                    </div>

                            <div class="mb-3">    </div>

                                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}</div>

                                {{ form_widget(form.description, {'attr': {'class': 'form-control' ~ (form.description.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}{% endblock %}
                                {% if form.description.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.description.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.description) }}
                            </div>
                            
                            {{ form_end(form) }}
                        </div>
                        
                        <div class="col-lg-6">
                            <div class="d-flex flex-column gap-3 sticky-top px-5" style="top: 20px;">
                                <h6 class="text-muted mb-0">Actions</h6>
                                <a href="{{ path('app_role_show', {'id_role': role.idRole}) }}" class="btn btn-info btn-lg py-3" style="margin: 0 3rem;">
                                    <i class="fas fa-eye me-2"></i>Voir le rôle
                                </a>
                                <a href="{{ path('app_role_index') }}" class="btn btn-secondary btn-lg py-3" style="margin: 0 3rem;">
                                    <i class="fas fa-times me-2"></i>Annuler
                                </a>
                                <button type="submit" class="btn btn-warning btn-lg py-3" style="margin: 0 3rem;" form="role_edit_form">
                                    <i class="fas fa-save me-2"></i>Mettre à jour
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}