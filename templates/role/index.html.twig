{% extends 'base.html.twig' %}

{% block title %}Gestion des Rôles et Permissions - RCA Application{% endblock %}

{% block body %}
    <style>
        #roles-table th:nth-child(1), #roles-table td:nth-child(1) { width: 120px !important; max-width: 120px !important; }
        #roles-table th:nth-child(2), #roles-table td:nth-child(2) { width: 180px !important; max-width: 180px !important; }
        #roles-table th:nth-child(3), #roles-table td:nth-child(3) { width: 200px !important; max-width: 200px !important; }
        #roles-table th:nth-child(4), #roles-table td:nth-child(4) { width: 120px !important; max-width: 120px !important; }
        
        #roles-table th:nth-child(1), #roles-table td:nth-child(1),
        #roles-table th:nth-child(2), #roles-table td:nth-child(2),
        #roles-table th:nth-child(3), #roles-table td:nth-child(3),
        #roles-table th:nth-child(4), #roles-table td:nth-child(4) {
            overflow: hidden !important;
            text-overflow: ellipsis !important;
            white-space: nowrap !important;
        }
        
        /* Marges pour le tableau */
        .container-fluid.mt-4 {
            padding-left: 8rem !important;
            padding-right: 8rem !important;
        }
    </style>
    
    <div class="container-fluid mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-primary">
                <i class="fas fa-user-shield me-2"></i>Gestion des Rôles et Permissions
            </h1>
            <div class="btn-group">
                <a href="{{ path('app_role_new') }}" class="btn btn-success btn-lg">
                    <i class="fas fa-plus me-2"></i>Nouveau Rôle
                </a>
                <a href="{{ path('app_permission_index') }}" class="btn btn-info btn-lg">
                    <i class="fas fa-key me-2"></i>Gérer les Permissions
                </a>
            </div>
        </div>

        <!-- Hiérarchie des Rôles -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-sitemap me-2"></i>Hiérarchie des Rôles
                    <small class="text-muted">(Du plus élevé au plus bas - Le rôle "Invité" gère l'accès public)</small>
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    {% set sorted_roles = roles|sort((a, b) => b.hierarchyLevel <=> a.hierarchyLevel) %}
                    {% for role in sorted_roles %}
                    <div class="col-md-4 mb-3">
                        {% set isGuestRole = role.libelle == 'Invité' %}
                        <div class="card {% if isGuestRole %}border-warning{% else %}border-primary{% endif %} h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="card-title mb-0">
                                        {{ role.libelle }}
                                        {% if isGuestRole %}<small class="text-muted">(Accès public)</small>{% endif %}
                                    </h6>
                                    <span class="badge {% if isGuestRole %}bg-warning text-dark{% else %}bg-primary{% endif %}">Niveau {{ role.hierarchyLevel }}</span>
                                </div>
                                <p class="card-text small text-muted">{{ role.description|default('Pas de description') }}</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-success">
                                        <i class="fas fa-users me-1"></i>{{ role.users|length }} utilisateur(s)
                                    </small>
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('app_role_show', {'id_role': role.idRole}) }}" class="btn btn-outline-info btn-sm">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('app_role_edit', {'id_role': role.idRole}) }}" class="btn btn-outline-warning btn-sm">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </div>
                                </div>
                                <div class="mt-2">
                                    <small class="text-info">
                                        <i class="fas fa-key me-1"></i>{{ role.permissions|length }} permission(s)
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% else %}
                    <div class="col-12">
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-inbox fa-2x mb-2"></i>
                            <p class="mb-0">Aucun rôle configuré</p>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>


{% endblock %}
