{% extends 'base.html.twig' %}

{% block title %}Nouveau Rôle{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-user-tag me-2"></i>Nouveau Rôle</h1>
                <a href="{{ path('app_role_index') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                </a>
            </div>

            {% if form.vars.errors|length > 0 %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i><strong>Erreurs de validation :</strong>
                    <ul class="mb-0 mt-2">
                        {% for error in form.vars.errors %}
                            <li>{{ error.message }}</li>
                        {% endfor %}
                    </ul>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endif %}

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-user-tag me-2"></i>Nouveau Rôle
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-6">
                            {{ form_start(form, {'attr': {'id': 'role_new_form'}}) }}
                            {{ form_rest(form) }}
                            {{ form_end(form) }}
                        </div>
                        
                        <div class="col-lg-6">
                            <div class="d-flex flex-column gap-3 sticky-top px-5" style="top: 20px;">
                                <h6 class="text-muted mb-0">Actions</h6>
                                <a href="{{ path('app_role_index') }}" class="btn btn-secondary btn-lg py-3" style="margin: 0 3rem;">
                                    <i class="fas fa-times me-2"></i>Annuler
                                </a>
                                <button type="submit" class="btn btn-success btn-lg py-3" style="margin: 0 3rem;" form="role_new_form">
                                    <i class="fas fa-save me-2"></i>Créer le rôle
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}