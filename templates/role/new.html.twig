{% extends 'base.html.twig' %}

{% block title %}Nouveau Rôle{% endblock %}

{% block body %}
<div class="container-fluid">
    <h1 class="mb-4">
        <i class="fas fa-user-tag me-2 text-success"></i>Nouveau Rôle
    </h1>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Créer un nouveau rôle</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                    
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.libelle, 'Libellé') }}
                                {{ form_widget(form.libelle, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.libelle) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.hierarchy_level, 'Niveau hiérarchique') }}
                                {{ form_widget(form.hierarchy_level) }}
                                {{ form_errors(form.hierarchy_level) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.description, 'Description') }}
                                {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.description) }}
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-12">
                            <div class="mb-3">
                                {{ form_label(form.permissions, 'Permissions accordées', {'label_attr': {'class': 'form-label'}}) }}
                                
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted">Sélectionnez les permissions pour ce rôle</small>
                                    <div>
                                        <button type="button" class="btn btn-sm btn-outline-success" onclick="toggleAllPermissions(true)">
                                            Tout sélectionner
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="toggleAllPermissions(false)">
                                            Tout désélectionner
                                        </button>
                                    </div>
                                </div>
                                
                                <div class="border rounded p-3" style="max-height: 400px; overflow-y: auto;">
                                    <div class="row">
                                        {{ form_widget(form.permissions, {'attr': {'class': 'permissions-grid'}}) }}
                                    </div>
                                </div>
                                {{ form_errors(form.permissions) }}
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <div>
                            <a href="{{ path('app_role_index') }}" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-list me-2"></i>Liste
                            </a>
                        </div>
                        <div>
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="fas fa-save me-2"></i>Créer le rôle
                            </button>
                        </div>
                    </div>

                    {{ form_rest(form) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function toggleAllPermissions(selectAll) {
    const checkboxes = document.querySelectorAll('input[type="checkbox"]');
    checkboxes.forEach(checkbox => {
        checkbox.checked = selectAll;
    });
}
</script>

<style>
.permissions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
}

.permissions-grid > div {
    padding: 12px;
    border: 2px solid #007bff;
    border-radius: 8px;
    background-color: #007bff;
    display: flex;
    align-items: center;
}

.permissions-grid label {
    font-weight: 600;
    color: white;
    font-size: 16px;
    margin: 0;
    margin-left: 8px;
    cursor: pointer;
}

.permissions-grid input[type="checkbox"] {
    width: 18px;
    height: 18px;
    margin: 0;
    cursor: pointer;
}
</style>
{% endblock %}