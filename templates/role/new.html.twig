{% extends 'base.html.twig' %}{% extends 'base.html.twig' %}



{% block title %}Nouveau Rôle{% endblock %}{% block title %}Nouveau Rôle{% endblock %}



{% block body %}{% block body %}

<div class="container-fluid"><div class="container-fluid">

    <div class="row">    <div class="row">

        <div class="col-12">        <div class="col-12">

            <div class="d-flex justify-content-between align-items-center mb-4">            <div class="card shadow-sm">

                <h1><i class="fas fa-user-tag me-2"></i>Nouveau Rôle</h1>                <div class="card-header bg-primary text-white">

                <a href="{{ path('app_role_index') }}" class="btn btn-secondary">                    <div class="d-flex justify-content-between align-items-center">

                    <i class="fas fa-arrow-left me-1"></i>Retour à la liste                        <h5 class="mb-0">

                </a>                            <i class="fas fa-user-tag me-2"></i>Nouveau Rôle

            </div>                        </h5>

                        <a href="{{ path('app_role_index') }}" class="btn btn-light btn-sm">

            {% if form.vars.errors|length > 0 %}                            <i class="fas fa-arrow-left me-1"></i>Retour à la liste

                <div class="alert alert-danger alert-dismissible fade show" role="alert">                        </a>

                    <i class="fas fa-exclamation-triangle me-2"></i><strong>Erreurs de validation :</strong>                    </div>

                    <ul class="mb-0 mt-2">                </div>

                        {% for error in form.vars.errors %}                <div class="card-body">

                            <li>{{ error.message }}</li>                    {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}

                        {% endfor %}                    {{ form_rest(form) }}

                    </ul>                    

                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>                    <div class="col-12">

                </div>                        <div class="d-flex gap-2">

            {% endif %}                            <button type="submit" class="btn btn-primary">

                                <i class="fas fa-save me-1"></i>Créer

            <div class="card shadow-sm">                            </button>

                <div class="card-body">                            <a href="{{ path('app_role_index') }}" class="btn btn-secondary">

                    <div class="row">                                <i class="fas fa-times me-1"></i>Annuler

                        <div class="col-lg-6">                            </a>

                            {{ form_start(form, {'attr': {'novalidate': false, 'id': 'role_new_form'}}) }}                        </div>

                                                </div>

                            <div class="mb-3">                    

                                {{ form_label(form.libelle, 'Libellé', {'label_attr': {'class': 'form-label'}}) }}                    {{ form_end(form) }}

                                {{ form_widget(form.libelle, {'attr': {'class': 'form-control' ~ (form.libelle.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}                </div>

                                {% if form.libelle.vars.errors|length > 0 %}            </div>

                                    <div class="invalid-feedback">        </div>

                                        {% for error in form.libelle.vars.errors %}    </div>

                                            {{ error.message }}</div>

                                        {% endfor %}{% endblock %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.libelle) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.description, {'attr': {'class': 'form-control' ~ (form.description.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.description.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.description.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.description) }}
                            </div>
                            
                            {{ form_end(form) }}
                        </div>
                        
                        <div class="col-lg-6">
                            <div class="d-flex flex-column gap-3 sticky-top px-5" style="top: 20px;">
                                <h6 class="text-muted mb-0">Actions</h6>
                                <a href="{{ path('app_role_index') }}" class="btn btn-secondary btn-lg py-3" style="margin: 0 3rem;">
                                    <i class="fas fa-times me-2"></i>Annuler
                                </a>
                                <button type="submit" class="btn btn-success btn-lg py-3" style="margin: 0 3rem;" form="role_new_form">
                                    <i class="fas fa-save me-2"></i>Créer le rôle
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}