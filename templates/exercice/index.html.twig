{% extends 'base.html.twig' %}

{% block title %}Exercices et Transactions{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .editable-field {
            cursor: pointer;
            padding: 5px;
            border: 1px solid transparent;
            border-radius: 3px;
            transition: all 0.2s;
        }
        
        .editable-field:hover {
            background-color: #f8f9fa;
            border-color: #dee2e6;
        }
        
        .editable-field.editing {
            background-color: #fff;
            border-color: #007bff;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
        }
        
        .editable-input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            font-size: inherit;
            font-family: inherit;
        }
        
        .saving {
            opacity: 0.6;
            pointer-events: none;
        }
        
        .alert {
            margin: 10px 0;
            padding: 10px;
            border-radius: 4px;
        }
        
        .alert-success {
            background-color: #d4edda;
            border-color: #c3e6cb;
            color: #155724;
        }
        
        .alert-danger {
            background-color: #f8d7da;
            border-color: #f5c6cb;
            color: #721c24;
        }
    </style>
{% endblock %}

{% block body %}
    <h1>Gestion des Exercices et Transactions</h1>
    
    <div id="message-container"></div>

    <div class="mb-3">
        <a href="{{ path('app_exercice_all_transactions') }}" class="btn btn-info">Voir toutes les transactions</a>
        <a href="{{ path('app_exercice_new') }}" class="btn btn-primary">Créer un nouvel exercice</a>
    </div>

    <table class="table" data-turbo="false">
        <thead>
            <tr>
                <th>ID</th>
                <th>Libellé</th>
                <th>Date début</th>
                <th>Date fin</th>
                <th>Nb transactions</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for exercice in exercices %}
            <tr data-id="{{ exercice.idExercice }}">
                <td>{{ exercice.idExercice }}</td>
                <td class="editable-field" data-field="libelle">{{ exercice.libelle }}</td>
                <td class="editable-field" data-field="date_debut">{{ exercice.dateDebut ? exercice.dateDebut|date('Y-m-d') : '' }}</td>
                <td class="editable-field" data-field="date_fin">{{ exercice.dateFin ? exercice.dateFin|date('Y-m-d') : '' }}</td>
                <td>
                    <span class="badge bg-secondary">{{ exercice.transactions|length }}</span>
                </td>
                <td>
                    <a href="{{ path('app_exercice_transactions', {'id_exercice': exercice.idExercice}) }}" class="btn btn-sm btn-success">Voir transactions</a>
                    <a href="{{ path('app_exercice_show', {'id_exercice': exercice.idExercice}) }}" class="btn btn-sm btn-info">Détails</a>
                    <a href="{{ path('app_exercice_edit', {'id_exercice': exercice.idExercice}) }}" class="btn btn-sm btn-warning">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">Aucun exercice trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            let currentEditingCell = null;
            let originalValue = '';
            
            function showMessage(message, type) {
                const container = document.getElementById('message-container');
                const alert = document.createElement('div');
                alert.className = `alert alert-${type}`;
                alert.textContent = message;
                container.appendChild(alert);
                
                setTimeout(() => {
                    alert.remove();
                }, 3000);
            }
            
            function saveField(cell, field, value, exerciceId) {
                const row = cell.closest('tr');
                row.classList.add('saving');
                
                fetch(`/exercice/${exerciceId}/update-field`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `field=${encodeURIComponent(field)}&value=${encodeURIComponent(value)}`
                })
                .then(response => response.json())
                .then(data => {
                    row.classList.remove('saving');
                    
                    if (data.success) {
                        cell.textContent = value || '';
                    } else {
                        cell.textContent = originalValue;
                        showMessage(data.message, 'danger');
                    }
                })
                .catch(error => {
                    row.classList.remove('saving');
                    cell.textContent = originalValue;
                    showMessage('Erreur de communication avec le serveur', 'danger');
                    console.error('Error:', error);
                });
            }
            
            function startEditing(cell) {
                if (currentEditingCell && currentEditingCell !== cell) {
                    stopEditing(currentEditingCell, false);
                }
                
                currentEditingCell = cell;
                originalValue = cell.textContent;
                
                cell.classList.add('editing');
                
                const input = document.createElement('input');
                input.className = 'editable-input';
                
                // Gérer les champs date
                if (cell.dataset.field.includes('date')) {
                    input.type = 'date';
                    input.value = originalValue;
                } else {
                    input.type = 'text';
                    input.value = originalValue;
                }
                
                cell.textContent = '';
                cell.appendChild(input);
                
                input.focus();
                if (input.type === 'text') {
                    input.select();
                }
                
                input.addEventListener('blur', function() {
                    stopEditing(cell, true);
                });
                
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        stopEditing(cell, true);
                    } else if (e.key === 'Escape') {
                        e.preventDefault();
                        stopEditing(cell, false);
                    }
                });
            }
            
            function stopEditing(cell, save) {
                if (!cell || !cell.classList.contains('editing')) return;
                
                const input = cell.querySelector('input');
                const newValue = input ? input.value.trim() : '';
                
                cell.classList.remove('editing');
                
                if (save && newValue !== originalValue) {
                    const field = cell.dataset.field;
                    const exerciceId = cell.closest('tr').dataset.id;
                    
                    if (field === 'libelle' && !newValue) {
                        showMessage('Le libellé ne peut pas être vide', 'danger');
                        cell.textContent = originalValue;
                    } else {
                        saveField(cell, field, newValue, exerciceId);
                    }
                } else {
                    cell.textContent = originalValue;
                }
                
                currentEditingCell = null;
            }
            
            document.querySelectorAll('.editable-field').forEach(cell => {
                cell.addEventListener('click', function() {
                    if (!this.classList.contains('editing')) {
                        startEditing(this);
                    }
                });
            });
            
            document.addEventListener('click', function(e) {
                if (currentEditingCell && !currentEditingCell.contains(e.target)) {
                    stopEditing(currentEditingCell, false);
                }
            });
        });
    </script>
{% endblock %}
