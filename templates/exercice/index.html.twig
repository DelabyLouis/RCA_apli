{% extends 'base.html.twig' %}

{% block title %}Gestion des exercices{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-calendar-alt me-2"></i>Gestion des exercices</h1>
                <a href="{{ path('app_exercice_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i>Nouvel exercice
                </a>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>ID</th>
                                    <th>Libellé</th>
                                    <th>Début</th>
                                    <th>Fin</th>
                                    <th>Statut</th>
                                    <th>Clôture</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for exercice in exercices %}
                                    <tr class="{% if exercice.clos %}table-secondary{% endif %}">
                                        <td>{{ exercice.idExercice }}</td>
                                        <td>
                                            {% if not exercice.clos %}
                                                <span class="editable-field" 
                                                      data-field="libelle" 
                                                      data-id="{{ exercice.idExercice }}" 
                                                      data-url="{{ path('app_exercice_update_field', {id_exercice: exercice.idExercice}) }}">
                                                    {{ exercice.libelle }}
                                                </span>
                                            {% else %}
                                                {{ exercice.libelle }}
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if not exercice.clos %}
                                                <span class="editable-field" 
                                                      data-field="dateDebut" 
                                                      data-id="{{ exercice.idExercice }}" 
                                                      data-url="{{ path('app_exercice_update_field', {id_exercice: exercice.idExercice}) }}">
                                                    {{ exercice.dateDebut ? exercice.dateDebut|date('d/m/Y') : '' }}
                                                </span>
                                            {% else %}
                                                {{ exercice.dateDebut ? exercice.dateDebut|date('d/m/Y') : '' }}
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if not exercice.clos %}
                                                <span class="editable-field" 
                                                      data-field="dateFin" 
                                                      data-id="{{ exercice.idExercice }}" 
                                                      data-url="{{ path('app_exercice_update_field', {id_exercice: exercice.idExercice}) }}">
                                                    {{ exercice.dateFin ? exercice.dateFin|date('d/m/Y') : '' }}
                                                </span>
                                            {% else %}
                                                {{ exercice.dateFin ? exercice.dateFin|date('d/m/Y') : '' }}
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if exercice.clos %}
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-lock me-1"></i>CLÔTURÉ
                                                </span>
                                            {% else %}
                                                <span class="badge bg-success">
                                                    <i class="fas fa-unlock me-1"></i>OUVERT
                                                </span>
                                            {% endif %}
                                        </td>
                                        <td class="text-center">
                                            {% if not exercice.clos %}
                                                <button type="button" 
                                                        class="btn btn-warning" 
                                                        title="Clôturer cet exercice"
                                                        onclick="cloturerExercice({{ exercice.idExercice }}, '{{ exercice.libelle }}')">
                                                    <i class="fas fa-lock me-1"></i>Clôturer
                                                </button>
                                            {% else %}
                                                <button type="button" 
                                                        class="btn btn-success" 
                                                        title="Déclôturer cet exercice"
                                                        onclick="decloturerExercice({{ exercice.idExercice }}, '{{ exercice.libelle }}')">
                                                    <i class="fas fa-unlock me-1"></i>Déclôturer
                                                </button>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if not exercice.clos %}
                                                <button type="button" 
                                                        class="btn btn-outline-danger btn-sm" 
                                                        title="Supprimer l'exercice"
                                                        onclick="if(confirm('Êtes-vous sûr de vouloir supprimer cet exercice ?')) { 
                                                            var form = document.createElement('form');
                                                            form.method = 'POST';
                                                            form.action = '{{ path('app_exercice_delete', {id_exercice: exercice.idExercice}) }}';
                                                            var token = document.createElement('input');
                                                            token.type = 'hidden';
                                                            token.name = '_token';
                                                            token.value = '{{ csrf_token('delete' ~ exercice.idExercice) }}';
                                                            form.appendChild(token);
                                                            document.body.appendChild(form);
                                                            form.submit();
                                                        }">
                                                    <i class="fas fa-trash me-1"></i>Supprimer
                                                </button>
                                            {% else %}
                                                <span class="btn btn-outline-secondary btn-sm disabled" title="Suppression interdite">
                                                    <i class="fas fa-trash me-1"></i>Supprimer
                                                </span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">
                                            <i class="fas fa-inbox fa-3x mb-3"></i>
                                            <br>Aucun exercice trouvé
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Fonctions pour clôturer et déclôturer directement
function cloturerExercice(exerciceId, exerciceNom) {
    if (!confirm(`Voulez-vous vraiment clôturer l'exercice "${exerciceNom}" ?`)) {
        return;
    }

    fetch('/historique-cloture/cloturer/' + exerciceId, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            commentaire: ''
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Erreur : ' + (data.message || 'Impossible de clôturer l\'exercice'));
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Erreur de communication avec le serveur');
    });
}

function decloturerExercice(exerciceId, exerciceNom) {
    if (!confirm(`Voulez-vous vraiment déclôturer l'exercice "${exerciceNom}" ?`)) {
        return;
    }

    fetch('/historique-cloture/decloturer/' + exerciceId, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            commentaire: ''
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Erreur : ' + (data.message || 'Impossible de déclôturer l\'exercice'));
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Erreur de communication avec le serveur');
    });
}

// Gestion de l'édition inline
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.editable-field').forEach(function(element) {
        element.addEventListener('click', function() {
            if (this.querySelector('input') || this.querySelector('select')) {
                return;
            }
            
            const field = this.dataset.field;
            const currentValue = this.textContent.trim();
            const url = this.dataset.url;
            const exerciceId = this.dataset.id;
            
            if (field === 'dateDebut' || field === 'dateFin') {
                let isoValue = '';
                if (currentValue && currentValue !== '') {
                    const parts = currentValue.split('/');
                    if (parts.length === 3) {
                        isoValue = parts[2] + '-' + parts[1].padStart(2, '0') + '-' + parts[0].padStart(2, '0');
                    }
                }
                
                this.innerHTML = '<input type="date" class="form-control form-control-sm" value="' + isoValue + '" style="min-width: 150px;">';
            } else {
                this.innerHTML = '<input type="text" class="form-control form-control-sm" value="' + currentValue + '" style="min-width: 150px;">';
            }
            
            const input = this.querySelector('input');
            input.focus();
            
            const saveValue = () => {
                const newValue = input.value;
                
                fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: 'field=' + field + '&value=' + encodeURIComponent(newValue)
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (field === 'dateDebut' || field === 'dateFin') {
                            if (newValue) {
                                const date = new Date(newValue);
                                const formattedDate = date.toLocaleDateString('fr-FR');
                                element.textContent = formattedDate;
                            } else {
                                element.textContent = '';
                            }
                        } else {
                            element.textContent = newValue;
                        }
                    } else {
                        alert('Erreur lors de la sauvegarde : ' + data.message);
                        element.textContent = currentValue;
                    }
                })
                .catch(error => {
                    alert('Erreur de connexion');
                    element.textContent = currentValue;
                });
            };
            
            input.addEventListener('blur', saveValue);
            input.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    saveValue();
                }
                if (e.key === 'Escape') {
                    element.textContent = currentValue;
                }
            });
        });
    });
});
</script>

<style>
.timeline {
    position: relative;
    padding-left: 30px;
}

.timeline-item {
    position: relative;
    margin-bottom: 20px;
}

.timeline-item:not(:last-child)::before {
    content: '';
    position: absolute;
    left: -19px;
    top: 30px;
    height: calc(100% + 10px);
    width: 2px;
    background-color: #dee2e6;
}

.timeline-marker {
    position: absolute;
    left: -30px;
    top: 5px;
}

.timeline-content {
    background-color: #f8f9fa;
    border-radius: 8px;
    padding: 15px;
    border-left: 4px solid #dee2e6;
}

.editable-field:hover {
    background-color: #f8f9fa;
    cursor: pointer;
    border-radius: 3px;
    padding: 2px 4px;
}

.table-secondary {
    --bs-table-bg: #f8f9fa;
}
</style>
{% endblock %}
