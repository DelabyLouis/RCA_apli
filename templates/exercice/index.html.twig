{% extends 'base.html.twig' %}

{% block title %}Gestion des exercices{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-calendar-alt me-2"></i>Gestion des exercices</h1>
                <a href="{{ path('app_exercice_new') }}" class="btn btn-success">
                    <i class="fas fa-plus me-1"></i>Nouvel exercice
                </a>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            <div class="card shadow-sm">
                <div class="card-body">
                    <!-- Filtres personnalisés -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filtres</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <!-- Filtre Libellé -->
                                <div class="col-md-3 mb-3">
                                    <label for="filter-libelle" class="form-label">Libellé</label>
                                    <input type="text" class="form-control" id="filter-libelle" placeholder="Rechercher par libellé...">
                                </div>
                                
                                <!-- Filtre Statut -->
                                <div class="col-md-3 mb-3">
                                    <label for="filter-statut" class="form-label">Statut</label>
                                    <select class="form-select" id="filter-statut">
                                        <option value="">Tous les statuts</option>
                                        <option value="ouvert">Ouvert</option>
                                        <option value="clos">Clôturé</option>
                                    </select>
                                </div>
                                
                                <!-- Filtre Date de début -->
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">Date de début</label>
                                    <div class="input-group input-group-sm">
                                        <input type="date" class="form-control" id="filter-date-debut-min" placeholder="Date min">
                                        <span class="input-group-text">-</span>
                                        <input type="date" class="form-control" id="filter-date-debut-max" placeholder="Date max">
                                    </div>
                                </div>
                                
                                <!-- Filtre Date de fin -->
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">Date de fin</label>
                                    <div class="input-group input-group-sm">
                                        <input type="date" class="form-control" id="filter-date-fin-min" placeholder="Date min">
                                        <span class="input-group-text">-</span>
                                        <input type="date" class="form-control" id="filter-date-fin-max" placeholder="Date max">
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-12">
                                    <button type="button" class="btn btn-primary me-2" id="apply-filters">
                                        <i class="fas fa-search me-1"></i>Filtrer
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" id="clear-filters">
                                        <i class="fas fa-times me-1"></i>Effacer les filtres
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="table-responsive">
                        <table class="table table-hover table-exercices">
                            <thead class="table-dark">
                                <tr>
                                    <th class="text-center">N°</th>
                                    <th class="text-center">Libellé</th>
                                    <th class="text-center">Début</th>
                                    <th class="text-center">Fin</th>
                                    <th class="text-center">Statut</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for exercice in exercices %}
                                    <tr class="{% if exercice.clos %}table-secondary{% endif %}">
                                        <td class="text-center"><strong>{{ exercice.numeroOrdre }}</strong></td>
                                        <td class="text-center">
                                            {% if not exercice.clos %}
                                                <span class="editable-field" 
                                                      data-field="libelle" 
                                                      data-id="{{ exercice.idExercice }}" 
                                                      data-url="{{ path('app_exercice_update_field', {id_exercice: exercice.idExercice}) }}">
                                                    {{ exercice.libelle }}
                                                </span>
                                            {% else %}
                                                {{ exercice.libelle }}
                                            {% endif %}
                                        </td>
                                        <td class="text-center">
                                            {% if not exercice.clos %}
                                                <span class="editable-field" 
                                                      data-field="dateDebut" 
                                                      data-id="{{ exercice.idExercice }}" 
                                                      data-url="{{ path('app_exercice_update_field', {id_exercice: exercice.idExercice}) }}">
                                                    {{ exercice.dateDebut ? exercice.dateDebut|date('d/m/Y') : '' }}
                                                </span>
                                            {% else %}
                                                {{ exercice.dateDebut ? exercice.dateDebut|date('d/m/Y') : '' }}
                                            {% endif %}
                                        </td>
                                        <td class="text-center">
                                            {% if not exercice.clos %}
                                                <span class="editable-field" 
                                                      data-field="dateFin" 
                                                      data-id="{{ exercice.idExercice }}" 
                                                      data-url="{{ path('app_exercice_update_field', {id_exercice: exercice.idExercice}) }}">
                                                    {{ exercice.dateFin ? exercice.dateFin|date('d/m/Y') : '' }}
                                                </span>
                                            {% else %}
                                                {{ exercice.dateFin ? exercice.dateFin|date('d/m/Y') : '' }}
                                            {% endif %}
                                        </td>
                                        <td class="text-center">
                                            {% if exercice.clos %}
                                                <button type="button" 
                                                        class="btn btn-statut-exercice btn-statut-clos" 
                                                        title="Exercice clôturé - Cliquer pour déclôturer"
                                                        onclick="decloturerExercice({{ exercice.idExercice }}, '{{ exercice.libelle }}')">
                                                    <i class="fas fa-lock me-2"></i>CLÔTURÉ
                                                </button>
                                            {% else %}
                                                <button type="button" 
                                                        class="btn btn-statut-exercice btn-statut-ouvert" 
                                                        title="Exercice ouvert - Cliquer pour clôturer"
                                                        onclick="cloturerExercice({{ exercice.idExercice }}, '{{ exercice.libelle }}')">
                                                    <i class="fas fa-unlock me-2"></i>OUVERT
                                                </button>
                                            {% endif %}
                                        </td>
                                        <td class="text-center">
                                            <button type="button" 
                                                    class="btn btn-warning btn-sm btn-transactions-exercice" 
                                                    title="Voir les transactions de cet exercice"
                                                    onclick="window.location.href='{{ path('app_transaction_index') }}?exercice_id={{ exercice.idExercice }}'">
                                                <i class="fas fa-list me-1"></i>Transactions
                                            </button>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            <i class="fas fa-inbox fa-3x mb-3"></i>
                                            <br>Aucun exercice trouvé
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Section Historique des clôtures récentes -->
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-history me-2"></i>Historique récent des clôtures
                    </h5>
                </div>
                <div class="card-body">
                    <div id="historiqueRecent">
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Chargement...</span>
                            </div>
                            <p class="mt-2 text-muted">Chargement de l'historique...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Fonctions pour clôturer et déclôturer directement
function cloturerExercice(exerciceId, exerciceNom) {
    if (!confirm(`Voulez-vous vraiment clôturer l'exercice "${exerciceNom}" ?`)) {
        return;
    }

    fetch('/historique-cloture/cloturer/' + exerciceId, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            commentaire: ''
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Erreur : ' + (data.message || 'Impossible de clôturer l\'exercice'));
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Erreur de communication avec le serveur');
    });
}

function decloturerExercice(exerciceId, exerciceNom) {
    if (!confirm(`Voulez-vous vraiment déclôturer l'exercice "${exerciceNom}" ?`)) {
        return;
    }

    fetch('/historique-cloture/decloturer/' + exerciceId, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            commentaire: ''
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Erreur : ' + (data.message || 'Impossible de déclôturer l\'exercice'));
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Erreur de communication avec le serveur');
    });
}

// Gestion de l'édition inline
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.editable-field').forEach(function(element) {
        element.addEventListener('click', function() {
            if (this.querySelector('input') || this.querySelector('select')) {
                return;
            }
            
            const field = this.dataset.field;
            const currentValue = this.textContent.trim();
            const url = this.dataset.url;
            const exerciceId = this.dataset.id;
            
            if (field === 'dateDebut' || field === 'dateFin') {
                let isoValue = '';
                if (currentValue && currentValue !== '') {
                    const parts = currentValue.split('/');
                    if (parts.length === 3) {
                        isoValue = parts[2] + '-' + parts[1].padStart(2, '0') + '-' + parts[0].padStart(2, '0');
                    }
                }
                
                this.innerHTML = '<input type="date" class="form-control form-control-sm" value="' + isoValue + '" style="min-width: 150px;">';
            } else {
                this.innerHTML = '<input type="text" class="form-control form-control-sm" value="' + currentValue + '" style="min-width: 150px;">';
            }
            
            const input = this.querySelector('input');
            input.focus();
            
            const saveValue = () => {
                const newValue = input.value;
                
                fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: 'field=' + field + '&value=' + encodeURIComponent(newValue)
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (field === 'dateDebut' || field === 'dateFin') {
                            if (newValue) {
                                const date = new Date(newValue);
                                const formattedDate = date.toLocaleDateString('fr-FR');
                                element.textContent = formattedDate;
                            } else {
                                element.textContent = '';
                            }
                        } else {
                            element.textContent = newValue;
                        }
                    } else {
                        alert('Erreur lors de la sauvegarde : ' + data.message);
                        element.textContent = currentValue;
                    }
                })
                .catch(error => {
                    alert('Erreur de connexion');
                    element.textContent = currentValue;
                });
            };
            
            input.addEventListener('blur', saveValue);
            input.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    saveValue();
                }
                if (e.key === 'Escape') {
                    element.textContent = currentValue;
                }
            });
        });
    });
});

// Charger l'historique récent au chargement de la page
function chargerHistoriqueRecent() {
    fetch('/historique-cloture/historique-recent')
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                afficherHistoriqueRecent(data.historiques);
            } else {
                document.getElementById('historiqueRecent').innerHTML = 
                    '<div class="alert alert-warning">' +
                    '<i class="fas fa-exclamation-triangle me-2"></i>Aucun historique récent disponible' +
                    '</div>';
            }
        })
        .catch(error => {
            document.getElementById('historiqueRecent').innerHTML = 
                '<div class="alert alert-danger">' +
                '<i class="fas fa-exclamation-triangle me-2"></i>Erreur lors du chargement de l\'historique' +
                '</div>';
        });
}

function afficherHistoriqueRecent(historiques) {
    if (historiques.length === 0) {
        document.getElementById('historiqueRecent').innerHTML = 
            '<div class="text-center text-muted py-3">' +
            '<i class="fas fa-inbox fa-2x mb-2"></i><br>' +
            'Aucune clôture récente' +
            '</div>';
        return;
    }

    let html = '<div class="row">';
    
    historiques.slice(0, 10).forEach((item, index) => {
        const isClotured = item.type_action === 'CLOTURE';
        const iconClass = isClotured ? 'fas fa-lock' : 'fas fa-unlock';
        const badgeClass = isClotured ? 'bg-danger' : 'bg-success';
        const date = new Date(item.date_action);
        
        html += '<div class="col-md-6 col-lg-4 mb-3">';
        html += '<div class="card border-start border-4 ' + (isClotured ? 'border-danger' : 'border-success') + '">';
        html += '<div class="card-body p-3">';
        html += '<div class="d-flex align-items-center mb-2">';
        html += '<span class="badge ' + badgeClass + ' me-2"><i class="' + iconClass + '"></i></span>';
        html += '<h6 class="mb-0">' + (isClotured ? 'Clôture' : 'Déclôture') + '</h6>';
        html += '</div>';
        html += '<p class="mb-1 fw-bold">' + item.exercice_libelle + '</p>';
        html += '<p class="mb-1 text-muted small">';
        html += '<i class="fas fa-calendar me-1"></i>' + date.toLocaleDateString('fr-FR');
        html += ' <i class="fas fa-clock ms-2 me-1"></i>' + date.toLocaleTimeString('fr-FR', {hour: '2-digit', minute: '2-digit'});
        html += '</p>';
        if (item.user) {
            html += '<p class="mb-0 text-muted small">';
            html += '<i class="fas fa-user me-1"></i>' + item.user;
            html += '</p>';
        }
        if (item.commentaire) {
            html += '<p class="mb-0 mt-2 small">' + item.commentaire + '</p>';
        }
        html += '</div></div></div>';
    });
    
    html += '</div>';
    document.getElementById('historiqueRecent').innerHTML = html;
}

// Charger l'historique au chargement de la page
window.addEventListener('load', chargerHistoriqueRecent);

// Gestion du filtrage personnalisé pour les exercices
document.addEventListener('DOMContentLoaded', function() {
    // Fonction de filtrage
    function applyFilters() {
        const libelleFilter = document.getElementById('filter-libelle').value.toLowerCase();
        const statutFilter = document.getElementById('filter-statut').value;
        const dateDebutMinFilter = document.getElementById('filter-date-debut-min').value;
        const dateDebutMaxFilter = document.getElementById('filter-date-debut-max').value;
        const dateFinMinFilter = document.getElementById('filter-date-fin-min').value;
        const dateFinMaxFilter = document.getElementById('filter-date-fin-max').value;
        
        const rows = document.querySelectorAll('tbody tr[class]');
        let visibleCount = 0;
        
        rows.forEach(row => {
            let showRow = true;
            const cells = row.cells;
            
            // Filtre par libellé (colonne 1)
            if (libelleFilter && cells[1]) {
                const libelle = cells[1].textContent.toLowerCase();
                if (!libelle.includes(libelleFilter)) {
                    showRow = false;
                }
            }
            
            // Filtre par statut (colonne 4)
            if (statutFilter && cells[4]) {
                const statut = cells[4].textContent.trim().toLowerCase();
                const isOuvert = statut.includes('ouvert') || statut.includes('actif');
                const isClos = statut.includes('clôturé') || statut.includes('fermé') || statut.includes('clos');
                
                if (statutFilter === 'ouvert' && !isOuvert) {
                    showRow = false;
                } else if (statutFilter === 'clos' && !isClos) {
                    showRow = false;
                }
            }
            
            // Filtre par plage de date de début (colonne 2)
            if ((dateDebutMinFilter || dateDebutMaxFilter) && cells[2]) {
                const dateDebut = cells[2].textContent.trim();
                if (dateDebut && dateDebut !== '-') {
                    // Convertir la date de la cellule (format DD/MM/YYYY vers YYYY-MM-DD)
                    let cellDate;
                    if (dateDebut.includes('/')) {
                        const parts = dateDebut.split('/');
                        cellDate = new Date(parts[2] + '-' + parts[1].padStart(2, '0') + '-' + parts[0].padStart(2, '0'));
                    } else {
                        cellDate = new Date(dateDebut);
                    }
                    
                    // Vérifier la date minimum
                    if (dateDebutMinFilter) {
                        const filterMinDate = new Date(dateDebutMinFilter);
                        if (cellDate < filterMinDate) {
                            showRow = false;
                        }
                    }
                    
                    // Vérifier la date maximum
                    if (dateDebutMaxFilter) {
                        const filterMaxDate = new Date(dateDebutMaxFilter);
                        if (cellDate > filterMaxDate) {
                            showRow = false;
                        }
                    }
                }
            }
            
            // Filtre par plage de date de fin (colonne 3)
            if ((dateFinMinFilter || dateFinMaxFilter) && cells[3]) {
                const dateFin = cells[3].textContent.trim();
                if (dateFin && dateFin !== '-') {
                    // Convertir la date de la cellule (format DD/MM/YYYY vers YYYY-MM-DD)
                    let cellDate;
                    if (dateFin.includes('/')) {
                        const parts = dateFin.split('/');
                        cellDate = new Date(parts[2] + '-' + parts[1].padStart(2, '0') + '-' + parts[0].padStart(2, '0'));
                    } else {
                        cellDate = new Date(dateFin);
                    }
                    
                    // Vérifier la date minimum
                    if (dateFinMinFilter) {
                        const filterMinDate = new Date(dateFinMinFilter);
                        if (cellDate < filterMinDate) {
                            showRow = false;
                        }
                    }
                    
                    // Vérifier la date maximum
                    if (dateFinMaxFilter) {
                        const filterMaxDate = new Date(dateFinMaxFilter);
                        if (cellDate > filterMaxDate) {
                            showRow = false;
                        }
                    }
                }
            }
            
            row.style.display = showRow ? '' : 'none';
            if (showRow) visibleCount++;
        });
        
        // Mettre à jour le compteur
        updateFilterInfo(visibleCount, rows.length);
        
        console.log(`Filtrage appliqué: ${visibleCount} exercices affichés sur ${rows.length}`);
    }
    
    // Fonction pour effacer tous les filtres
    function clearAllFilters() {
        document.getElementById('filter-libelle').value = '';
        document.getElementById('filter-statut').value = '';
        document.getElementById('filter-date-debut-min').value = '';
        document.getElementById('filter-date-debut-max').value = '';
        document.getElementById('filter-date-fin-min').value = '';
        document.getElementById('filter-date-fin-max').value = '';
        
        // Afficher toutes les lignes
        const rows = document.querySelectorAll('tbody tr[class]');
        rows.forEach(row => {
            row.style.display = '';
        });
        
        updateFilterInfo(rows.length, rows.length);
        console.log('Tous les filtres ont été effacés');
    }
    
    // Fonction pour mettre à jour les informations de filtrage
    function updateFilterInfo(visible, total) {
        // Créer ou mettre à jour l'élément d'information s'il n'existe pas
        let infoElement = document.getElementById('filter-results-info');
        if (!infoElement) {
            infoElement = document.createElement('div');
            infoElement.id = 'filter-results-info';
            infoElement.className = 'text-muted small mt-2';
            document.querySelector('.card-body').appendChild(infoElement);
        }
        
        // Recompter le total réel pour s'assurer de la précision
        const realTotal = document.querySelectorAll('tbody tr[class]').length;
        
        if (visible === realTotal) {
            infoElement.innerHTML = `<i class="fas fa-list me-1"></i>Tous les ${realTotal} exercices affichés`;
        } else {
            infoElement.innerHTML = `<i class="fas fa-filter me-1"></i>${visible} sur ${realTotal} exercices affichés`;
        }
    }
    
    // Event listeners pour les boutons
    document.getElementById('apply-filters').addEventListener('click', function() {
        applyFilters();
        
        // Feedback visuel
        const btn = this;
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check me-1"></i>Filtres appliqués';
        btn.classList.add('btn-success');
        btn.classList.remove('btn-primary');
        
        setTimeout(() => {
            btn.innerHTML = originalText;
            btn.classList.add('btn-primary');
            btn.classList.remove('btn-success');
        }, 1500);
    });
    
    document.getElementById('clear-filters').addEventListener('click', function() {
        clearAllFilters();
        
        // Feedback visuel
        const btn = this;
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check me-1"></i>Filtres effacés';
        btn.classList.add('btn-success');
        btn.classList.remove('btn-outline-secondary');
        
        setTimeout(() => {
            btn.innerHTML = originalText;
            btn.classList.add('btn-outline-secondary');
            btn.classList.remove('btn-success');
        }, 1500);
    });
    
    // Appliquer les filtres en temps réel pour le libellé
    document.getElementById('filter-libelle').addEventListener('input', function() {
        if (this.value.length === 0 || this.value.length >= 2) {
            applyFilters();
        }
    });
    
    // Appliquer les filtres automatiquement pour les autres champs
    document.getElementById('filter-statut').addEventListener('change', applyFilters);
    document.getElementById('filter-date-debut-min').addEventListener('change', applyFilters);
    document.getElementById('filter-date-debut-max').addEventListener('change', applyFilters);
    document.getElementById('filter-date-fin-min').addEventListener('change', applyFilters);
    document.getElementById('filter-date-fin-max').addEventListener('change', applyFilters);
    
    // Permettre l'application des filtres avec la touche Entrée
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && (e.target.id.startsWith('filter-'))) {
            e.preventDefault();
            applyFilters();
        }
    });
    
    // Initialiser l'affichage des informations
    const totalRows = document.querySelectorAll('tbody tr[class]').length;
    updateFilterInfo(totalRows, totalRows);
});
</script>

<style>
.timeline {
    position: relative;
    padding-left: 30px;
}

.timeline-item {
    position: relative;
    margin-bottom: 20px;
}

.timeline-item:not(:last-child)::before {
    content: '';
    position: absolute;
    left: -19px;
    top: 30px;
    height: calc(100% + 10px);
    width: 2px;
    background-color: #dee2e6;
}

.timeline-marker {
    position: absolute;
    left: -30px;
    top: 5px;
}

.timeline-content {
    background-color: #f8f9fa;
    border-radius: 8px;
    padding: 15px;
    border-left: 4px solid #dee2e6;
}

.editable-field:hover {
    background-color: #f8f9fa;
    cursor: pointer;
    border-radius: 3px;
    padding: 2px 4px;
}

.table-secondary {
    --bs-table-bg: #f8f9fa;
}
</style>
{% endblock %}
