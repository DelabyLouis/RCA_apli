{% extends 'base.html.twig' %}

{% block title %}Exercice index{% endblock %}

{% block body %}
    <h1>Exercice index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id_exercice</th>
                <th>Libelle</th>
                <th>Date_debut</th>
                <th>Date_fin</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for exercice in exercices %}
            <tr>
                <td>{{ exercice.idExercice }}</td>
                <td>{{ exercice.libelle }}</td>
                <td>{{ exercice.dateDebut ? exercice.dateDebut|date('Y-m-d') : '' }}</td>
                <td>{{ exercice.dateFin ? exercice.dateFin|date('Y-m-d') : '' }}</td>
                <td>
                    <a href="{{ path('app_exercice_show', {'id_exercice': exercice.idExercice}) }}">show</a>
                    <a href="{{ path('app_exercice_edit', {'id_exercice': exercice.idExercice}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_exercice_new') }}">Create new</a>
{% endblock %}
