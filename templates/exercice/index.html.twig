{% extends 'base.html.twig' %}

{% block title %}Gestion des exercices{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-calendar-alt me-2"></i>Gestion des exercices</h1>
                <a href="{{ path('app_exercice_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i>Nouvel exercice
                </a>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            <div class="card shadow-sm">
                <div class="card-body">
                    {{ include('components/entity_filter_detailed.html.twig', {
                        'filters': [
                            {
                                'field': 'libelle',
                                'label': 'Libellé',
                                'type': 'text',
                                'placeholder': 'Rechercher par libellé...',
                                'width': 4
                            },
                            {
                                'field': 'annee',
                                'label': 'Année',
                                'type': 'number',
                                'width': 2
                            },
                            {
                                'field': 'statut',
                                'label': 'Statut',
                                'type': 'select',
                                'width': 3,
                                'options': [
                                    { 'value': 'ouvert', 'label': 'Ouvert' },
                                    { 'value': 'clos', 'label': 'Clôturé' }
                                ]
                            },
                            {
                                'field': 'date_creation',
                                'label': 'Date de création',
                                'type': 'date',
                                'width': 3
                            }
                        ]
                    }) }}
                    
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>N°</th>
                                    <th>Libellé</th>
                                    <th>Début</th>
                                    <th>Fin</th>
                                    <th>Statut</th>
                                    <th>Clôture</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for exercice in exercices %}
                                    <tr class="{% if exercice.clos %}table-secondary{% endif %}">
                                        <td><strong>{{ exercice.numeroOrdre }}</strong></td>
                                        <td>
                                            {% if not exercice.clos %}
                                                <span class="editable-field" 
                                                      data-field="libelle" 
                                                      data-id="{{ exercice.idExercice }}" 
                                                      data-url="{{ path('app_exercice_update_field', {id_exercice: exercice.idExercice}) }}">
                                                    {{ exercice.libelle }}
                                                </span>
                                            {% else %}
                                                {{ exercice.libelle }}
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if not exercice.clos %}
                                                <span class="editable-field" 
                                                      data-field="dateDebut" 
                                                      data-id="{{ exercice.idExercice }}" 
                                                      data-url="{{ path('app_exercice_update_field', {id_exercice: exercice.idExercice}) }}">
                                                    {{ exercice.dateDebut ? exercice.dateDebut|date('d/m/Y') : '' }}
                                                </span>
                                            {% else %}
                                                {{ exercice.dateDebut ? exercice.dateDebut|date('d/m/Y') : '' }}
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if not exercice.clos %}
                                                <span class="editable-field" 
                                                      data-field="dateFin" 
                                                      data-id="{{ exercice.idExercice }}" 
                                                      data-url="{{ path('app_exercice_update_field', {id_exercice: exercice.idExercice}) }}">
                                                    {{ exercice.dateFin ? exercice.dateFin|date('d/m/Y') : '' }}
                                                </span>
                                            {% else %}
                                                {{ exercice.dateFin ? exercice.dateFin|date('d/m/Y') : '' }}
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if exercice.clos %}
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-lock me-1"></i>CLÔTURÉ
                                                </span>
                                            {% else %}
                                                <span class="badge bg-success">
                                                    <i class="fas fa-unlock me-1"></i>OUVERT
                                                </span>
                                            {% endif %}
                                        </td>
                                        <td class="text-center">
                                            {% if not exercice.clos %}
                                                <button type="button" 
                                                        class="btn btn-warning" 
                                                        title="Clôturer cet exercice"
                                                        onclick="cloturerExercice({{ exercice.idExercice }}, '{{ exercice.libelle }}')">
                                                    <i class="fas fa-lock me-1"></i>Clôturer
                                                </button>
                                            {% else %}
                                                <button type="button" 
                                                        class="btn btn-success" 
                                                        title="Déclôturer cet exercice"
                                                        onclick="decloturerExercice({{ exercice.idExercice }}, '{{ exercice.libelle }}')">
                                                    <i class="fas fa-unlock me-1"></i>Déclôturer
                                                </button>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if not exercice.clos %}
                                                <button type="button" 
                                                        class="btn btn-outline-danger btn-sm" 
                                                        title="Supprimer l'exercice"
                                                        onclick="if(confirm('Êtes-vous sûr de vouloir supprimer cet exercice ?')) { 
                                                            var form = document.createElement('form');
                                                            form.method = 'POST';
                                                            form.action = '{{ path('app_exercice_delete', {id_exercice: exercice.idExercice}) }}';
                                                            var token = document.createElement('input');
                                                            token.type = 'hidden';
                                                            token.name = '_token';
                                                            token.value = '{{ csrf_token('delete' ~ exercice.idExercice) }}';
                                                            form.appendChild(token);
                                                            document.body.appendChild(form);
                                                            form.submit();
                                                        }">
                                                    <i class="fas fa-trash me-1"></i>Supprimer
                                                </button>
                                            {% else %}
                                                <span class="btn btn-outline-secondary btn-sm disabled" title="Suppression interdite">
                                                    <i class="fas fa-trash me-1"></i>Supprimer
                                                </span>
                                            {% endif %}
                                            
                                            <button type="button" 
                                                    class="btn btn-outline-primary btn-sm ms-1" 
                                                    title="Voir les transactions de cet exercice"
                                                    onclick="window.location.href='{{ path('app_transaction_index') }}?exercice_id={{ exercice.idExercice }}'">
                                                <i class="fas fa-list me-1"></i>Transactions
                                            </button>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">
                                            <i class="fas fa-inbox fa-3x mb-3"></i>
                                            <br>Aucun exercice trouvé
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Section Historique des clôtures récentes -->
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-history me-2"></i>Historique récent des clôtures
                    </h5>
                </div>
                <div class="card-body">
                    <div id="historiqueRecent">
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Chargement...</span>
                            </div>
                            <p class="mt-2 text-muted">Chargement de l'historique...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Fonctions pour clôturer et déclôturer directement
function cloturerExercice(exerciceId, exerciceNom) {
    if (!confirm(`Voulez-vous vraiment clôturer l'exercice "${exerciceNom}" ?`)) {
        return;
    }

    fetch('/historique-cloture/cloturer/' + exerciceId, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            commentaire: ''
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Erreur : ' + (data.message || 'Impossible de clôturer l\'exercice'));
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Erreur de communication avec le serveur');
    });
}

function decloturerExercice(exerciceId, exerciceNom) {
    if (!confirm(`Voulez-vous vraiment déclôturer l'exercice "${exerciceNom}" ?`)) {
        return;
    }

    fetch('/historique-cloture/decloturer/' + exerciceId, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            commentaire: ''
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Erreur : ' + (data.message || 'Impossible de déclôturer l\'exercice'));
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Erreur de communication avec le serveur');
    });
}

// Gestion de l'édition inline
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.editable-field').forEach(function(element) {
        element.addEventListener('click', function() {
            if (this.querySelector('input') || this.querySelector('select')) {
                return;
            }
            
            const field = this.dataset.field;
            const currentValue = this.textContent.trim();
            const url = this.dataset.url;
            const exerciceId = this.dataset.id;
            
            if (field === 'dateDebut' || field === 'dateFin') {
                let isoValue = '';
                if (currentValue && currentValue !== '') {
                    const parts = currentValue.split('/');
                    if (parts.length === 3) {
                        isoValue = parts[2] + '-' + parts[1].padStart(2, '0') + '-' + parts[0].padStart(2, '0');
                    }
                }
                
                this.innerHTML = '<input type="date" class="form-control form-control-sm" value="' + isoValue + '" style="min-width: 150px;">';
            } else {
                this.innerHTML = '<input type="text" class="form-control form-control-sm" value="' + currentValue + '" style="min-width: 150px;">';
            }
            
            const input = this.querySelector('input');
            input.focus();
            
            const saveValue = () => {
                const newValue = input.value;
                
                fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: 'field=' + field + '&value=' + encodeURIComponent(newValue)
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (field === 'dateDebut' || field === 'dateFin') {
                            if (newValue) {
                                const date = new Date(newValue);
                                const formattedDate = date.toLocaleDateString('fr-FR');
                                element.textContent = formattedDate;
                            } else {
                                element.textContent = '';
                            }
                        } else {
                            element.textContent = newValue;
                        }
                    } else {
                        alert('Erreur lors de la sauvegarde : ' + data.message);
                        element.textContent = currentValue;
                    }
                })
                .catch(error => {
                    alert('Erreur de connexion');
                    element.textContent = currentValue;
                });
            };
            
            input.addEventListener('blur', saveValue);
            input.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    saveValue();
                }
                if (e.key === 'Escape') {
                    element.textContent = currentValue;
                }
            });
        });
    });
});

// Charger l'historique récent au chargement de la page
function chargerHistoriqueRecent() {
    fetch('/historique-cloture/historique-recent')
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                afficherHistoriqueRecent(data.historiques);
            } else {
                document.getElementById('historiqueRecent').innerHTML = 
                    '<div class="alert alert-warning">' +
                    '<i class="fas fa-exclamation-triangle me-2"></i>Aucun historique récent disponible' +
                    '</div>';
            }
        })
        .catch(error => {
            document.getElementById('historiqueRecent').innerHTML = 
                '<div class="alert alert-danger">' +
                '<i class="fas fa-exclamation-triangle me-2"></i>Erreur lors du chargement de l\'historique' +
                '</div>';
        });
}

function afficherHistoriqueRecent(historiques) {
    if (historiques.length === 0) {
        document.getElementById('historiqueRecent').innerHTML = 
            '<div class="text-center text-muted py-3">' +
            '<i class="fas fa-inbox fa-2x mb-2"></i><br>' +
            'Aucune clôture récente' +
            '</div>';
        return;
    }

    let html = '<div class="row">';
    
    historiques.slice(0, 10).forEach((item, index) => {
        const isClotured = item.type_action === 'CLOTURE';
        const iconClass = isClotured ? 'fas fa-lock' : 'fas fa-unlock';
        const badgeClass = isClotured ? 'bg-danger' : 'bg-success';
        const date = new Date(item.date_action);
        
        html += '<div class="col-md-6 col-lg-4 mb-3">';
        html += '<div class="card border-start border-4 ' + (isClotured ? 'border-danger' : 'border-success') + '">';
        html += '<div class="card-body p-3">';
        html += '<div class="d-flex align-items-center mb-2">';
        html += '<span class="badge ' + badgeClass + ' me-2"><i class="' + iconClass + '"></i></span>';
        html += '<h6 class="mb-0">' + (isClotured ? 'Clôture' : 'Déclôture') + '</h6>';
        html += '</div>';
        html += '<p class="mb-1 fw-bold">' + item.exercice_libelle + '</p>';
        html += '<p class="mb-1 text-muted small">';
        html += '<i class="fas fa-calendar me-1"></i>' + date.toLocaleDateString('fr-FR');
        html += ' <i class="fas fa-clock ms-2 me-1"></i>' + date.toLocaleTimeString('fr-FR', {hour: '2-digit', minute: '2-digit'});
        html += '</p>';
        if (item.user) {
            html += '<p class="mb-0 text-muted small">';
            html += '<i class="fas fa-user me-1"></i>' + item.user;
            html += '</p>';
        }
        if (item.commentaire) {
            html += '<p class="mb-0 mt-2 small">' + item.commentaire + '</p>';
        }
        html += '</div></div></div>';
    });
    
    html += '</div>';
    document.getElementById('historiqueRecent').innerHTML = html;
}

// Charger l'historique au chargement de la page
window.addEventListener('load', chargerHistoriqueRecent);
</script>

<style>
.timeline {
    position: relative;
    padding-left: 30px;
}

.timeline-item {
    position: relative;
    margin-bottom: 20px;
}

.timeline-item:not(:last-child)::before {
    content: '';
    position: absolute;
    left: -19px;
    top: 30px;
    height: calc(100% + 10px);
    width: 2px;
    background-color: #dee2e6;
}

.timeline-marker {
    position: absolute;
    left: -30px;
    top: 5px;
}

.timeline-content {
    background-color: #f8f9fa;
    border-radius: 8px;
    padding: 15px;
    border-left: 4px solid #dee2e6;
}

.editable-field:hover {
    background-color: #f8f9fa;
    cursor: pointer;
    border-radius: 3px;
    padding: 2px 4px;
}

.table-secondary {
    --bs-table-bg: #f8f9fa;
}
</style>
{% endblock %}
