{% extends 'base.html.twig' %}

{% block title %}Exercice{% endblock %}

{% block body %}
    <h1>Exercice</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id_exercice</th>
                <td>{{ exercice.idExercice }}</td>
            </tr>
            <tr>
                <th>Libelle</th>
                <td>{{ exercice.libelle }}</td>
            </tr>
            <tr>
                <th>Date_debut</th>
                <td>{{ exercice.dateDebut ? exercice.dateDebut|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Date_fin</th>
                <td>{{ exercice.dateFin ? exercice.dateFin|date('Y-m-d') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_exercice_index') }}">back to list</a>

    <a href="{{ path('app_exercice_edit', {'id_exercice': exercice.idExercice}) }}">edit</a>

    {{ include('exercice/_delete_form.html.twig') }}
{% endblock %}
