{% extends 'base.html.twig' %}

{% block title %}Transactions de l'exercice "{{ exercice.libelle }}"{% endblock %}

{% block body %}
    <h1>Transactions de l'exercice "{{ exercice.libelle }}"</h1>

    <div class="mb-3">
        <a href="{{ path('app_exercice_index') }}" class="btn btn-secondary">← Retour aux exercices</a>
        <a href="{{ path('app_exercice_all_transactions') }}" class="btn btn-info">Voir toutes les transactions</a>
        <a href="{{ path('app_transaction_new') }}" class="btn btn-primary">Créer nouvelle transaction</a>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            <h5>Informations sur l'exercice</h5>
        </div>
        <div class="card-body">
            <p><strong>Libellé :</strong> {{ exercice.libelle }}</p>
            <p><strong>Date début :</strong> {{ exercice.dateDebut ? exercice.dateDebut|date('d/m/Y') : 'Non définie' }}</p>
            <p><strong>Date fin :</strong> {{ exercice.dateFin ? exercice.dateFin|date('d/m/Y') : 'Non définie' }}</p>
            <p><strong>Nombre de transactions :</strong> {{ transactions|length }}</p>
        </div>
    </div>

    {% if transactions|length > 0 %}
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Libellé</th>
                    <th>N° Ordre</th>
                    <th>Date</th>
                    <th>Montant</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for transaction in transactions %}
                <tr>
                    <td>{{ transaction.idTransaction }}</td>
                    <td>{{ transaction.libelle }}</td>
                    <td>{{ transaction.numeroOrdre }}</td>
                    <td>{{ transaction.dateTransaction ? transaction.dateTransaction|date('d/m/Y') : '' }}</td>
                    <td class="text-end">
                        <span class="{% if transaction.montant >= 0 %}text-success{% else %}text-danger{% endif %}">
                            {{ transaction.montant|number_format(2, ',', ' ') }} €
                        </span>
                    </td>
                    <td>
                        <a href="{{ path('app_transaction_show', {'id_transaction': transaction.idTransaction}) }}" class="btn btn-sm btn-info">Voir</a>
                        <a href="{{ path('app_transaction_edit', {'id_transaction': transaction.idTransaction}) }}" class="btn btn-sm btn-warning">Modifier</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
            <tfoot>
                <tr class="table-info">
                    <td colspan="4"><strong>Total</strong></td>
                    <td class="text-end">
                        {% set total = 0 %}
                        {% for transaction in transactions %}
                            {% set total = total + transaction.montant %}
                        {% endfor %}
                        <strong>
                            <span class="{% if total >= 0 %}text-success{% else %}text-danger{% endif %}">
                                {{ total|number_format(2, ',', ' ') }} €
                            </span>
                        </strong>
                    </td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    {% else %}
        <div class="alert alert-info">
            <h5>Aucune transaction</h5>
            <p>Cet exercice ne contient encore aucune transaction.</p>
            <a href="{{ path('app_transaction_new') }}" class="btn btn-primary">Créer la première transaction</a>
        </div>
    {% endif %}
{% endblock %}