{% extends 'base.html.twig' %}

{% block title %}Nouvelle Personne{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-user-plus me-2"></i>Nouvelle Personne</h1>
                <a href="{{ path('app_personne_index') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                </a>
            </div>

            {% if form.vars.errors|length > 0 %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i><strong>Erreurs de validation :</strong>
                    <ul class="mb-0 mt-2">
                        {% for error in form.vars.errors %}
                            <li>{{ error.message }}</li>
                        {% endfor %}
                    </ul>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endif %}

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-6">
                            {{ form_start(form, {'attr': {'novalidate': false, 'id': 'personne_new_form'}}) }}
                            
                            <div class="mb-3">
                                {{ form_label(form.civilite, 'Civilité', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.civilite, {'attr': {'class': 'form-select' ~ (form.civilite.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.civilite.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.civilite.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.civilite) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.prenom, 'Prénom', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.prenom, {'attr': {'class': 'form-control' ~ (form.prenom.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.prenom.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.prenom.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.prenom) }}
                            </div>

                            <div class="mb-3">
                                {{ form_label(form.nom, 'Nom', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.nom, {'attr': {'class': 'form-control' ~ (form.nom.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.nom.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.nom.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.nom) }}
                            </div>

                            <h6 class="text-muted border-bottom pb-2 mb-3">Adresse</h6>
                            
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="mb-3">
                                        {{ form_label(form.numero_voie, 'N°', {'label_attr': {'class': 'form-label'}}) }}
                                        {{ form_widget(form.numero_voie, {'attr': {'class': 'form-control' ~ (form.numero_voie.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {{ form_errors(form.numero_voie) }}
                                    </div>
                                </div>
                                <div class="col-md-9">
                                    <div class="mb-3">
                                        {{ form_label(form.rue, 'Rue', {'label_attr': {'class': 'form-label'}}) }}
                                        {{ form_widget(form.rue, {'attr': {'class': 'form-control' ~ (form.rue.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {{ form_errors(form.rue) }}
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.complement_adresse, 'Complément d\'adresse', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.complement_adresse, {'attr': {'class': 'form-control' ~ (form.complement_adresse.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {{ form_errors(form.complement_adresse) }}
                            </div>
                            
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="mb-3">
                                        {{ form_label(form.code_postal, 'Code postal', {'label_attr': {'class': 'form-label'}}) }}
                                        {{ form_widget(form.code_postal, {'attr': {'class': 'form-control' ~ (form.code_postal.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {{ form_errors(form.code_postal) }}
                                    </div>
                                </div>
                                <div class="col-md-9">
                                    <div class="mb-3">
                                        {{ form_label(form.ville, 'Ville', {'label_attr': {'class': 'form-label'}}) }}
                                        {{ form_widget(form.ville, {'attr': {'class': 'form-control' ~ (form.ville.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {{ form_errors(form.ville) }}
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.pays, 'Pays', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.pays, {'attr': {'class': 'form-control' ~ (form.pays.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {{ form_errors(form.pays) }}
                            </div>

                            <h6 class="text-muted border-bottom pb-2 mb-3">Contact</h6>
                            
                            <div class="mb-3">
                                {{ form_label(form.telephone, 'Téléphone', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.telephone, {'attr': {'class': 'form-control' ~ (form.telephone.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {{ form_errors(form.telephone) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.email, 'Email', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.email, {'attr': {'class': 'form-control' ~ (form.email.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {{ form_errors(form.email) }}
                            </div>
                            
                            <h6 class="text-muted border-bottom pb-2 mb-3">
                                <i class="fas fa-building me-1"></i>Entreprises liées
                            </h6>
                            
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    {{ form_label(form.entreprise, 'Entreprises associées', {'label_attr': {'class': 'form-label mb-0'}}) }}
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="toggleAllCheckboxes('entreprise', true)">
                                            <i class="fas fa-check-square me-1"></i>Tout sélectionner
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleAllCheckboxes('entreprise', false)">
                                            <i class="fas fa-square me-1"></i>Tout déselectionner
                                        </button>
                                    </div>
                                </div>
                                <div class="checkbox-container p-3 border rounded bg-light" style="max-height: 200px; overflow-y: auto;" data-checkbox-group="entreprise">
                                    {% for choice in form.entreprise %}
                                        <div class="form-check mb-2">
                                            {{ form_widget(choice, {'attr': {'class': 'form-check-input'}}) }}
                                            {{ form_label(choice, null, {'label_attr': {'class': 'form-check-label ms-2'}}) }}
                                        </div>
                                    {% endfor %}
                                </div>
                                {% if form.entreprise.vars.help %}
                                    <div class="form-text">
                                        <i class="fas fa-info-circle me-1"></i>{{ form.entreprise.vars.help }}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.entreprise) }}
                            </div>
                            
                            {{ form_end(form) }}
                        </div>
                        
                        <div class="col-lg-6">
                            <div class="d-flex flex-column gap-3 sticky-top px-5" style="top: 20px;">
                                <h6 class="text-muted mb-0">Actions</h6>
                                <a href="{{ path('app_personne_index') }}" class="btn btn-secondary btn-lg py-3" style="margin: 0 3rem;">
                                    <i class="fas fa-times me-2"></i>Annuler
                                </a>
                                <button type="submit" class="btn btn-success btn-lg py-3" style="margin: 0 3rem;" form="personne_new_form">
                                    <i class="fas fa-save me-2"></i>Créer la personne
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function toggleAllCheckboxes(groupName, selectAll) {
    const container = document.querySelector(`[data-checkbox-group="${groupName}"]`);
    if (!container) return;
    
    const checkboxes = container.querySelectorAll('input[type="checkbox"]');
    checkboxes.forEach(checkbox => {
        checkbox.checked = selectAll;
    });
}
</script>
{% endblock %}