{% extends 'base.html.twig' %}

{% block title %}Modifier {{ personne.prenom }} {{ personne.nom }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-edit me-2"></i>Modifier {{ personne.prenom }} {{ personne.nom }}
                        </h5>
                        <div class="btn-group">
                            <a href="{{ path('app_personne_show', {'id_personne': personne.idPersonne}) }}" class="btn btn-info btn-sm">
                                <i class="fas fa-eye me-1"></i>Voir
                            </a>
                            <a href="{{ path('app_personne_index') }}" class="btn btn-light btn-sm">
                                <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}
                    {{ form_rest(form) }}
                    
                    <div class="col-12">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save me-1"></i>Mettre à jour
                            </button>
                            <a href="{{ path('app_personne_show', {'id_personne': personne.idPersonne}) }}" class="btn btn-info">
                                <i class="fas fa-eye me-1"></i>Voir
                            </a>
                            <a href="{{ path('app_personne_index') }}" class="btn btn-secondary">
                                <i class="fas fa-times me-1"></i>Annuler
                            </a>
                        </div>
                    </div>
                    
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}