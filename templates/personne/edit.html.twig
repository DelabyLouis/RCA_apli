{% extends 'base.html.twig' %}

{% block title %}Modifier {{ personne.prenom }} {{ personne.nom }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <h1 class="mb-4">
        <i class="fas fa-edit me-2 text-warning"></i>Modifier {{ personne.prenom }} {{ personne.nom }}
    </h1>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Modifier les informations de la personne</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.civilite, 'Civilité') }}
                                {{ form_widget(form.civilite, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.civilite) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.prenom, 'Prénom') }}
                                {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.prenom) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.nom, 'Nom') }}
                                {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.nom) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.telephone, 'Téléphone') }}
                                {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.telephone) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.email, 'Email') }}
                                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.email) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.numero_voie, 'N° de voie') }}
                                {{ form_widget(form.numero_voie, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.numero_voie) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.rue, 'Rue') }}
                                {{ form_widget(form.rue, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.rue) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.complement_adresse, 'Complément d\'adresse') }}
                                {{ form_widget(form.complement_adresse, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.complement_adresse) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.ville, 'Ville') }}
                                {{ form_widget(form.ville, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.ville) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.code_postal, 'Code postal') }}
                                {{ form_widget(form.code_postal, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.code_postal) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.pays, 'Pays') }}
                                {{ form_widget(form.pays, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.pays) }}
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            {{ form_label(form.entreprise, 'Entreprises associées', {'label_attr': {'class': 'form-label mb-0'}}) }}
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="toggleAllCheckboxes('entreprise', true)">
                                    <i class="fas fa-check-square me-1"></i>Tout sélectionner
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleAllCheckboxes('entreprise', false)">
                                    <i class="fas fa-square me-1"></i>Tout déselectionner
                                </button>
                            </div>
                        </div>
                        <div class="checkbox-container p-3 border rounded bg-light" style="max-height: 200px; overflow-y: auto;" data-checkbox-group="entreprise">
                            {% for choice in form.entreprise %}
                                <div class="form-check mb-2">
                                    {{ form_widget(choice, {'attr': {'class': 'form-check-input'}}) }}
                                    {{ form_label(choice, null, {'label_attr': {'class': 'form-check-label ms-2'}}) }}
                                </div>
                            {% endfor %}
                        </div>
                        {% if form.entreprise.vars.help %}
                            <div class="form-text">
                                <i class="fas fa-info-circle me-1"></i>{{ form.entreprise.vars.help }}
                            </div>
                        {% endif %}
                        {{ form_errors(form.entreprise) }}
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <div>
                            <a href="{{ path('app_personne_show', {'id_personne': personne.idPersonne}) }}" class="btn btn-secondary btn-lg me-2">
                                <i class="fas fa-eye me-2"></i>Voir
                            </a>
                            <a href="{{ path('app_personne_index') }}" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-list me-2"></i>Liste
                            </a>
                        </div>
                        <div>
                            <button type="submit" class="btn btn-warning btn-lg">
                                <i class="fas fa-save me-2"></i>Modifier la personne
                            </button>
                        </div>
                    </div>

                    {{ form_rest(form) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function toggleAllCheckboxes(groupName, selectAll) {
    const container = document.querySelector(`[data-checkbox-group="${groupName}"]`);
    if (!container) return;
    
    const checkboxes = container.querySelectorAll('input[type="checkbox"]');
    checkboxes.forEach(checkbox => {
        checkbox.checked = selectAll;
    });
}
</script>
{% endblock %}