{% extends 'base.html.twig' %}

{% block title %}{{ personne.prenom }} {{ personne.nom }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-user me-2"></i>{{ personne.prenom }} {{ personne.nom }}
                        </h5>
                        <div class="btn-group">
                            <a href="{{ path('app_personne_edit', {'id_personne': personne.idPersonne}) }}" class="btn btn-warning btn-sm">
                                <i class="fas fa-edit me-1"></i>Modifier
                            </a>
                            <a href="{{ path('app_personne_index') }}" class="btn btn-light btn-sm">
                                <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <tr>
                                        <th class="text-muted" style="width: 40%;">Nom :</th>
                                        <td><strong>{{ personne.nom }}</strong></td>
                                    </tr>
                                    <tr>
                                        <th class="text-muted">Prénom :</th>
                                        <td><strong>{{ personne.prenom }}</strong></td>
                                    </tr>
                                    {% if personne.civilite %}
                                    <tr>
                                        <th class="text-muted">Civilité :</th>
                                        <td>{{ personne.civilite }}</td>
                                    </tr>
                                    {% endif %}
                                </table>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            {% if personne.numeroVoie or personne.rue or personne.ville %}
                            <h6 class="text-muted border-bottom pb-2 mb-3">
                                <i class="fas fa-map-marker-alt me-2"></i>Adresse
                            </h6>
                            <address class="mb-0">
                                {% if personne.numeroVoie %}{{ personne.numeroVoie }} {% endif %}{{ personne.rue }}<br>
                                {% if personne.complementAdresse %}{{ personne.complementAdresse }}<br>{% endif %}
                                {% if personne.codePostal %}{{ personne.codePostal }} {% endif %}{{ personne.ville }}<br>
                                {% if personne.pays %}{{ personne.pays }}{% endif %}
                            </address>
                            {% endif %}
                            
                            {% if personne.telephone or personne.email %}
                            <h6 class="text-muted border-bottom pb-2 mb-3 mt-4">
                                <i class="fas fa-address-book me-2"></i>Contact
                            </h6>
                            {% if personne.telephone %}
                                <p class="mb-1">
                                    <i class="fas fa-phone me-2 text-muted"></i>{{ personne.telephone }}
                                </p>
                            {% endif %}
                            {% if personne.email %}
                                <p class="mb-1">
                                    <i class="fas fa-envelope me-2 text-muted"></i>
                                    <a href="mailto:{{ personne.email }}">{{ personne.email }}</a>
                                </p>
                            {% endif %}
                            {% endif %}
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light">
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_personne_edit', {'id_personne': personne.idPersonne}) }}" class="btn btn-warning">
                            <i class="fas fa-edit me-1"></i>Modifier
                        </a>
                        <a href="{{ path('app_personne_index') }}" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}