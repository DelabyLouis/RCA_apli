{% extends 'base.html.twig' %}

{% block title %}Personne index{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .editable-field {
            cursor: pointer;
            padding: 5px;
            border: 1px solid transparent;
            border-radius: 3px;
            transition: all 0.2s;
        }
        
        .editable-field:hover {
            background-color: #f8f9fa;
            border-color: #dee2e6;
        }
        
        .editable-field.editing {
            background-color: #fff;
            border-color: #007bff;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
        }
        
        .editable-input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            font-size: inherit;
            font-family: inherit;
            padding: 0;
            margin: 0;
        }
        
        /* Masquer les rectangles blancs indésirables */
        .editable-field input,
        .editable-field textarea,
        .editable-field select {
            border: none !important;
            outline: none !important;
            box-shadow: none !important;
            background: transparent !important;
        }
        
        .saving {
            opacity: 0.6;
            pointer-events: none;
        }
        
        .alert {
            margin: 10px 0;
            padding: 10px;
            border-radius: 4px;
        }
        
        .alert-success {
            background-color: #d4edda;
            border-color: #c3e6cb;
            color: #155724;
        }
        
        .alert-danger {
            background-color: #f8d7da;
            border-color: #f5c6cb;
            color: #721c24;
        }
    </style>
{% endblock %}

{% block body %}
    <h1>Personne index</h1>
    
    <div id="message-container"></div>

    <table class="table" data-turbo="false">
        <thead>
                        <tr>
                <th>Id</th>
                <th>Civilite</th>
                <th>Nom</th>
                <th>Prenom</th>
                <th>Adresse</th>
                <th>Contact</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for personne in personnes %}
            <tr data-id="{{ personne.idPersonne }}">
                <td>{{ personne.idPersonne }}</td>
                <td class="editable-field" data-field="nom">{{ personne.nom }}</td>
                <td class="editable-field" data-field="prenom">{{ personne.prenom }}</td>
                <td class="editable-field" data-field="civilite">{{ personne.civilite }}</td>
                <td class="editable-field" data-field="numero_voie">{{ personne.numeroVoie }}</td>
                <td class="editable-field" data-field="rue">{{ personne.rue }}</td>
                <td class="editable-field" data-field="complement_adresse">{{ personne.complementAdresse }}</td>
                <td class="editable-field" data-field="ville">{{ personne.ville }}</td>
                <td class="editable-field" data-field="code_postal">{{ personne.codePostal }}</td>
                <td class="editable-field" data-field="pays">{{ personne.pays }}</td>
                <td class="editable-field" data-field="telephone">{{ personne.telephone }}</td>
                <td class="editable-field" data-field="email">{{ personne.email }}</td>
                <td>
                    {% if personne.entreprise|length > 0 %}
                        {% for entreprise in personne.entreprise %}
                            <span class="badge bg-primary me-1">{{ entreprise.nomEntreprise }}</span>
                        {% endfor %}
                    {% else %}
                        <span class="text-muted">Aucune</span>
                    {% endif %}
                </td>
                <td>
                    {% if personne.users|length > 0 %}
                        <span class="badge bg-success">Oui</span>
                    {% else %}
                        <span class="badge bg-secondary">Non</span>
                    {% endif %}
                </td>
                <td>
                    <span class="badge bg-info">{{ personne.transactions|length }}</span>
                </td>
                <td>
                    <button class="btn btn-danger btn-sm delete-btn" data-id="{{ personne.idPersonne }}" title="Supprimer">
                        <i class="fas fa-trash me-1"></i> Supprimer
                    </button>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="13">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_personne_new') }}">Create new</a>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Attendre que tout soit complètement chargé
        window.addEventListener('load', function() {
            console.log('Window load - JavaScript chargé');
            
            let currentEditingCell = null;
            let originalValue = '';
            
            // Petit délai pour s'assurer que Turbo a fini
            setTimeout(function() {
                const editableFields = document.querySelectorAll('.editable-field');
                console.log('Nombre de champs éditables trouvés:', editableFields.length);
                
                function showMessage(message, type) {
                const container = document.getElementById('message-container');
                const alert = document.createElement('div');
                alert.className = `alert alert-${type}`;
                alert.textContent = message;
                container.appendChild(alert);
                
                setTimeout(() => {
                    alert.remove();
                }, 3000);
            }
            
            function saveField(cell, field, value, personneId) {
                const row = cell.closest('tr');
                row.classList.add('saving');
                
                fetch(`/personne/${personneId}/update-field`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `field=${encodeURIComponent(field)}&value=${encodeURIComponent(value)}`
                })
                .then(response => response.json())
                .then(data => {
                    row.classList.remove('saving');
                    
                    if (data.success) {
                        cell.textContent = value || '';
                    } else {
                        cell.textContent = originalValue;
                        showMessage(data.message, 'danger');
                    }
                })
                .catch(error => {
                    row.classList.remove('saving');
                    cell.textContent = originalValue;
                    showMessage('Erreur de communication avec le serveur', 'danger');
                    console.error('Error:', error);
                });
            }
            
            function startEditing(cell) {
                console.log('startEditing appelé pour:', cell);
                if (currentEditingCell && currentEditingCell !== cell) {
                    stopEditing(currentEditingCell, false);
                }
                
                currentEditingCell = cell;
                originalValue = cell.textContent;
                
                cell.classList.add('editing');
                
                const input = document.createElement('input');
                input.className = 'editable-input';
                input.type = 'text';
                input.value = originalValue;
                
                cell.textContent = '';
                cell.appendChild(input);
                
                input.focus();
                input.select();
                
                input.addEventListener('blur', function() {
                    stopEditing(cell, true);
                });
                
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        stopEditing(cell, true);
                    } else if (e.key === 'Escape') {
                        e.preventDefault();
                        stopEditing(cell, false);
                    }
                });
                
                // Empêcher la propagation du clic sur l'input pour éviter de relancer l'édition
                input.addEventListener('click', function(e) {
                    e.stopPropagation();
                });
            }
            
            function stopEditing(cell, save) {
                if (!cell || !cell.classList.contains('editing')) return;
                
                const input = cell.querySelector('input');
                const newValue = input ? input.value.trim() : '';
                
                cell.classList.remove('editing');
                
                if (save && newValue !== originalValue) {
                    const field = cell.dataset.field;
                    const personneId = cell.closest('tr').dataset.id;
                    
                    if ((field === 'nom' || field === 'prenom') && !newValue) {
                        showMessage('Le nom et le prénom ne peuvent pas être vides', 'danger');
                        cell.textContent = originalValue;
                    } else {
                        saveField(cell, field, newValue, personneId);
                    }
                } else {
                    cell.textContent = originalValue;
                }
                
                currentEditingCell = null;
            }
            
            // Délégation d'événements pour les cellules éditables - plus robuste
            document.addEventListener('click', function(e) {
                const cell = e.target.closest('.editable-field');
                if (!cell) return;
                
                // Si on clique sur un input/textarea à l'intérieur, ne pas traiter le clic de la cellule
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') {
                    return;
                }
                
                // Si la cellule est déjà en cours d'édition, ne pas relancer l'édition
                if (cell.classList.contains('editing')) {
                    return;
                }
                
                startEditing(cell);
            });
            
            document.addEventListener('click', function(e) {
                if (currentEditingCell && !currentEditingCell.contains(e.target)) {
                    stopEditing(currentEditingCell, false);
                }
            });

            // Délégation d'événements pour les boutons de suppression
            document.addEventListener('click', function(e) {
                if (!e.target.closest('.delete-btn')) return;
                
                const button = e.target.closest('.delete-btn');
                e.stopPropagation();
                
                const id = button.getAttribute('data-id');
                const row = button.closest('tr');
                
                if (confirm('Êtes-vous sûr de vouloir supprimer cette personne ?')) {
                    // Désactiver le bouton pendant la suppression
                    button.disabled = true;
                    button.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Suppression...';
                        
                        fetch(`/personne/${id}/delete-ajax`, {
                            method: 'DELETE',
                            headers: {
                                'Content-Type': 'application/json',
                            }
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                // Supprimer la ligne du tableau avec animation
                                row.style.transition = 'opacity 0.3s';
                                row.style.opacity = '0';
                                setTimeout(() => {
                                    row.remove();
                                }, 300);
                            } else {
                                alert('Erreur lors de la suppression : ' + data.message);
                                // Restaurer le bouton
                                this.disabled = false;
                                this.innerHTML = '<i class="fas fa-trash me-1"></i> Supprimer';
                            }
                        })
                        .catch(error => {
                            console.error('Erreur:', error);
                            alert('Erreur lors de la suppression');
                            // Restaurer le bouton
                            button.disabled = false;
                            button.innerHTML = '<i class="fas fa-trash me-1"></i> Supprimer';
                        });
                    }
                });
            }, 100); // Délai pour s'assurer que les boutons sont prêts
        });
    </script>
{% endblock %}
