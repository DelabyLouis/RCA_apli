{% extends 'base.html.twig' %}

{% block title %}Personne index{% endblock %}

{% block body %}
    <h1>Personne index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id_personne</th>
                <th>Nom</th>
                <th>Prenom</th>
                <th>Civilite</th>
                <th>Numero_voie</th>
                <th>Rue</th>
                <th>Complement_adresse</th>
                <th>Ville</th>
                <th>Code_postal</th>
                <th>Pays</th>
                <th>Telephone</th>
                <th>Email</th>
                <th>Entreprise(s)</th>
                <th>Est utilisateur</th>
                <th>Nb transactions</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for personne in personnes %}
            <tr>
                <td>{{ personne.idPersonne }}</td>
                <td>{{ personne.nom }}</td>
                <td>{{ personne.prenom }}</td>
                <td>{{ personne.civilite }}</td>
                <td>{{ personne.numeroVoie }}</td>
                <td>{{ personne.rue }}</td>
                <td>{{ personne.complementAdresse }}</td>
                <td>{{ personne.ville }}</td>
                <td>{{ personne.codePostal }}</td>
                <td>{{ personne.pays }}</td>
                <td>{{ personne.telephone }}</td>
                <td>{{ personne.email }}</td>
                <td>
                    {% if personne.entreprise|length > 0 %}
                        {% for entreprise in personne.entreprise %}
                            <span class="badge bg-primary me-1">{{ entreprise.nomEntreprise }}</span>
                        {% endfor %}
                    {% else %}
                        <span class="text-muted">Aucune</span>
                    {% endif %}
                </td>
                <td>
                    {% if personne.users|length > 0 %}
                        <span class="badge bg-success">Oui</span>
                    {% else %}
                        <span class="badge bg-secondary">Non</span>
                    {% endif %}
                </td>
                <td>
                    <span class="badge bg-info">{{ personne.transactions|length }}</span>
                </td>
                <td>
                    <a href="{{ path('app_personne_show', {'id_personne': personne.idPersonne}) }}">show</a>
                    <a href="{{ path('app_personne_edit', {'id_personne': personne.idPersonne}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="13">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_personne_new') }}">Create new</a>
{% endblock %}
