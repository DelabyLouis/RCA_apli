{% extends 'base.html.twig' %}

{% block title %}Gestion des Personnes - RCA Application{% endblock %}

{% block body %}
    {{ include('components/inline_edit_styles.html.twig') }}
    
    <style>
        #personnes-table th:nth-child(1), #personnes-table td:nth-child(1) { width: 80px !important; max-width: 80px !important; }
        #personnes-table th:nth-child(2), #personnes-table td:nth-child(2) { width: 150px !important; max-width: 150px !important; }
        #personnes-table th:nth-child(3), #personnes-table td:nth-child(3) { width: 150px !important; max-width: 150px !important; }
        #personnes-table th:nth-child(4), #personnes-table td:nth-child(4) { width: 200px !important; max-width: 200px !important; }
        #personnes-table th:nth-child(5), #personnes-table td:nth-child(5) { width: 180px !important; max-width: 180px !important; }
        #personnes-table th:nth-child(6), #personnes-table td:nth-child(6) { width: 120px !important; max-width: 120px !important; }
        #personnes-table th:nth-child(7), #personnes-table td:nth-child(7) { width: 120px !important; max-width: 120px !important; }
        
        #personnes-table th:nth-child(1), #personnes-table td:nth-child(1),
        #personnes-table th:nth-child(2), #personnes-table td:nth-child(2),
        #personnes-table th:nth-child(3), #personnes-table td:nth-child(3),
        #personnes-table th:nth-child(5), #personnes-table td:nth-child(5),
        #personnes-table th:nth-child(6), #personnes-table td:nth-child(6),
        #personnes-table th:nth-child(7), #personnes-table td:nth-child(7) {
            overflow: hidden !important;
            text-overflow: ellipsis !important;
            white-space: nowrap !important;
        }
        
        /* Marges pour le tableau */
        .container-fluid.mt-4 {
            padding-left: 3rem !important;
            padding-right: 3rem !important;
        }
    </style>
    
    <div class="container-fluid mt-4">
        <h1 class="mb-4">Gestion des Personnes</h1>
        
        <!-- Zone de notifications pour les suppressions -->
        <div id="notifications" style="position: fixed; top: 20px; right: 20px; z-index: 9999; min-width: 300px;"></div>
        
        <div class="row mb-3">
            <div class="col">
                <a href="{{ path('app_personne_new') }}" class="btn btn-success">
                    <i class="fas fa-plus me-2"></i>Nouvelle Personne
                </a>
            </div>
        </div>
        
        <!-- Filtres personnalisés -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filtres</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Filtre Nom/Prénom -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-nom" class="form-label">Nom/Prénom</label>
                        <input type="text" class="form-control" id="filter-nom" placeholder="Rechercher par nom ou prénom...">
                    </div>
                    
                    <!-- Filtre Civilité -->
                    <div class="col-md-2 mb-3">
                        <label for="filter-civilite" class="form-label">Civilité</label>
                        <select class="form-select" id="filter-civilite">
                            <option value="">Toutes</option>
                            <option value="M.">M.</option>
                            <option value="Mme">Mme</option>
                            <option value="Mlle">Mlle</option>
                        </select>
                    </div>
                    
                    <!-- Filtre Email -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-email" class="form-label">Email</label>
                        <input type="text" class="form-control" id="filter-email" placeholder="Rechercher par email...">
                    </div>
                    
                    <!-- Filtre Ville -->
                    <div class="col-md-2 mb-3">
                        <label for="filter-ville" class="form-label">Ville</label>
                        <input type="text" class="form-control" id="filter-ville" placeholder="Ville...">
                    </div>
                    
                    <!-- Actions filtres -->
                    <div class="col-md-2 mb-3 d-flex align-items-end">
                        <button type="button" class="btn btn-secondary me-2" onclick="clearAllFilters()">
                            <i class="fas fa-eraser me-1"></i>Effacer
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tableau des personnes -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-users me-2"></i>Liste des Personnes
                    <span id="total-count" class="badge bg-primary ms-2">{{ personnes|length }}</span>
                </h5>
                <small class="text-muted">
                    <span id="filtered-count">{{ personnes|length }}</span> personnes affichées
                </small>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="personnes-table" class="table table-striped table-hover mb-0 fs-5">
                        <thead class="table-dark">
                            <tr>
                                <th class="fs-5" style="width: 80px;">Civilité</th>
                                <th class="fs-5" style="width: 150px;">Nom</th>
                                <th class="fs-5" style="width: 150px;">Prénom</th>
                                <th class="fs-5">Email</th>
                                <th class="fs-5" style="width: 180px;">Téléphone</th>
                                <th class="fs-5" style="width: 120px;">Ville</th>
                                <th class="text-center fs-5" style="width: 120px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="personnes-table-body">
                            {% for personne in personnes %}
                            <tr class="personne-row" 
                                data-nom="{{ personne.nom|lower }}" 
                                data-prenom="{{ personne.prenom|lower }}" 
                                data-email="{{ personne.email|lower }}" 
                                data-civilite="{{ personne.civilite }}"
                                data-ville="{{ personne.ville|lower }}">
                                <td>{{ personne.civilite }}</td>
                                <td class="fw-semibold">{{ personne.nom }}</td>
                                <td>{{ personne.prenom }}</td>
                                <td>
                                    {% if personne.email %}
                                        <a href="mailto:{{ personne.email }}" class="text-decoration-none">
                                            <i class="fas fa-envelope me-1"></i>{{ personne.email }}
                                        </a>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if personne.telephone %}
                                        <i class="fas fa-phone me-1"></i>{{ personne.telephone }}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if personne.ville %}
                                        <i class="fas fa-map-marker-alt me-1"></i>{{ personne.ville }}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a href="{{ path('app_personne_show', {'id_personne': personne.idPersonne}) }}" 
                                           class="btn btn-outline-primary btn-sm" 
                                           title="Voir les détails">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('app_personne_edit', {'id_personne': personne.idPersonne}) }}" 
                                           class="btn btn-outline-secondary btn-sm" 
                                           title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button class="btn btn-outline-danger btn-sm delete-btn" 
                                                data-id="{{ personne.idPersonne }}" 
                                                title="Supprimer">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            {% else %}
                            <tr id="no-results-row" style="display: none;">
                                <td colspan="7" class="text-center text-muted py-4">
                                    <i class="fas fa-search me-2"></i>Aucune personne ne correspond aux critères de recherche.
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- JavaScript pour les filtres -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const filterNom = document.getElementById('filter-nom');
            const filterCivilite = document.getElementById('filter-civilite');
            const filterEmail = document.getElementById('filter-email');
            const filterVille = document.getElementById('filter-ville');
            const tableBody = document.getElementById('personnes-table-body');
            const filteredCount = document.getElementById('filtered-count');
            const noResultsRow = document.getElementById('no-results-row');
            
            function applyFilters() {
                const nomValue = filterNom.value.toLowerCase();
                const civiliteValue = filterCivilite.value;
                const emailValue = filterEmail.value.toLowerCase();
                const villeValue = filterVille.value.toLowerCase();
                
                const rows = document.querySelectorAll('.personne-row');
                let visibleCount = 0;
                
                rows.forEach(row => {
                    const nom = row.dataset.nom || '';
                    const prenom = row.dataset.prenom || '';
                    const email = row.dataset.email || '';
                    const civilite = row.dataset.civilite || '';
                    const ville = row.dataset.ville || '';
                    
                    const matchesNom = nomValue === '' || nom.includes(nomValue) || prenom.includes(nomValue);
                    const matchesCivilite = civiliteValue === '' || civilite === civiliteValue;
                    const matchesEmail = emailValue === '' || email.includes(emailValue);
                    const matchesVille = villeValue === '' || ville.includes(villeValue);
                    
                    if (matchesNom && matchesCivilite && matchesEmail && matchesVille) {
                        row.style.display = '';
                        visibleCount++;
                    } else {
                        row.style.display = 'none';
                    }
                });
                
                filteredCount.textContent = visibleCount;
                
                // Afficher "Aucun résultat" si nécessaire
                if (visibleCount === 0) {
                    noResultsRow.style.display = '';
                } else {
                    noResultsRow.style.display = 'none';
                }
            }
            
            // Ajouter les event listeners
            filterNom.addEventListener('input', applyFilters);
            filterCivilite.addEventListener('change', applyFilters);
            filterEmail.addEventListener('input', applyFilters);
            filterVille.addEventListener('input', applyFilters);
        });
        
        function clearAllFilters() {
            document.getElementById('filter-nom').value = '';
            document.getElementById('filter-civilite').value = '';
            document.getElementById('filter-email').value = '';
            document.getElementById('filter-ville').value = '';
            
            // Réappliquer les filtres (vides)
            document.querySelectorAll('.personne-row').forEach(row => {
                row.style.display = '';
            });
            
            document.getElementById('filtered-count').textContent = document.querySelectorAll('.personne-row').length;
            document.getElementById('no-results-row').style.display = 'none';
        }
        
        // Fonction pour afficher une notification
        function showNotification(message, type = 'danger') {
            const notificationsContainer = document.getElementById('notifications');
            
            const notification = document.createElement('div');
            notification.className = `alert alert-${type} alert-dismissible fade show`;
            notification.innerHTML = `
                <strong>${type === 'success' ? '✅ Succès:' : '❌ Erreur:'}</strong> ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            
            notificationsContainer.appendChild(notification);
            
            // Supprimer automatiquement après 5 secondes
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.remove();
                }
            }, 5000);
        }
        
        // Gestion de la suppression des personnes
        document.querySelectorAll('.delete-btn').forEach(function(button) {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                
                if (!confirm('Êtes-vous sûr de vouloir supprimer cette personne ?')) {
                    return;
                }
                
                const personneId = this.dataset.id;
                const row = this.closest('tr');
                
                fetch(`/personne/${personneId}/delete-ajax`, {
                    method: 'DELETE',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showNotification('Personne supprimée avec succès !', 'success');
                        row.remove();
                        // Mettre à jour le compteur
                        const count = document.querySelectorAll('.personne-row').length;
                        document.getElementById('filtered-count').textContent = count;
                        if (count === 0) {
                            document.getElementById('no-results-row').style.display = '';
                        }
                    } else {
                        showNotification(data.error || 'Impossible de supprimer la personne', 'danger');
                    }
                })
                .catch(error => {
                    console.error('Erreur:', error);
                    showNotification('Erreur de connexion ou serveur indisponible', 'danger');
                });
            });
        });
    </script>
{% endblock %}