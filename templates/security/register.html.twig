{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm mt-5">
                <div class="card-header text-center bg-success text-white">
                    <h4><i class="fas fa-user-plus me-2"></i>Inscription</h4>
                </div>
                <div class="card-body">
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i>{{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    {% if registrationForm.vars.errors|length > 0 %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i><strong>Erreurs de validation :</strong>
                            <ul class="mb-0 mt-2">
                                {% for error in registrationForm.vars.errors %}
                                    <li>{{ error.message }}</li>
                                {% endfor %}
                            </ul>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endif %}

                    {{ form_start(registrationForm, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
                    
                    <div class="mb-3">
                        {{ form_label(registrationForm.username, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(registrationForm.username, {'attr': {'class': 'form-control' ~ (registrationForm.username.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                        {% if registrationForm.username.vars.errors|length > 0 %}
                            <div class="invalid-feedback">
                                {% for error in registrationForm.username.vars.errors %}
                                    {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div class="mb-3">
                        {{ form_label(registrationForm.plainPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control' ~ (registrationForm.plainPassword.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                        {% if registrationForm.plainPassword.vars.errors|length > 0 %}
                            <div class="invalid-feedback">
                                {% for error in registrationForm.plainPassword.vars.errors %}
                                    {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div class="mb-3">
                        {{ form_label(registrationForm.plainPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control' ~ (registrationForm.plainPassword.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                    </div>

                    <div class="mb-3 form-check">
                        {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input' ~ (registrationForm.agreeTerms.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                        {{ form_label(registrationForm.agreeTerms, null, {'label_attr': {'class': 'form-check-label'}}) }}
                        {% if registrationForm.agreeTerms.vars.errors|length > 0 %}
                            <div class="invalid-feedback">
                                {% for error in registrationForm.agreeTerms.vars.errors %}
                                    {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-user-plus me-1"></i>S'inscrire
                        </button>
                    </div>

                    {{ form_end(registrationForm) }}

                    <hr>
                    <div class="text-center">
                        <p class="mb-0">Déjà un compte ?</p>
                        <a href="{{ path('app_login') }}" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-sign-in-alt me-1"></i>Se connecter
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Validation Bootstrap
(function() {
    'use strict';
    window.addEventListener('load', function() {
        var forms = document.getElementsByClassName('needs-validation');
        var validation = Array.prototype.filter.call(forms, function(form) {
            form.addEventListener('submit', function(event) {
                if (form.checkValidity() === false) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            }, false);
        });
        
        // Validation en temps réel
        const usernameInput = document.querySelector('#registration_form_username');
        const passwordInput = document.querySelector('#registration_form_plainPassword_first');
        const confirmPasswordInput = document.querySelector('#registration_form_plainPassword_second');
        
        if (usernameInput) {
            usernameInput.addEventListener('blur', validateUsername);
        }
        
        if (passwordInput) {
            passwordInput.addEventListener('blur', validatePassword);
        }
        
        if (confirmPasswordInput) {
            confirmPasswordInput.addEventListener('blur', validatePasswordConfirmation);
        }
    }, false);
    
    function validateUsername() {
        const input = document.querySelector('#registration_form_username');
        const value = input.value.trim();
        
        if (value.length < 3) {
            input.classList.add('is-invalid');
            input.classList.remove('is-valid');
        } else {
            input.classList.remove('is-invalid');
            input.classList.add('is-valid');
        }
    }
    
    function validatePassword() {
        const input = document.querySelector('#registration_form_plainPassword_first');
        const value = input.value;
        
        if (value.length < 6) {
            input.classList.add('is-invalid');
            input.classList.remove('is-valid');
        } else {
            input.classList.remove('is-invalid');
            input.classList.add('is-valid');
        }
    }
    
    function validatePasswordConfirmation() {
        const passwordInput = document.querySelector('#registration_form_plainPassword_first');
        const confirmInput = document.querySelector('#registration_form_plainPassword_second');
        
        if (passwordInput.value !== confirmInput.value) {
            confirmInput.classList.add('is-invalid');
            confirmInput.classList.remove('is-valid');
        } else {
            confirmInput.classList.remove('is-invalid');
            confirmInput.classList.add('is-valid');
        }
    }
})();
</script>
{% endblock %}