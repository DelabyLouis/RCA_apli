{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm mt-4">
                <div class="card-header text-center bg-success text-white">
                    <h3><i class="fas fa-user-plus me-2"></i>Inscription</h3>
                    <p class="mb-0">Créez votre compte pour accéder à l'application</p>
                </div>
                <div class="card-body">
                    {% if registrationForm.vars.errors|length > 0 %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i><strong>Erreurs de validation :</strong>
                            <ul class="mb-0 mt-2">
                                {% for error in registrationForm.vars.errors %}
                                    <li>{{ error.message }}</li>
                                {% endfor %}
                            </ul>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endif %}

                    {{ form_start(registrationForm, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
                    
                    <!-- ========== INFORMATIONS DE CONNEXION ========== -->
                    <div class="border rounded p-3 mb-4 bg-light">
                        <h5 class="text-primary mb-3">
                            <i class="fas fa-key me-2"></i>Informations de connexion
                        </h5>
                        
                        <div class="mb-3">
                            {{ form_label(registrationForm.username, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(registrationForm.username, {'attr': {'class': 'form-control' ~ (registrationForm.username.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                            {% if registrationForm.username.vars.errors|length > 0 %}
                                <div class="invalid-feedback">
                                    {% for error in registrationForm.username.vars.errors %}
                                        {{ error.message }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(registrationForm.plainPassword.first, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control' ~ (registrationForm.plainPassword.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if registrationForm.plainPassword.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in registrationForm.plainPassword.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(registrationForm.plainPassword.second, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control' ~ (registrationForm.plainPassword.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                            </div>
                        </div>
                    </div>

                    <!-- ========== INFORMATIONS PERSONNELLES ========== -->
                    <div class="border rounded p-3 mb-4 bg-light">
                        <h5 class="text-primary mb-3">
                            <i class="fas fa-user me-2"></i>Informations personnelles
                        </h5>
                        
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                {{ form_label(registrationForm.civilite, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.civilite, {'attr': {'class': 'form-select'}}) }}
                            </div>
                            <div class="col-md-4 mb-3">
                                {{ form_label(registrationForm.nom, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(registrationForm.nom, {'attr': {'class': 'form-control' ~ (registrationForm.nom.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if registrationForm.nom.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in registrationForm.nom.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="col-md-4 mb-3">
                                {{ form_label(registrationForm.prenom, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(registrationForm.prenom, {'attr': {'class': 'form-control' ~ (registrationForm.prenom.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if registrationForm.prenom.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in registrationForm.prenom.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control' ~ (registrationForm.email.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if registrationForm.email.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in registrationForm.email.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="col-md-4 mb-3">
                                {{ form_label(registrationForm.telephone, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.telephone, {'attr': {'class': 'form-control'}}) }}
                            </div>
                        </div>
                    </div>

                    <!-- ========== ADRESSE ========== -->
                    <div class="border rounded p-3 mb-4 bg-light">
                        <h5 class="text-primary mb-3">
                            <i class="fas fa-map-marker-alt me-2"></i>Adresse
                        </h5>
                        
                        <div class="row">
                            <div class="col-md-3 mb-3">
                                {{ form_label(registrationForm.numero_voie, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.numero_voie, {'attr': {'class': 'form-control'}}) }}
                            </div>
                            <div class="col-md-9 mb-3">
                                {{ form_label(registrationForm.rue, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.rue, {'attr': {'class': 'form-control'}}) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.complement_adresse, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.complement_adresse, {'attr': {'class': 'form-control'}}) }}
                        </div>

                        <div class="row">
                            <div class="col-md-3 mb-3">
                                {{ form_label(registrationForm.code_postal, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.code_postal, {'attr': {'class': 'form-control'}}) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(registrationForm.ville, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.ville, {'attr': {'class': 'form-control'}}) }}
                            </div>
                            <div class="col-md-3 mb-3">
                                {{ form_label(registrationForm.pays, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.pays, {'attr': {'class': 'form-control'}}) }}
                            </div>
                        </div>
                    </div>

                    <!-- ========== CONDITIONS ET RGPD ========== -->
                    <div class="border rounded p-3 mb-4 bg-primary bg-opacity-10">
                        <h6 class="text-primary mb-3">
                            <i class="fas fa-shield-alt me-2"></i>Conditions et Protection des Données
                        </h6>
                        
                        <!-- Conditions d'utilisation -->
                        <div class="form-check mb-3">
                            {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input' ~ (registrationForm.agreeTerms.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                            {{ form_label(registrationForm.agreeTerms, null, {'label_attr': {'class': 'form-check-label fw-bold'}}) }}
                            {% if registrationForm.agreeTerms.vars.errors|length > 0 %}
                                <div class="invalid-feedback">
                                    {% for error in registrationForm.agreeTerms.vars.errors %}
                                        {{ error.message }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <!-- Politique de confidentialité -->
                        <div class="form-check mb-3">
                            {{ form_widget(registrationForm.agreePrivacy, {'attr': {'class': 'form-check-input' ~ (registrationForm.agreePrivacy.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                            <label class="form-check-label fw-bold" for="{{ registrationForm.agreePrivacy.vars.id }}">
                                J'accepte la 
                                <a href="{{ path('app_privacy_policy') }}" target="_blank" class="text-decoration-none">
                                    politique de confidentialité
                                    <i class="fas fa-external-link-alt fa-xs"></i>
                                </a>
                                et le traitement de mes données personnelles *
                            </label>
                            {% if registrationForm.agreePrivacy.vars.errors|length > 0 %}
                                <div class="invalid-feedback">
                                    {% for error in registrationForm.agreePrivacy.vars.errors %}
                                        {{ error.message }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <!-- Consentement communication (optionnel) -->
                        <div class="form-check mb-3">
                            {{ form_widget(registrationForm.consentCommunication, {'attr': {'class': 'form-check-input'}}) }}
                            {{ form_label(registrationForm.consentCommunication, null, {'label_attr': {'class': 'form-check-label'}}) }}
                            <small class="form-text text-muted d-block mt-1">
                                <i class="fas fa-info-circle me-1"></i>
                                Vous pouvez retirer ce consentement à tout moment dans votre espace personnel.
                            </small>
                        </div>

                        <div class="alert alert-info mb-0">
                            <small>
                                <i class="fas fa-info-circle me-1"></i>
                                <strong>Information RGPD :</strong> Vos données personnelles sont collectées pour la gestion 
                                de votre adhésion au club. Vous disposez d'un droit d'accès, de rectification, de suppression 
                                et de portabilité sur vos données. 
                                <a href="{{ path('app_privacy_policy') }}" target="_blank" class="text-decoration-none">
                                    En savoir plus
                                </a>
                            </small>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="fas fa-user-plus me-2"></i>Créer mon compte
                        </button>
                    </div>

                    {{ form_end(registrationForm) }}

                    <div class="text-center mt-3">
                        <p class="text-muted">
                            Vous avez déjà un compte ? 
                            <a href="{{ path('app_login') }}" class="text-decoration-none">
                                <i class="fas fa-sign-in-alt me-1"></i>Se connecter
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}