{% extends 'base.html.twig' %}

{% block title %}Entreprise{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .editable-field {
            cursor: pointer;
            padding: 8px;
            border: 1px solid transparent;
            border-radius: 4px;
            transition: all 0.2s;
            min-height: 20px;
            display: inline-block;
            min-width: 200px;
        }
        
        .editable-field:hover {
            background-color: #f8f9fa;
            border-color: #dee2e6;
        }
        
        .editable-field.editing {
            background-color: #fff;
            border-color: #007bff;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
        }
        
        .editable-input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            font-size: inherit;
            font-family: inherit;
            min-width: 200px;
        }
        
        .saving {
            opacity: 0.6;
            pointer-events: none;
        }
        
        .alert {
            margin: 15px 0;
            padding: 12px;
            border-radius: 4px;
            border: 1px solid transparent;
        }
        
        .alert-success {
            background-color: #d4edda;
            border-color: #c3e6cb;
            color: #155724;
        }
        
        .alert-danger {
            background-color: #f8d7da;
            border-color: #f5c6cb;
            color: #721c24;
        }
        
        .table td {
            vertical-align: middle;
        }
        
        .readonly-field {
            background-color: #f8f9fa;
            color: #6c757d;
            padding: 8px;
            border-radius: 4px;
        }
    </style>
{% endblock %}

{% block body %}
    <h1>Entreprise</h1>
    
    <div id="message-container"></div>

    <table class="table" data-id="{{ entreprise.idEntreprise }}">
        <tbody>
            <tr>
                <th width="150">Id_entreprise</th>
                <td>
                    <span class="readonly-field">{{ entreprise.idEntreprise }}</span>
                </td>
            </tr>
            <tr>
                <th>Nom_entreprise</th>
                <td>
                    <span class="editable-field" data-field="nom_entreprise">{{ entreprise.nomEntreprise }}</span>
                </td>
            </tr>
            <tr>
                <th>Siret</th>
                <td>
                    <span class="editable-field" data-field="siret">{{ entreprise.siret }}</span>
                </td>
            </tr>
            <tr>
                <th>Siren</th>
                <td>
                    <span class="editable-field" data-field="siren">{{ entreprise.siren }}</span>
                </td>
            </tr>
            <tr>
                <th>Numero_voie</th>
                <td>
                    <span class="editable-field" data-field="numero_voie">{{ entreprise.numeroVoie }}</span>
                </td>
            </tr>
            <tr>
                <th>Rue</th>
                <td>
                    <span class="editable-field" data-field="rue">{{ entreprise.rue }}</span>
                </td>
            </tr>
            <tr>
                <th>Complement_adresse</th>
                <td>
                    <span class="editable-field" data-field="complement_adresse">{{ entreprise.complementAdresse }}</span>
                </td>
            </tr>
            <tr>
                <th>Ville</th>
                <td>
                    <span class="editable-field" data-field="ville">{{ entreprise.ville }}</span>
                </td>
            </tr>
            <tr>
                <th>Code_postal</th>
                <td>
                    <span class="editable-field" data-field="code_postal">{{ entreprise.codePostal }}</span>
                </td>
            </tr>
            <tr>
                <th>Pays</th>
                <td>
                    <span class="editable-field" data-field="pays">{{ entreprise.pays }}</span>
                </td>
            </tr>
            <tr>
                <th>Telephone</th>
                <td>
                    <span class="editable-field" data-field="telephone">{{ entreprise.telephone }}</span>
                </td>
            </tr>
            <tr>
                <th>Email</th>
                <td>
                    <span class="editable-field" data-field="email">{{ entreprise.email }}</span>
                </td>
            </tr>
        </tbody>
    </table>

    <div class="mt-3">
        <a href="{{ path('app_entreprise_index') }}" class="btn btn-secondary">back to list</a>
        <a href="{{ path('app_entreprise_edit', {'id_entreprise': entreprise.idEntreprise}) }}" class="btn btn-primary">edit</a>
        {{ include('entreprise/_delete_form.html.twig') }}
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            let currentEditingField = null;
            let originalValue = '';
            
            function showMessage(message, type) {
                const container = document.getElementById('message-container');
                container.innerHTML = '';
                
                const alert = document.createElement('div');
                alert.className = `alert alert-${type}`;
                alert.textContent = message;
                container.appendChild(alert);
                
                setTimeout(() => {
                    alert.remove();
                }, 4000);
            }
            
            function saveField(field, value, entrepriseId) {
                const table = document.querySelector('.table');
                table.classList.add('saving');
                
                fetch(`/entreprise/${entrepriseId}/update-field`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `field=${encodeURIComponent(field)}&value=${encodeURIComponent(value)}`
                })
                .then(response => response.json())
                .then(data => {
                    table.classList.remove('saving');
                    
                    if (data.success) {
                        currentEditingField.textContent = value || '';
                        showMessage(data.message, 'success');
                    } else {
                        currentEditingField.textContent = originalValue;
                        showMessage(data.message, 'danger');
                    }
                })
                .catch(error => {
                    table.classList.remove('saving');
                    currentEditingField.textContent = originalValue;
                    showMessage('Erreur de communication avec le serveur', 'danger');
                    console.error('Error:', error);
                });
            }
            
            function startEditing(field) {
                if (currentEditingField && currentEditingField !== field) {
                    stopEditing(false);
                }
                
                currentEditingField = field;
                originalValue = field.textContent;
                
                field.classList.add('editing');
                
                const input = document.createElement('input');
                input.className = 'editable-input';
                input.type = 'text';
                input.value = originalValue;
                
                field.textContent = '';
                field.appendChild(input);
                
                input.focus();
                input.select();
                
                input.addEventListener('blur', function() {
                    stopEditing(true);
                });
                
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        stopEditing(true);
                    } else if (e.key === 'Escape') {
                        e.preventDefault();
                        stopEditing(false);
                    }
                });
            }
            
            function stopEditing(save) {
                if (!currentEditingField || !currentEditingField.classList.contains('editing')) return;
                
                const input = currentEditingField.querySelector('input');
                const newValue = input ? input.value.trim() : '';
                
                currentEditingField.classList.remove('editing');
                
                if (save && newValue !== originalValue) {
                    const fieldName = currentEditingField.dataset.field;
                    const entrepriseId = document.querySelector('.table').dataset.id;
                    
                    if (fieldName === 'nom_entreprise' && !newValue) {
                        showMessage('Le nom de l\'entreprise ne peut pas être vide', 'danger');
                        currentEditingField.textContent = originalValue;
                    } else {
                        saveField(fieldName, newValue, entrepriseId);
                    }
                } else {
                    currentEditingField.textContent = originalValue;
                }
                
                currentEditingField = null;
            }
            
            document.querySelectorAll('.editable-field').forEach(field => {
                field.addEventListener('click', function() {
                    if (!this.classList.contains('editing')) {
                        startEditing(this);
                    }
                });
            });
            
            document.addEventListener('click', function(e) {
                if (currentEditingField && 
                    !currentEditingField.contains(e.target) && 
                    !e.target.classList.contains('editable-field')) {
                    stopEditing(false);
                }
            });
        });
    </script>
{% endblock %}
