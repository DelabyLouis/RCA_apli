{% extends 'base.html.twig' %}

{% block title %}Entreprise index{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .editable-field {
            cursor: pointer;
            padding: 5px;
            border: 1px solid transparent;
            border-radius: 3px;
            transition: all 0.2s;
        }
        
        .editable-field:hover {
            background-color: #f8f9fa;
            border-color: #dee2e6;
        }
        
        .editable-field.editing {
            background-color: #fff;
            border-color: #007bff;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
        }
        
        .editable-input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            font-size: inherit;
            font-family: inherit;
            padding: 0;
            margin: 0;
        }
        
        /* Masquer les rectangles blancs indésirables */
        .editable-field input,
        .editable-field textarea,
        .editable-field select {
            border: none !important;
            outline: none !important;
            box-shadow: none !important;
            background: transparent !important;
        }
        
        .saving {
            opacity: 0.6;
            pointer-events: none;
        }
        
        .alert {
            margin: 10px 0;
            padding: 10px;
            border-radius: 4px;
        }
        
        .alert-success {
            background-color: #d4edda;
            border-color: #c3e6cb;
            color: #155724;
        }
        
        .alert-danger {
            background-color: #f8d7da;
            border-color: #f5c6cb;
            color: #721c24;
        }
    </style>
{% endblock %}

{% block body %}
    <h1>Entreprise index</h1>
    
    <div id="message-container"></div>

        {% include 'components/entity_filter_detailed.html.twig' with {
        'filters': [
            {
                'field': 'nom',
                'label': 'Nom',
                'type': 'text',
                'placeholder': 'Rechercher par nom...',
                'width': 3
            },
            {
                'field': 'siret',
                'label': 'SIRET',
                'type': 'text',
                'placeholder': 'Rechercher par SIRET...',
                'width': 3
            },
            {
                'field': 'siren',
                'label': 'SIREN',
                'type': 'text',
                'placeholder': 'Rechercher par SIREN...',
                'width': 3
            },
            {
                'field': 'ville',
                'label': 'Ville',
                'type': 'text',
                'placeholder': 'Rechercher par ville...',
                'width': 3
            }
        ],
        'tableSelector': '.table tbody'
    } %}

    <table class="table" data-turbo="false">
        <thead>
            <tr>
                <th>Nom entreprise</th>
                <th>Siret</th>
                <th>Siren</th>
                <th>N° Voie</th>
                <th>Rue</th>
                <th>Complément</th>
                <th>Ville</th>
                <th>Code Postal</th>
                <th>Pays</th>
                <th>Téléphone</th>
                <th>Email</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for entreprise in entreprises %}
            <tr data-id="{{ entreprise.idEntreprise }}">
                <td class="editable-field" data-field="nom_entreprise">{{ entreprise.nomEntreprise }}</td>
                <td class="editable-field" data-field="siret">{{ entreprise.siret }}</td>
                <td class="editable-field" data-field="siren">{{ entreprise.siren }}</td>
                <td class="editable-field" data-field="numero_voie">{{ entreprise.numeroVoie }}</td>
                <td class="editable-field" data-field="rue">{{ entreprise.rue }}</td>
                <td class="editable-field" data-field="complement_adresse">{{ entreprise.complementAdresse }}</td>
                <td class="editable-field" data-field="ville">{{ entreprise.ville }}</td>
                <td class="editable-field" data-field="code_postal">{{ entreprise.codePostal }}</td>
                <td class="editable-field" data-field="pays">{{ entreprise.pays }}</td>
                <td class="editable-field" data-field="telephone">{{ entreprise.telephone }}</td>
                <td class="editable-field" data-field="email">{{ entreprise.email }}</td>
                <td>
                    <div class="btn-group" role="group">
                        <a href="{{ path('app_entreprise_show', {'id_entreprise': entreprise.idEntreprise}) }}" class="btn btn-info btn-sm" title="Voir les détails">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a href="{{ path('app_entreprise_edit', {'id_entreprise': entreprise.idEntreprise}) }}" class="btn btn-warning btn-sm" title="Modifier">
                            <i class="fas fa-edit"></i>
                        </a>
                        <button class="btn btn-danger btn-sm delete-btn" data-id="{{ entreprise.idEntreprise }}" title="Supprimer">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="13">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_entreprise_new') }}">Create new</a>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            let currentEditingCell = null;
            let originalValue = '';
            
            // Fonction pour afficher les messages
            function showMessage(message, type) {
                const container = document.getElementById('message-container');
                const alert = document.createElement('div');
                alert.className = `alert alert-${type}`;
                alert.textContent = message;
                container.appendChild(alert);
                
                setTimeout(() => {
                    alert.remove();
                }, 3000);
            }
            
            // Fonction pour sauvegarder la modification
            function saveField(cell, field, value, entrepriseId) {
                const row = cell.closest('tr');
                row.classList.add('saving');
                
                fetch(`/entreprise/${entrepriseId}/update-field`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `field=${encodeURIComponent(field)}&value=${encodeURIComponent(value)}`
                })
                .then(response => response.json())
                .then(data => {
                    row.classList.remove('saving');
                    
                    if (data.success) {
                        cell.textContent = value || '';
                    } else {
                        cell.textContent = originalValue;
                        showMessage(data.message, 'danger');
                    }
                })
                .catch(error => {
                    row.classList.remove('saving');
                    cell.textContent = originalValue;
                    showMessage('Erreur de communication avec le serveur', 'danger');
                    console.error('Error:', error);
                });
            }
            
            // Fonction pour entrer en mode édition
            function startEditing(cell) {
                if (currentEditingCell && currentEditingCell !== cell) {
                    stopEditing(currentEditingCell, false);
                }
                
                currentEditingCell = cell;
                originalValue = cell.textContent;
                
                cell.classList.add('editing');
                
                const input = document.createElement('input');
                input.className = 'editable-input';
                input.type = 'text';
                input.value = originalValue;
                
                cell.textContent = '';
                cell.appendChild(input);
                
                input.focus();
                input.select();
                
                input.addEventListener('blur', function() {
                    stopEditing(cell, true);
                });
                
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        stopEditing(cell, true);
                    } else if (e.key === 'Escape') {
                        e.preventDefault();
                        stopEditing(cell, false);
                    }
                });
                
                // Empêcher la propagation du clic sur l'input pour éviter de relancer l'édition
                input.addEventListener('click', function(e) {
                    e.stopPropagation();
                });
            }
            
            // Fonction pour sortir du mode édition
            function stopEditing(cell, save) {
                if (!cell || !cell.classList.contains('editing')) return;
                
                const input = cell.querySelector('input');
                const newValue = input ? input.value.trim() : '';
                
                cell.classList.remove('editing');
                
                if (save && newValue !== originalValue) {
                    const field = cell.dataset.field;
                    const entrepriseId = cell.closest('tr').dataset.id;
                    
                    if (field === 'nom_entreprise' && !newValue) {
                        showMessage('Le nom de l\'entreprise ne peut pas être vide', 'danger');
                        cell.textContent = originalValue;
                    } else {
                        saveField(cell, field, newValue, entrepriseId);
                    }
                } else {
                    cell.textContent = originalValue;
                }
                
                currentEditingCell = null;
            }
            
            // Délégation d'événements pour les cellules éditables - plus robuste
            document.addEventListener('click', function(e) {
                const cell = e.target.closest('.editable-field');
                if (!cell) return;
                
                // Si on clique sur un input/textarea à l'intérieur, ne pas traiter le clic de la cellule
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') {
                    return;
                }
                
                // Si la cellule est déjà en cours d'édition, ne pas relancer l'édition
                if (cell.classList.contains('editing')) {
                    return;
                }
                
                startEditing(cell);
            });
            
            // Annuler l'édition si on clique ailleurs
            document.addEventListener('click', function(e) {
                if (currentEditingCell && !currentEditingCell.contains(e.target)) {
                    stopEditing(currentEditingCell, false);
                }
            });

            // Délégation d'événements pour les boutons de suppression
            document.addEventListener('click', function(e) {
                if (!e.target.closest('.delete-btn')) return;
                
                const button = e.target.closest('.delete-btn');
                e.stopPropagation();
                
                const id = button.getAttribute('data-id');
                const row = button.closest('tr');
                
                if (confirm('Êtes-vous sûr de vouloir supprimer cette entreprise ?')) {
                    // Désactiver le bouton pendant la suppression
                    button.disabled = true;
                    button.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Suppression...';
                        
                        // Restaurer le bouton
                            button.disabled = false;
                            button.innerHTML = '<i class="fas fa-trash me-1"></i> Supprimer';
                        }
                    })
                    .catch(error => {
                        console.error('Erreur:', error);
                        alert('Erreur lors de la suppression');
                        // Restaurer le bouton
                        button.disabled = false;
                        button.innerHTML = '<i class="fas fa-trash me-1"></i> Supprimer';
                    });
                }
            });
                    }
            });
            }, 100); // Délai pour s'assurer que tous les éléments sont prêts
        });
    </script>
{% endblock %}
