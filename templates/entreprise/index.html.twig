{% extends 'base.html.twig' %}

{% block title %}Gestion des Entreprises - RCA Application{% endblock %}

{% block body %}
    {{ include('components/inline_edit_styles.html.twig') }}
    
    <style>
        #entreprises-table th:nth-child(1), #entreprises-table td:nth-child(1) { width: 195px !important; max-width: 195px !important; }
        #entreprises-table th:nth-child(2), #entreprises-table td:nth-child(2) { width: 155px !important; max-width: 155px !important; }
        #entreprises-table th:nth-child(3), #entreprises-table td:nth-child(3) { width: 165px !important; max-width: 165px !important; }
        #entreprises-table th:nth-child(4), #entreprises-table td:nth-child(4) { width: 175px !important; max-width: 175px !important; }
        #entreprises-table th:nth-child(5), #entreprises-table td:nth-child(5) { width: 145px !important; max-width: 145px !important; }
        #entreprises-table th:nth-child(6), #entreprises-table td:nth-child(6) { width: 120px !important; max-width: 120px !important; }
        
        #entreprises-table th:nth-child(1), #entreprises-table td:nth-child(1),
        #entreprises-table th:nth-child(2), #entreprises-table td:nth-child(2),
        #entreprises-table th:nth-child(3), #entreprises-table td:nth-child(3),
        #entreprises-table th:nth-child(4), #entreprises-table td:nth-child(4),
        #entreprises-table th:nth-child(5), #entreprises-table td:nth-child(5),
        #entreprises-table th:nth-child(6), #entreprises-table td:nth-child(6) {
            overflow: hidden !important;
            text-overflow: ellipsis !important;
            white-space: nowrap !important;
        }
        
        /* Marges pour le tableau */
        .container-fluid.mt-4 {
            padding-left: 3rem !important;
            padding-right: 3rem !important;
        }
    </style>
    
    <div class="container-fluid mt-4">
        <h1 class="mb-4">Gestion des Entreprises</h1>
        
        <div class="row mb-3">
            <div class="col">
                <a href="{{ path('app_entreprise_new') }}" class="btn btn-success">
                    <i class="fas fa-plus me-2"></i>Nouvelle Entreprise
                </a>
            </div>
        </div>
        
        <!-- Filtres personnalisés -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filtres</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Filtre Nom -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-nom" class="form-label">Nom de l'entreprise</label>
                        <input type="text" class="form-control" id="filter-nom" placeholder="Rechercher par nom...">
                    </div>
                    
                    <!-- Filtre SIRET -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-siret" class="form-label">SIRET</label>
                        <input type="text" class="form-control" id="filter-siret" placeholder="SIRET...">
                    </div>
                    
                    <!-- Filtre Ville -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-ville" class="form-label">Ville</label>
                        <input type="text" class="form-control" id="filter-ville" placeholder="Ville...">
                    </div>
                    
                    <!-- Actions filtres -->
                    <div class="col-md-2 mb-3 d-flex align-items-end">
                        <button type="button" class="btn btn-secondary me-2" onclick="clearAllFilters()">
                            <i class="fas fa-eraser me-1"></i>Effacer
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tableau des entreprises -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-building me-2"></i>Liste des Entreprises
                    <span id="total-count" class="badge bg-primary ms-2">{{ entreprises|length }}</span>
                </h5>
                <small class="text-muted">
                    <span id="filtered-count">{{ entreprises|length }}</span> entreprises affichées
                </small>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="entreprises-table" class="table table-striped table-hover mb-0 fs-5">
                        <thead class="table-dark">
                            <tr>
                                <th class="fs-5">Nom</th>
                                <th class="fs-5">SIRET</th>
                                <th class="fs-5">Email</th>
                                <th class="fs-5">Téléphone</th>
                                <th class="fs-5">Ville</th>
                                <th class="text-center fs-5" style="width: 120px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="entreprises-table-body">
                            {% for entreprise in entreprises %}
                            <tr class="entreprise-row" 
                                data-nom="{{ entreprise.nomEntreprise|lower }}" 
                                data-siret="{{ entreprise.siret }}" 
                                data-email="{{ entreprise.email|lower }}"
                                data-ville="{{ entreprise.ville|lower }}">
                                <td class="fw-semibold">{{ entreprise.nomEntreprise }}</td>
                                <td>
                                    {% if entreprise.siret %}
                                        <span class="font-monospace">{{ entreprise.siret }}</span>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if entreprise.email %}
                                        <a href="mailto:{{ entreprise.email }}" class="text-decoration-none">
                                            <i class="fas fa-envelope me-1"></i>{{ entreprise.email }}
                                        </a>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if entreprise.telephone %}
                                        <i class="fas fa-phone me-1"></i>{{ entreprise.telephone }}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if entreprise.ville %}
                                        <i class="fas fa-map-marker-alt me-1"></i>{{ entreprise.ville }}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a href="{{ path('app_entreprise_show', {'id_entreprise': entreprise.idEntreprise}) }}" 
                                           class="btn btn-outline-primary btn-sm" 
                                           title="Voir les détails">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('app_entreprise_edit', {'id_entreprise': entreprise.idEntreprise}) }}" 
                                           class="btn btn-outline-secondary btn-sm" 
                                           title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            {% else %}
                            <tr id="no-results-row" style="display: none;">
                                <td colspan="7" class="text-center text-muted py-4">
                                    <i class="fas fa-search me-2"></i>Aucune entreprise ne correspond aux critères de recherche.
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- JavaScript pour les filtres -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const filterNom = document.getElementById('filter-nom');
            const filterSiret = document.getElementById('filter-siret');
            const filterVille = document.getElementById('filter-ville');
            const tableBody = document.getElementById('entreprises-table-body');
            const filteredCount = document.getElementById('filtered-count');
            const noResultsRow = document.getElementById('no-results-row');
            
            function applyFilters() {
                const nomValue = filterNom.value.toLowerCase();
                const siretValue = filterSiret.value;
                const villeValue = filterVille.value.toLowerCase();
                
                const rows = document.querySelectorAll('.entreprise-row');
                let visibleCount = 0;
                
                rows.forEach(row => {
                    const nom = row.dataset.nom || '';
                    const siret = row.dataset.siret || '';
                    const ville = row.dataset.ville || '';
                    
                    const matchesNom = nomValue === '' || nom.includes(nomValue);
                    const matchesSiret = siretValue === '' || siret.includes(siretValue);
                    const matchesVille = villeValue === '' || ville.includes(villeValue);
                    
                    if (matchesNom && matchesSiret && matchesVille) {
                        row.style.display = '';
                        visibleCount++;
                    } else {
                        row.style.display = 'none';
                    }
                });
                
                filteredCount.textContent = visibleCount;
                
                // Afficher "Aucun résultat" si nécessaire
                if (visibleCount === 0) {
                    noResultsRow.style.display = '';
                } else {
                    noResultsRow.style.display = 'none';
                }
            }
            
            // Ajouter les event listeners
            filterNom.addEventListener('input', applyFilters);
            filterSiret.addEventListener('input', applyFilters);
            filterVille.addEventListener('input', applyFilters);
        });
        
        function clearAllFilters() {
            document.getElementById('filter-nom').value = '';
            document.getElementById('filter-siret').value = '';
            document.getElementById('filter-ville').value = '';
            
            // Réappliquer les filtres (vides)
            document.querySelectorAll('.entreprise-row').forEach(row => {
                row.style.display = '';
            });
            
            document.getElementById('filtered-count').textContent = document.querySelectorAll('.entreprise-row').length;
            document.getElementById('no-results-row').style.display = 'none';
        }
    </script>
{% endblock %}