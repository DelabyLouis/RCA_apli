{% extends 'base.html.twig' %}

{% block title %}{{ user.username }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-user me-2"></i>{{ user.username }}
                    </h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <tr>
                                <th class="text-muted" style="width: 20%;">Nom d'utilisateur :</th>
                                <td><strong>{{ user.username }}</strong></td>
                            </tr>
                            {% if user.personne %}
                            <tr>
                                <th class="text-muted">Personne liée :</th>
                                <td>{{ user.personne.prenom }} {{ user.personne.nom }}</td>
                            </tr>
                            {% endif %}
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-light">
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_user_edit', {'id_user': user.idUser}) }}" class="btn btn-warning">
                            <i class="fas fa-edit me-1"></i>Modifier
                        </a>
                        <a href="{{ path('app_user_index') }}" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}