{% extends 'base.html.twig' %}{% extends 'base.html.twig' %}



{% block title %}Nouvel Utilisateur{% endblock %}{% block title %}Nouvel Utilisateur{% endblock %}



{% block body %}{% block body %}

<div class="container-fluid"><div class="container-fluid">

    <div class="row">    <div class="row">

        <div class="col-12">        <div class="col-12">

            <div class="d-flex justify-content-between align-items-center mb-4">            <div class="card shadow-sm">

                <h1><i class="fas fa-user-plus me-2"></i>Nouvel Utilisateur</h1>                <div class="card-header bg-primary text-white">

                <a href="{{ path('app_user_index') }}" class="btn btn-secondary">                    <h5 class="mb-0">

                    <i class="fas fa-arrow-left me-1"></i>Retour à la liste                        <i class="fas fa-user-plus me-2"></i>Nouvel Utilisateur

                </a>                    </h5>

            </div>                </div>

                <div class="card-body">

            {% if form.vars.errors|length > 0 %}                    {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}

                <div class="alert alert-danger alert-dismissible fade show" role="alert">                    {{ form_rest(form) }}

                    <i class="fas fa-exclamation-triangle me-2"></i><strong>Erreurs de validation :</strong>                    

                    <ul class="mb-0 mt-2">                    <div class="col-12">

                        {% for error in form.vars.errors %}                        <div class="d-flex gap-2">

                            <li>{{ error.message }}</li>                            <button type="submit" class="btn btn-primary">

                        {% endfor %}                                <i class="fas fa-save me-1"></i>Créer

                    </ul>                            </button>

                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>                            <a href="{{ path('app_user_index') }}" class="btn btn-secondary">

                </div>                                <i class="fas fa-times me-1"></i>Annuler

            {% endif %}                            </a>

                        </div>

            <div class="card shadow-sm">                    </div>

                <div class="card-body">                    

                    <div class="row">                    {{ form_end(form) }}

                        <div class="col-lg-6">                </div>

                            {{ form_start(form, {'attr': {'novalidate': false, 'id': 'user_new_form'}}) }}            </div>

                                    </div>

                            <div class="mb-3">    </div>

                                {{ form_label(form.username, 'Nom d\'utilisateur', {'label_attr': {'class': 'form-label'}}) }}</div>

                                {{ form_widget(form.username, {'attr': {'class': 'form-control' ~ (form.username.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}{% endblock %}
                                {% if form.username.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.username.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.username) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.password, 'Mot de passe', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.password, {'attr': {'class': 'form-control' ~ (form.password.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.password.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.password.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.password) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.personne, 'Personne associée', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.personne, {'attr': {'class': 'form-select' ~ (form.personne.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.personne.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.personne.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.personne) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.roles, 'Rôles', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.roles, {'attr': {'class': 'form-select' ~ (form.roles.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.roles.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.roles.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.roles) }}
                            </div>
                            
                            {{ form_end(form) }}
                        </div>
                        
                        <div class="col-lg-6">
                            <div class="d-flex flex-column gap-3 sticky-top px-5" style="top: 20px;">
                                <h6 class="text-muted mb-0">Actions</h6>
                                <a href="{{ path('app_user_index') }}" class="btn btn-secondary btn-lg py-3" style="margin: 0 3rem;">
                                    <i class="fas fa-times me-2"></i>Annuler
                                </a>
                                <button type="submit" class="btn btn-success btn-lg py-3" style="margin: 0 3rem;" form="user_new_form">
                                    <i class="fas fa-save me-2"></i>Créer l'utilisateur
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}