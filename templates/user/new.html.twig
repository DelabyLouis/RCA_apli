{% extends 'base.html.twig' %}

{% block title %}Nouvel Utilisateur{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-user-plus me-2"></i>Nouvel Utilisateur</h1>
                <a href="{{ path('app_user_index') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                </a>
            </div>

            {% if form.vars.errors|length > 0 %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i><strong>Erreurs de validation :</strong>
                    <ul class="mb-0 mt-2">
                        {% for error in form.vars.errors %}
                            <li>{{ error.message }}</li>
                        {% endfor %}
                    </ul>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endif %}

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-user-plus me-2"></i>Nouvel Utilisateur
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-6">
                            {{ form_start(form, {'attr': {'id': 'user_new_form'}}) }}
                            
                            <div class="mb-3">
                    <div class="row">
                        <div class="col-lg-6">
                            {{ form_start(form, {'attr': {'id': 'user_new_form'}}) }}
                            
                            <div class="mb-3">
                                {{ form_label(form.username, 'Nom d\'utilisateur', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.username, {'attr': {'class': 'form-control' ~ (form.username.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.username.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.username.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.username) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.password, 'Mot de passe', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.password, {'attr': {'class': 'form-control' ~ (form.password.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.password.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.password.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.password) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.personne, 'Personne associée', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.personne, {'attr': {'class': 'form-select' ~ (form.personne.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.personne.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.personne.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.personne) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.userRoles, 'Rôles', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.userRoles, {'attr': {'class': 'form-check' ~ (form.userRoles.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.userRoles.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.userRoles.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.userRoles) }}
                            </div>
                            
                            {{ form_end(form) }}
                        </div>
                        
                        <div class="col-lg-6">
                            <div class="d-flex flex-column gap-3 sticky-top px-5" style="top: 20px;">
                                <h6 class="text-muted mb-0">Actions</h6>
                                <a href="{{ path('app_user_index') }}" class="btn btn-secondary btn-lg py-3" style="margin: 0 3rem;">
                                    <i class="fas fa-times me-2"></i>Annuler
                                </a>
                                <button type="submit" class="btn btn-success btn-lg py-3" style="margin: 0 3rem;" form="user_new_form">
                                    <i class="fas fa-save me-2"></i>Créer l'utilisateur
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}