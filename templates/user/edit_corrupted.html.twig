{% extends 'base.html.twig' %}

{% block title %}Modifier {{ user.username }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <h1 class="mb-4">
        <i class="fas fa-edit me-2 text-warning"></i>Modifier {{ user.username }}
    </h1>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Modifier les informations de l'utilisateur</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.username, 'Nom d\'utilisateur') }}
                                {{ form_widget(form.username, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.username) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.password, 'Mot de passe') }}
                                {{ form_widget(form.password, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.password) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.personne, 'Personne associée', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.personne, {'attr': {'class': 'form-select' ~ (form.personne.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.personne.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.personne.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.personne) }}
                            </div>
                            
                            <div class="mb-3">
                                {{ form_label(form.userRoles, 'Rôles', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.userRoles, {'attr': {'class': 'form-check' ~ (form.userRoles.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.userRoles.vars.errors|length > 0 %}
                                    <div class="invalid-feedback">
                                        {% for error in form.userRoles.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {{ form_errors(form.userRoles) }}
                            </div>
                            
                            {{ form_end(form) }}
                        </div>
                        
                        <div class="col-lg-6">
                            <div class="d-flex flex-column gap-3 sticky-top px-5" style="top: 20px;">
                                <h6 class="text-muted mb-0">Actions</h6>
                                <a href="{{ path('app_user_show', {'id_user': user.idUser}) }}" class="btn btn-info btn-lg py-3" style="margin: 0 3rem;">
                                    <i class="fas fa-eye me-2"></i>Voir l'utilisateur
                                </a>
                                <a href="{{ path('app_user_index') }}" class="btn btn-secondary btn-lg py-3" style="margin: 0 3rem;">
                                    <i class="fas fa-times me-2"></i>Annuler
                                </a>
                                <button type="submit" class="btn btn-warning btn-lg py-3" style="margin: 0 3rem;" form="user_edit_form">
                                    <i class="fas fa-save me-2"></i>Mettre à jour
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}