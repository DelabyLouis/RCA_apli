{% extends 'base.html.twig' %}

{% block title %}User index{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .editable-field {
            cursor: pointer;
            padding: 5px;
            border: 1px solid transparent;
            border-radius: 3px;
            transition: all 0.2s;
        }
        
        .editable-field:hover {
            background-color: #f8f9fa;
            border-color: #dee2e6;
        }
        
        .editable-field.editing {
            background-color: #fff;
            border-color: #007bff;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
        }
        
        .editable-input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            font-size: inherit;
            font-family: inherit;
            padding: 0;
            margin: 0;
        }
        
        /* Masquer les rectangles blancs indésirables */
        .editable-field input,
        .editable-field textarea,
        .editable-field select {
            border: none !important;
            outline: none !important;
            box-shadow: none !important;
            background: transparent !important;
        }
        
        .saving {
            opacity: 0.6;
            pointer-events: none;
        }
        
        .alert {
            margin: 10px 0;
            padding: 10px;
            border-radius: 4px;
        }
        
        .alert-success {
            background-color: #d4edda;
            border-color: #c3e6cb;
            color: #155724;
        }
        
        .alert-danger {
            background-color: #f8d7da;
            border-color: #f5c6cb;
            color: #721c24;
        }
        
        .password-mask {
            color: #6c757d;
            font-family: monospace;
        }
    </style>
{% endblock %}

{% block body %}
    <h1>User index</h1>
    
    {% include 'components/entity_filter.html.twig' with {
        'placeholder': 'Rechercher par nom d\'utilisateur, nom, prénom, rôle...',
        'tableSelector': '.table tbody'
    } %}
    
    <div id="message-container"></div>

    <table class="table" data-turbo="false">
        <thead>
            <tr>
                <th>Id_user</th>
                <th>Username</th>
                <th>Personne</th>
                <th>Roles</th>
                <th>Password</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr data-id="{{ user.idUser }}">
                <td>{{ user.idUser }}</td>
                <td class="editable-field" data-field="username">{{ user.username }}</td>
                <td class="editable-field" data-field="personne" data-current-value="{{ user.personne ? user.personne.idPersonne : '' }}">
                    {% if user.personne %}
                        {{ user.personne.prenom }} {{ user.personne.nom }}
                    {% else %}
                        <span class="text-muted">Aucune personne</span>
                    {% endif %}
                </td>
                <td>
                    {% if user.userRoles is not empty %}
                        {% for role in user.userRoles %}
                            <span class="badge bg-primary me-1">{{ role.libelle }}</span>
                        {% endfor %}
                    {% else %}
                        <span class="text-muted">Aucun rôle</span>
                    {% endif %}
                </td>
                <td>
                    <span class="password-mask">••••••••</span>
                </td>
                <td>
                    <button class="btn btn-danger btn-sm delete-btn" data-id="{{ user.idUser }}" title="Supprimer">
                        <i class="fas fa-trash me-1"></i> Supprimer
                    </button>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_user_new') }}">Create new</a>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Données des personnes pour les listes déroulantes
            const personnes = [
                {% for personne in personnes %}
                {
                    id: {{ personne.idPersonne }},
                    nom: "{{ personne.nom|e('js') }}",
                    prenom: "{{ personne.prenom|e('js') }}",
                    fullName: "{{ personne.prenom|e('js') }} {{ personne.nom|e('js') }}"
                }{{ not loop.last ? ',' : '' }}
                {% endfor %}
            ];
            
            let currentEditingCell = null;
            let originalValue = '';
            
            function showMessage(message, type) {
                const container = document.getElementById('message-container');
                const alert = document.createElement('div');
                alert.className = `alert alert-${type}`;
                alert.textContent = message;
                container.appendChild(alert);
                
                setTimeout(() => {
                    alert.remove();
                }, 3000);
            }
            
            function saveField(cell, field, value, userId) {
                const row = cell.closest('tr');
                row.classList.add('saving');
                
                fetch(`/user/${userId}/update-field`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `field=${encodeURIComponent(field)}&value=${encodeURIComponent(value)}`
                })
                .then(response => response.json())
                .then(data => {
                    row.classList.remove('saving');
                    
                    if (data.success) {
                        if (field === 'personne') {
                            // Mettre à jour l'affichage et la valeur courante
                            cell.dataset.currentValue = value;
                            if (value) {
                                const personne = personnes.find(p => p.id == value);
                                cell.textContent = personne ? personne.fullName : 'Aucune personne';
                            } else {
                                cell.innerHTML = '<span class="text-muted">Aucune personne</span>';
                            }
                        } else {
                            cell.textContent = value || '';
                        }
                    } else {
                        restoreOriginalContent(cell, field);
                        showMessage(data.message, 'danger');
                    }
                })
                .catch(error => {
                    row.classList.remove('saving');
                    restoreOriginalContent(cell, field);
                    showMessage('Erreur de communication avec le serveur', 'danger');
                    console.error('Error:', error);
                });
            }
            
            function startEditing(cell) {
                if (currentEditingCell && currentEditingCell !== cell) {
                    stopEditing(currentEditingCell, false);
                }
                
                currentEditingCell = cell;
                originalValue = cell.textContent;
                
                cell.classList.add('editing');
                
                const field = cell.dataset.field;
                let input;
                
                if (field === 'personne') {
                    // Créer un select pour les personnes
                    input = document.createElement('select');
                    input.className = 'editable-input';
                    
                    // Option vide
                    const emptyOption = document.createElement('option');
                    emptyOption.value = '';
                    emptyOption.textContent = 'Aucune personne';
                    input.appendChild(emptyOption);
                    
                    // Options des personnes
                    personnes.forEach(personne => {
                        const option = document.createElement('option');
                        option.value = personne.id;
                        option.textContent = personne.fullName;
                        input.appendChild(option);
                    });
                    
                    // Sélectionner la valeur actuelle
                    const currentValue = cell.dataset.currentValue;
                    if (currentValue) {
                        input.value = currentValue;
                    }
                } else {
                    // Input text normal pour les autres champs
                    input = document.createElement('input');
                    input.className = 'editable-input';
                    input.type = 'text';
                    input.value = originalValue;
                }
                
                cell.textContent = '';
                cell.appendChild(input);
                
                input.focus();
                if (input.tagName.toLowerCase() === 'input') {
                    input.select();
                }
                
                input.addEventListener('blur', function() {
                    stopEditing(cell, true);
                });
                
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        stopEditing(cell, true);
                    } else if (e.key === 'Escape') {
                        e.preventDefault();
                        stopEditing(cell, false);
                    }
                });
            }
            
            function stopEditing(cell, save) {
                if (!cell || !cell.classList.contains('editing')) return;
                
                const input = cell.querySelector('input, select');
                const newValue = input ? input.value.trim() : '';
                const field = cell.dataset.field;
                
                cell.classList.remove('editing');
                
                if (save && newValue !== (field === 'personne' ? cell.dataset.currentValue : originalValue)) {
                    const userId = cell.closest('tr').dataset.id;
                    
                    if (field === 'username' && !newValue) {
                        showMessage('Le nom d\'utilisateur ne peut pas être vide', 'danger');
                        restoreOriginalContent(cell, field);
                    } else {
                        saveField(cell, field, newValue, userId);
                    }
                } else {
                    restoreOriginalContent(cell, field);
                }
                
                currentEditingCell = null;
            }
            
            function restoreOriginalContent(cell, field) {
                if (field === 'personne') {
                    const currentValue = cell.dataset.currentValue;
                    if (currentValue) {
                        const personne = personnes.find(p => p.id == currentValue);
                        cell.textContent = personne ? personne.fullName : 'Aucune personne';
                    } else {
                        cell.innerHTML = '<span class="text-muted">Aucune personne</span>';
                    }
                } else {
                    cell.textContent = originalValue;
                }
            }
            
            // Délégation d'événements pour les cellules éditables - plus robuste  
            document.addEventListener('click', function(e) {
                const cell = e.target.closest('.editable-field');
                if (!cell) return;
                // Si on clique sur un input/select à l'intérieur, ne pas traiter le clic de la cellule
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT') {
                    return;
                }
                
                // Si la cellule est déjà en cours d'édition, ne pas relancer l'édition
                if (cell.classList.contains('editing')) {
                    return;
                }
                
                startEditing(cell);
            });
            
            document.addEventListener('click', function(e) {
                if (currentEditingCell && !currentEditingCell.contains(e.target)) {
                    stopEditing(currentEditingCell, false);
                }
            });

            // Délégation d'événements pour les boutons de suppression
            document.addEventListener('click', function(e) {
                if (!e.target.closest('.delete-btn')) return;
                
                const button = e.target.closest('.delete-btn');
                e.stopPropagation();
                
                const id = button.getAttribute('data-id');
                const row = button.closest('tr');
                
                if (confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?')) {
                    // Désactiver le bouton pendant la suppression
                    button.disabled = true;
                    button.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Suppression...';
                        
                        fetch(`/user/${id}/delete-ajax`, {
                            method: 'DELETE',
                            headers: {
                                'Content-Type': 'application/json',
                            }
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                // Supprimer la ligne du tableau avec animation
                                row.style.transition = 'opacity 0.3s';
                                row.style.opacity = '0';
                                setTimeout(() => {
                                    row.remove();
                                }, 300);
                            } else {
                                alert('Erreur lors de la suppression : ' + data.message);
                                // Restaurer le bouton
                                button.disabled = false;
                                button.innerHTML = '<i class="fas fa-trash me-1"></i> Supprimer';
                            }
                        })
                        .catch(error => {
                            console.error('Erreur:', error);
                            alert('Erreur lors de la suppression');
                            // Restaurer le bouton
                            button.disabled = false;
                            button.innerHTML = '<i class="fas fa-trash me-1"></i> Supprimer';
                    });
                }
            });
        });
    </script>
{% endblock %}
