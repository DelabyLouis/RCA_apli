{% extends 'base.html.twig' %}

{% block title %}User index{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .editable-field {
            cursor: pointer;
            padding: 5px;
            border: 1px solid transparent;
            border-radius: 3px;
            transition: all 0.2s;
        }
        
        .editable-field:hover {
            background-color: #f8f9fa;
            border-color: #dee2e6;
        }
        
        .editable-field.editing {
            background-color: #fff;
            border-color: #007bff;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
        }
        
        .editable-input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            font-size: inherit;
            font-family: inherit;
        }
        
        .saving {
            opacity: 0.6;
            pointer-events: none;
        }
        
        .alert {
            margin: 10px 0;
            padding: 10px;
            border-radius: 4px;
        }
        
        .alert-success {
            background-color: #d4edda;
            border-color: #c3e6cb;
            color: #155724;
        }
        
        .alert-danger {
            background-color: #f8d7da;
            border-color: #f5c6cb;
            color: #721c24;
        }
        
        .password-mask {
            color: #6c757d;
            font-family: monospace;
        }
    </style>
{% endblock %}

{% block body %}
    <h1>User index</h1>
    
    <div id="message-container"></div>

    <table class="table">
        <thead>
            <tr>
                <th>Id_user</th>
                <th>Username</th>
                <th>Personne</th>
                <th>Roles</th>
                <th>Password</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr data-id="{{ user.idUser }}">
                <td>{{ user.idUser }}</td>
                <td class="editable-field" data-field="username">{{ user.username }}</td>
                <td>
                    {% if user.personne %}
                        {{ user.personne.prenom }} {{ user.personne.nom }}
                    {% else %}
                        <span class="text-muted">Aucune personne</span>
                    {% endif %}
                </td>
                <td>
                    {% if user.userRoles is not empty %}
                        {% for role in user.userRoles %}
                            <span class="badge bg-primary me-1">{{ role.libelle }}</span>
                        {% endfor %}
                    {% else %}
                        <span class="text-muted">Aucun rôle</span>
                    {% endif %}
                </td>
                <td>
                    <span class="password-mask">••••••••</span>
                </td>
                <td>
                    <a href="{{ path('app_user_show', {'id_user': user.idUser}) }}">show</a>
                    <a href="{{ path('app_user_edit', {'id_user': user.idUser}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_user_new') }}">Create new</a>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            let currentEditingCell = null;
            let originalValue = '';
            
            function showMessage(message, type) {
                const container = document.getElementById('message-container');
                const alert = document.createElement('div');
                alert.className = `alert alert-${type}`;
                alert.textContent = message;
                container.appendChild(alert);
                
                setTimeout(() => {
                    alert.remove();
                }, 3000);
            }
            
            function saveField(cell, field, value, userId) {
                const row = cell.closest('tr');
                row.classList.add('saving');
                
                fetch(`/user/${userId}/update-field`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `field=${encodeURIComponent(field)}&value=${encodeURIComponent(value)}`
                })
                .then(response => response.json())
                .then(data => {
                    row.classList.remove('saving');
                    
                    if (data.success) {
                        cell.textContent = value || '';
                        showMessage(data.message, 'success');
                    } else {
                        cell.textContent = originalValue;
                        showMessage(data.message, 'danger');
                    }
                })
                .catch(error => {
                    row.classList.remove('saving');
                    cell.textContent = originalValue;
                    showMessage('Erreur de communication avec le serveur', 'danger');
                    console.error('Error:', error);
                });
            }
            
            function startEditing(cell) {
                if (currentEditingCell && currentEditingCell !== cell) {
                    stopEditing(currentEditingCell, false);
                }
                
                currentEditingCell = cell;
                originalValue = cell.textContent;
                
                cell.classList.add('editing');
                
                const input = document.createElement('input');
                input.className = 'editable-input';
                input.type = 'text';
                input.value = originalValue;
                
                cell.textContent = '';
                cell.appendChild(input);
                
                input.focus();
                input.select();
                
                input.addEventListener('blur', function() {
                    stopEditing(cell, true);
                });
                
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        stopEditing(cell, true);
                    } else if (e.key === 'Escape') {
                        e.preventDefault();
                        stopEditing(cell, false);
                    }
                });
            }
            
            function stopEditing(cell, save) {
                if (!cell || !cell.classList.contains('editing')) return;
                
                const input = cell.querySelector('input');
                const newValue = input ? input.value.trim() : '';
                
                cell.classList.remove('editing');
                
                if (save && newValue !== originalValue) {
                    const field = cell.dataset.field;
                    const userId = cell.closest('tr').dataset.id;
                    
                    if (field === 'username' && !newValue) {
                        showMessage('Le nom d\'utilisateur ne peut pas être vide', 'danger');
                        cell.textContent = originalValue;
                    } else {
                        saveField(cell, field, newValue, userId);
                    }
                } else {
                    cell.textContent = originalValue;
                }
                
                currentEditingCell = null;
            }
            
            document.querySelectorAll('.editable-field').forEach(cell => {
                cell.addEventListener('click', function() {
                    if (!this.classList.contains('editing')) {
                        startEditing(this);
                    }
                });
            });
            
            document.addEventListener('click', function(e) {
                if (currentEditingCell && !currentEditingCell.contains(e.target)) {
                    stopEditing(currentEditingCell, false);
                }
            });
        });
    </script>
{% endblock %}
