{% extends 'base.html.twig' %}

{% block title %}Gestion des Utilisateurs - RCA Application{% endblock %}

{% block body %}
    {{ include('components/inline_edit_styles.html.twig') }}
    
    <style>
        #users-table th:nth-child(1), #users-table td:nth-child(1) { width: 250px !important; max-width: 250px !important; }
        #users-table th:nth-child(2), #users-table td:nth-child(2) { width: 200px !important; max-width: 200px !important; }
        #users-table th:nth-child(3), #users-table td:nth-child(3) { width: 100px !important; max-width: 100px !important; }
        #users-table th:nth-child(4), #users-table td:nth-child(4) { width: 120px !important; max-width: 120px !important; }
        
        #users-table th:nth-child(1), #users-table td:nth-child(1),
        #users-table th:nth-child(2), #users-table td:nth-child(2),
        #users-table th:nth-child(3), #users-table td:nth-child(3),
        #users-table th:nth-child(4), #users-table td:nth-child(4) {
            overflow: hidden !important;
            text-overflow: ellipsis !important;
            white-space: nowrap !important;
        }
        
        /* Marges pour le tableau */
        .container-fluid.mt-4 {
            padding-left: 5rem !important;
            padding-right: 5rem !important;
        }
    </style>
    
    <div class="container-fluid mt-4">
        <h1 class="mb-4">Gestion des Utilisateurs</h1>
        
        <!-- Information sur la gestion des utilisateurs -->
        <div class="alert alert-info mb-4">
            <h5><i class="fas fa-info-circle me-2"></i>Gestion des comptes utilisateurs</h5>
            <p class="mb-2"><strong>Création de comptes :</strong> Les utilisateurs doivent s'inscrire eux-mêmes via le <a href="{{ path('app_register') }}" class="alert-link">formulaire d'inscription</a>.</p>
            <p class="mb-0"><strong>Attribution des rôles :</strong> Les administrateurs peuvent ensuite modifier les utilisateurs pour leur attribuer des rôles et permissions.</p>
        </div>
        
        <!-- Filtres personnalisés -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filtres</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Filtre Utilisateur -->
                    <div class="col-md-4 mb-3">
                        <label for="filter-email" class="form-label">Utilisateur/Email</label>
                        <input type="text" class="form-control" id="filter-email" placeholder="Rechercher par nom d'utilisateur ou email...">
                    </div>
                    
                    <!-- Filtre Rôle -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-role" class="form-label">Rôle</label>
                        <select class="form-select" id="filter-role">
                            <option value="">Tous les rôles</option>
                            <option value="ROLE_ADMIN">Administrateur</option>
                            <option value="ROLE_USER">Utilisateur</option>
                        </select>
                    </div>
                    
                    <!-- Filtre Statut -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-actif" class="form-label">Statut</label>
                        <select class="form-select" id="filter-actif">
                            <option value="">Tous</option>
                            <option value="true">Actif</option>
                            <option value="false">Inactif</option>
                        </select>
                    </div>
                    
                    <!-- Actions filtres -->
                    <div class="col-md-2 mb-3 d-flex align-items-end">
                        <button type="button" class="btn btn-secondary me-2" onclick="clearAllFilters()">
                            <i class="fas fa-eraser me-1"></i>Effacer
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tableau des utilisateurs -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-users-cog me-2"></i>Liste des Utilisateurs
                    <span id="total-count" class="badge bg-primary ms-2">{{ users|length }}</span>
                </h5>
                <small class="text-muted">
                    <span id="filtered-count">{{ users|length }}</span> utilisateurs affichés
                </small>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="users-table" class="table table-striped table-hover mb-0 fs-5">
                        <thead class="table-dark">
                            <tr>
                                <th class="fs-5">Utilisateur</th>
                                <th class="fs-5">Rôles</th>
                                <th class="fs-5">Statut</th>
                                <th class="text-center fs-5">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="users-table-body">
                            {% for user in users %}
                            <tr class="user-row" 
                                data-username="{{ user.username|lower }}" 
                                data-email="{{ user.personne and user.personne.email ? user.personne.email|lower : '' }}"
                                data-roles="{{ user.userRoles|map(role => role.libelle)|join(',')|lower }}"
                                data-actif="true">
                                <td class="fw-semibold">
                                    <i class="fas fa-user me-2"></i>{{ user.username }}
                                    {% if user.personne and user.personne.email %}
                                        <br><small class="text-muted">
                                            <i class="fas fa-envelope me-1"></i>{{ user.personne.email }}
                                        </small>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if user.userRoles is not empty %}
                                        {% for role in user.userRoles %}
                                            <span class="badge bg-{% if role.libelle == 'ROLE_ADMIN' %}danger{% else %}primary{% endif %} me-1">
                                                {% if role.libelle == 'ROLE_ADMIN' %}
                                                    <i class="fas fa-crown me-1"></i>Administrateur
                                                {% else %}
                                                    <i class="fas fa-user me-1"></i>Utilisateur
                                                {% endif %}
                                            </span>
                                        {% endfor %}
                                    {% else %}
                                        <span class="text-muted">Aucun rôle</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if user.enabled is defined %}
                                        {% if user.enabled %}
                                            <span class="badge bg-success">
                                                <i class="fas fa-check me-1"></i>Actif
                                            </span>
                                        {% else %}
                                            <span class="badge bg-danger">
                                                <i class="fas fa-times me-1"></i>Désactivé
                                            </span>
                                        {% endif %}
                                    {% else %}
                                        <span class="badge bg-success">
                                            <i class="fas fa-check me-1"></i>Actif
                                        </span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a href="{{ path('app_user_show', {'id_user': user.idUser}) }}" 
                                           class="btn btn-outline-primary btn-sm" 
                                           title="Voir les détails">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('app_user_edit', {'id_user': user.idUser}) }}" 
                                           class="btn btn-outline-secondary btn-sm" 
                                           title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        {% if user.enabled is defined %}
                                            {% if user.enabled %}
                                                <button type="button" 
                                                        class="btn btn-outline-warning btn-sm toggle-enabled-btn" 
                                                        data-user-id="{{ user.idUser }}"
                                                        title="Désactiver l'utilisateur">
                                                    <i class="fas fa-user-slash"></i>
                                                </button>
                                            {% else %}
                                                <button type="button" 
                                                        class="btn btn-outline-success btn-sm toggle-enabled-btn" 
                                                        data-user-id="{{ user.idUser }}"
                                                        title="Réactiver l'utilisateur">
                                                    <i class="fas fa-user-check"></i>
                                                </button>
                                            {% endif %}
                                        {% else %}
                                            <button type="button" 
                                                    class="btn btn-outline-warning btn-sm toggle-enabled-btn" 
                                                    data-user-id="{{ user.idUser }}"
                                                    title="Désactiver l'utilisateur">
                                                <i class="fas fa-user-slash"></i>
                                            </button>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% else %}
                            <tr id="no-results-row" style="display: none;">
                                <td colspan="4" class="text-center text-muted py-4">
                                    <i class="fas fa-search me-2"></i>Aucun utilisateur ne correspond aux critères de recherche.
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- JavaScript pour les filtres -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const filterEmail = document.getElementById('filter-email');
            const filterRole = document.getElementById('filter-role');
            const filterActif = document.getElementById('filter-actif');
            const tableBody = document.getElementById('users-table-body');
            const filteredCount = document.getElementById('filtered-count');
            const noResultsRow = document.getElementById('no-results-row');
            
            function applyFilters() {
                const emailValue = filterEmail.value.toLowerCase();
                const roleValue = filterRole.value;
                const actifValue = filterActif.value;
                
                const rows = document.querySelectorAll('.user-row');
                let visibleCount = 0;
                
                rows.forEach(row => {
                    const username = row.dataset.username || '';
                    const email = row.dataset.email || '';
                    const roles = row.dataset.roles || '';
                    const actif = row.dataset.actif || '';
                    
                    const matchesUser = emailValue === '' || username.includes(emailValue) || email.includes(emailValue);
                    const matchesRole = roleValue === '' || roles.includes(roleValue.toLowerCase());
                    const matchesActif = actifValue === '' || actif === actifValue;
                    
                    if (matchesUser && matchesRole && matchesActif) {
                        row.style.display = '';
                        visibleCount++;
                    } else {
                        row.style.display = 'none';
                    }
                });
                
                filteredCount.textContent = visibleCount;
                
                // Afficher "Aucun résultat" si nécessaire
                if (visibleCount === 0) {
                    noResultsRow.style.display = '';
                } else {
                    noResultsRow.style.display = 'none';
                }
            }
            
            // Ajouter les event listeners
            filterEmail.addEventListener('input', applyFilters);
            filterRole.addEventListener('change', applyFilters);
            filterActif.addEventListener('change', applyFilters);
        });
        
        function clearAllFilters() {
            document.getElementById('filter-email').value = '';
            document.getElementById('filter-role').value = '';
            document.getElementById('filter-actif').value = '';
            
            // Réappliquer les filtres (vides)
            document.querySelectorAll('.user-row').forEach(row => {
                row.style.display = '';
            });
            
            document.getElementById('filtered-count').textContent = document.querySelectorAll('.user-row').length;
            document.getElementById('no-results-row').style.display = 'none';
        }

        // Gestion de l'activation/désactivation des utilisateurs
        document.addEventListener('click', function(e) {
            if (e.target.closest('.toggle-enabled-btn')) {
                e.preventDefault();
                const btn = e.target.closest('.toggle-enabled-btn');
                const userId = btn.dataset.userId;
                
                if (confirm('Êtes-vous sûr de vouloir changer le statut de cet utilisateur ?')) {
                    fetch(`/user/${userId}/toggle-enabled`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showNotification(data.message, 'success');
                            // Recharger la page pour mettre à jour l'affichage
                            setTimeout(() => location.reload(), 1000);
                        } else {
                            showNotification(data.message || 'Erreur lors de la modification', 'error');
                        }
                    })
                    .catch(error => {
                        console.error('Erreur:', error);
                        showNotification('Erreur lors de la modification du statut', 'error');
                    });
                }
            }
        });

        // Fonction pour afficher les notifications
        function showNotification(message, type = 'info') {
            const notification = document.createElement('div');
            notification.className = `alert alert-${type === 'error' ? 'danger' : type === 'success' ? 'success' : 'info'} alert-dismissible fade show position-fixed`;
            notification.style.cssText = 'top: 20px; right: 20px; z-index: 1050; max-width: 300px;';
            notification.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            
            document.body.appendChild(notification);
            
            // Auto-remove after 5 seconds
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.remove();
                }
            }, 5000);
        }
    </script>
{% endblock %}