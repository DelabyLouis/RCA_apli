{% extends 'base.html.twig' %}

{% block title %}Attestations Fiscales - RCA Application{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3">
                    <i class="fas fa-file-invoice me-2 text-primary"></i>
                    Attestations Fiscales
                </h1>
            </div>

            <!-- Recherche rapide de personne -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-user-search me-2"></i>Recherche rapide de personne
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label for="search_donateur" class="form-label">Rechercher une personne</label>
                            <input type="text" 
                                   class="form-control" 
                                   id="search_donateur" 
                                   placeholder="Tapez le nom ou prénom d'une personne..."
                                   style="border-radius: 8px; padding: 10px; font-size: 14px;"
                                   autocomplete="off">
                            <div id="search_results" class="list-group mt-2" style="display: none; position: absolute; z-index: 1000; max-width: 500px;"></div>
                        </div>
                    </div>
                    <div class="mt-2">
                        <small class="text-muted">
                            <i class="fas fa-info-circle me-1"></i>
                            Tapez au moins 2 caractères pour démarrer la recherche. Cliquez sur un résultat pour sélectionner ses cotisations.
                        </small>
                    </div>
                </div>
            </div>

            {% if type_cotisation is null %}
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Le type de transaction "cotisation" n'existe pas. 
                    <a href="{{ path('app_type_transaction_new') }}" class="alert-link">Créez-le d'abord</a> 
                    pour pouvoir générer des attestations fiscales.
                </div>
            {% else %}
                <!-- Liste des cotisations -->
                {% if cotisations is empty %}
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        Aucune cotisation trouvée avec les filtres sélectionnés.
                    </div>
                {% else %}
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="fas fa-list me-2"></i>
                                Cotisations éligibles aux attestations fiscales
                                <span class="badge bg-primary ms-2">{{ cotisations|length }} cotisation{{ cotisations|length > 1 ? 's' : '' }}</span>
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table attestations-liste-table fs-5">
                                    <thead>
                                        <tr>
                                            <th class="fs-5">Date</th>
                                            <th class="fs-5">Personne</th>
                                            <th class="fs-5">Libellé</th>
                                            <th class="fs-5">Mode de paiement</th>
                                            <th class="fs-5">Montant</th>
                                            <th class="fs-5">Exercice</th>
                                            <th class="fs-5">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for cotisation in cotisations %}
                                            <tr>
                                                <td>{{ cotisation.dateTransaction|date('d/m/Y') }}</td>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <div class="me-2">
                                                            <i class="fas fa-user text-primary"></i>
                                                        </div>
                                                        <div>
                                                            <strong>{{ cotisation.personne.prenom }} {{ cotisation.personne.nom }}</strong>
                                                            {% if cotisation.personne.email %}
                                                                <br><small class="text-muted">{{ cotisation.personne.email }}</small>
                                                            {% endif %}
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>{{ cotisation.libelle }}</td>
                                                <td>
                                                    {% if cotisation.modeDePaiement %}
                                                        <span class="badge bg-light text-dark">
                                                            {{ cotisation.modeDePaiement.libelle }}
                                                        </span>
                                                    {% else %}
                                                        <span class="text-muted">-</span>
                                                    {% endif %}
                                                </td>
                                                <td>
                                                    <strong>{{ cotisation.montant|number_format(2, ',', ' ') }} €</strong>
                                                </td>
                                                <td>
                                                    {% if cotisation.exercice %}
                                                        <small class="text-muted">{{ cotisation.exercice.libelle }}</small>
                                                    {% else %}
                                                        <small class="text-muted">-</small>
                                                    {% endif %}
                                                </td>
                                                <td>
                                                    <a href="{{ path('app_attestation_fiscale_formulaire_date', {
                                                        'personne_id': cotisation.personne.idPersonne
                                                    }) }}?cotisations[]={{ cotisation.idTransaction }}" 
                                                       class="btn btn-sm btn-success" 
                                                       title="Choisir la date et générer l'attestation">
                                                        <i class="fas fa-calendar-alt me-1"></i>Générer PDF
                                                    </a>
                                                    <a href="{{ path('app_attestation_fiscale_personne_details', {
                                                        'personne_id': cotisation.personne.idPersonne
                                                    }) }}" 
                                                       class="btn btn-sm btn-outline-primary" 
                                                       title="Voir toutes les cotisations de cette personne">
                                                        <i class="fas fa-eye me-1"></i>Détails
                                                    </a>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endif %}
        </div>
    </div>
</div>

<!-- JavaScript pour la recherche en temps réel -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('search_donateur');
    const searchResults = document.getElementById('search_results');
    let searchTimeout;

    function performSearch() {
        const query = searchInput.value.trim();
        
        if (query.length < 2) {
            searchResults.style.display = 'none';
            return;
        }

        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
            fetch(`{{ path('app_attestation_fiscale_recherche_personne') }}?q=${encodeURIComponent(query)}`)
                .then(response => response.json())
                .then(data => {
                    displayResults(data);
                })
                .catch(error => {
                    console.error('Erreur de recherche:', error);
                    searchResults.style.display = 'none';
                });
        }, 300);
    }

    function displayResults(results) {
        searchResults.innerHTML = '';
        
        if (results.length === 0) {
            searchResults.innerHTML = '<div class="list-group-item text-muted">Aucune personne trouvée</div>';
        } else {
            results.forEach(result => {
                const item = document.createElement('a');
                item.href = `{{ path('app_attestation_fiscale_personne_details', {'personne_id': '_ID_'}) }}`
                    .replace('_ID_', result.id);
                item.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-start';
                
                item.innerHTML = `
                    <div class="d-flex w-100">
                        <div class="me-3">
                            <i class="fas fa-user text-primary"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">${result.label}</h6>
                                <span class="badge bg-primary">Personne</span>
                            </div>
                            <div class="text-muted small">
                                ${result.email ? '<i class="fas fa-envelope me-1"></i>' + result.email : ''}
                                ${result.ville ? '<i class="fas fa-map-marker-alt me-1 ms-2"></i>' + result.ville : ''}
                            </div>
                        </div>
                    </div>
                `;
                
                searchResults.appendChild(item);
            });
        }
        
        searchResults.style.display = 'block';
    }

    searchInput.addEventListener('input', performSearch);
    
    // Cacher les résultats en cliquant ailleurs
    document.addEventListener('click', function(e) {
        if (!e.target.closest('#search_donateur') && !e.target.closest('#search_results')) {
            searchResults.style.display = 'none';
        }
    });
    
    // Montrer les résultats si on clique dans le champ et qu'il y a du contenu
    searchInput.addEventListener('focus', function() {
        if (searchResults.children.length > 0) {
            searchResults.style.display = 'block';
        }
    });
});
</script>
{% endblock %}