<!DOCTYPE html>
<html>
<head>
    <title>Test Suppression Amélioré</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            min-width: 300px;
        }
    </style>
</head>
<body>
    <div class="container mt-4">
        <h1>Test Suppression avec Notifications Améliorées</h1>
        
        <!-- Zone de notifications -->
        <div id="notifications"></div>
        
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Libellé</th>
                        <th>Montant</th>
                        <th>Exercice</th>
                        <th>Statut Exercice</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for transaction in transactions %}
                    <tr data-id="{{ transaction.idTransaction }}">
                        <td>{{ transaction.idTransaction }}</td>
                        <td>{{ transaction.libelle }}</td>
                        <td>{{ transaction.montant }}€</td>
                        <td>
                            {% if transaction.exercice %}
                                {{ transaction.exercice.libelle }}
                            {% else %}
                                <em>Aucun</em>
                            {% endif %}
                        </td>
                        <td>
                            {% if transaction.exercice %}
                                {% if transaction.exercice.clos %}
                                    <span class="badge bg-danger">Clôturé</span>
                                {% else %}
                                    <span class="badge bg-success">Ouvert</span>
                                {% endif %}
                            {% else %}
                                <span class="badge bg-secondary">N/A</span>
                            {% endif %}
                        </td>
                        <td>
                            <button class="btn btn-danger btn-sm delete-btn" data-id="{{ transaction.idTransaction }}">
                                🗑️ Supprimer
                            </button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <script>
        // Fonction pour afficher une notification
        function showNotification(message, type = 'danger') {
            const notificationsContainer = document.getElementById('notifications');
            
            const notification = document.createElement('div');
            notification.className = `alert alert-${type} alert-dismissible fade show notification`;
            notification.innerHTML = `
                <strong>${type === 'success' ? '✅ Succès:' : '❌ Erreur:'}</strong> ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            
            notificationsContainer.appendChild(notification);
            
            // Supprimer automatiquement après 5 secondes
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.remove();
                }
            }, 5000);
        }

        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.delete-btn').forEach(function(button) {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    const transactionId = this.dataset.id;
                    const row = this.closest('tr');
                    
                    // Désactiver le bouton pendant l'opération
                    this.disabled = true;
                    this.innerHTML = '⏳ Suppression...';
                    
                    if (!confirm('Êtes-vous sûr de vouloir supprimer cette transaction ?')) {
                        // Réactiver le bouton si annulé
                        this.disabled = false;
                        this.innerHTML = '🗑️ Supprimer';
                        return;
                    }
                    
                    const url = '/transaction/' + transactionId + '/delete-ajax';
                    
                    console.log('🚀 Tentative de suppression:', {
                        transactionId: transactionId,
                        url: url
                    });
                    
                    fetch(url, {
                        method: 'DELETE',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'Content-Type': 'application/json'
                        }
                    })
                    .then(response => {
                        console.log('📡 Réponse reçue:', response.status, response.statusText);
                        return response.json();
                    })
                    .then(data => {
                        console.log('📋 Données reçues:', data);
                        
                        if (data.success) {
                            showNotification('Transaction supprimée avec succès !', 'success');
                            row.remove();
                        } else {
                            showNotification(data.error || 'Impossible de supprimer la transaction', 'danger');
                            // Réactiver le bouton
                            this.disabled = false;
                            this.innerHTML = '🗑️ Supprimer';
                        }
                    })
                    .catch(error => {
                        console.error('💥 Erreur:', error);
                        showNotification('Erreur de connexion ou serveur indisponible', 'danger');
                        // Réactiver le bouton
                        this.disabled = false;
                        this.innerHTML = '🗑️ Supprimer';
                    });
                });
            });
        });
    </script>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>