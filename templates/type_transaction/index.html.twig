{% extends 'base.html.twig' %}

{% block title %}Types de Transaction{% endblock %}

{% block body %}
    {{ include('components/inline_edit_styles.html.twig') }}
    
    <div class="container-fluid">
        <h1 class="mb-4">Gestion des Types de Transaction</h1>
        
        <div class="row mb-3">
            <div class="col">
                <a href="{{ path('app_type_transaction_new') }}" class="btn btn-success">
                    <i class="fas fa-plus me-2"></i>Nouveau Type
                </a>
            </div>
        </div>
        
        {{ include('components/entity_filter.html.twig', {
            'filter_id': 'type-transaction-filter',
            'placeholder': 'Rechercher par libellé, description...'
        }) }}
        
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Libellé</th>
                        <th>Description</th>
                        <th>Nb Transactions</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for type_transaction in type_transactions %}
                    <tr data-id="{{ type_transaction.idType }}">
                        <td class="editable-field" data-field="libelle">{{ type_transaction.libelle }}</td>
                        <td class="editable-field" data-field="description">{{ type_transaction.description ?: 'Aucune description' }}</td>
                        <td>
                            <span class="badge bg-info text-dark">{{ type_transaction.transactions|length }}</span>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_type_transaction_show', {'id_type': type_transaction.idType}) }}" class="btn btn-info btn-sm" title="Voir les détails">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('app_type_transaction_edit', {'id_type': type_transaction.idType}) }}" class="btn btn-warning btn-sm" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button class="btn btn-danger btn-sm delete-btn" data-id="{{ type_transaction.idType }}" title="Supprimer">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center">Aucun type de transaction trouvé</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {{ include('components/inline_editor.html.twig') }}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Configuration de l'éditeur pour les types de transaction
            const editor = new InlineEditor({
                entityName: 'type de transaction',
                entityIdField: 'idType',
                updateUrl: '/typetransaction/{id}/update-field',
                deleteUrl: '/typetransaction/{id}/delete-ajax'
            });
            
            console.log('TypeTransaction InlineEditor initialisé');
        });
    </script>
{% endblock %}