{% extends 'base.html.twig' %}

{% block title %}Types de Transaction - RCA Application{% endblock %}

{% block body %}
    <div class="container-fluid mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-primary">
                <i class="fas fa-tags me-2"></i>Types de Transaction
            </h1>
            <a href="{{ path('app_type_transaction_new') }}" class="btn btn-success btn-lg">
                <i class="fas fa-plus me-2"></i>Nouveau Type
            </a>
        </div>

        <!-- Filtres -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filtres</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Filtre Libellé -->
                    <div class="col-md-4 mb-3">
                        <label for="filter-libelle" class="form-label">Libellé du type</label>
                        <input type="text" class="form-control" id="filter-libelle" placeholder="Rechercher par libellé...">
                    </div>
                    
                    <!-- Filtre Description -->
                    <div class="col-md-6 mb-3">
                        <label for="filter-description" class="form-label">Description</label>
                        <input type="text" class="form-control" id="filter-description" placeholder="Rechercher dans la description...">
                    </div>
                    
                    <!-- Actions filtres -->
                    <div class="col-md-2 mb-3 d-flex align-items-end">
                        <button type="button" class="btn btn-secondary me-2" onclick="clearAllFilters()">
                            <i class="fas fa-eraser me-1"></i>Effacer
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tableau des types de transaction -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-list me-2"></i>Liste des Types de Transaction
                    <span id="total-count" class="badge bg-primary ms-2">{{ type_transactions|length }}</span>
                </h5>
                <small class="text-muted">
                    <span id="filtered-count">{{ type_transactions|length }}</span> types affichés
                </small>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0 fs-5">
                        <thead class="table-dark">
                            <tr>
                                <th class="fs-5">Libellé</th>
                                <th class="fs-5">Description</th>
                                <th class="fs-5">Transactions</th>
                                <th class="text-center fs-5" style="width: 120px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="types-table-body">
                            {% for type_transaction in type_transactions %}
                            <tr class="type-row" 
                                data-libelle="{{ type_transaction.libelle|lower }}" 
                                data-description="{{ type_transaction.description|default('')|lower }}">
                                <td class="fw-semibold">
                                    <span class="badge bg-success">{{ type_transaction.libelle }}</span>
                                </td>
                                <td>
                                    {% if type_transaction.description %}
                                        {{ type_transaction.description }}
                                    {% else %}
                                        <span class="text-muted">Aucune description</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="badge bg-info">
                                        <i class="fas fa-exchange-alt me-1"></i>
                                        {{ type_transaction.transactions|length }} transactions
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group" aria-label="Actions">
                                        <a href="{{ path('app_type_transaction_show', {'id_type': type_transaction.idType}) }}" 
                                           class="btn btn-outline-info btn-sm" 
                                           title="Voir les détails">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('app_type_transaction_edit', {'id_type': type_transaction.idType}) }}" 
                                           class="btn btn-outline-warning btn-sm" 
                                           title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form method="post" action="{{ path('app_type_transaction_delete', {'id_type': type_transaction.idType}) }}" 
                                              class="d-inline" 
                                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce type de transaction ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ type_transaction.idType) }}">
                                            <button type="submit" class="btn btn-outline-danger btn-sm" title="Supprimer">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% else %}
                            <tr id="no-results-row">
                                <td colspan="4" class="text-center py-4 text-muted">
                                    <i class="fas fa-inbox fa-2x mb-2"></i>
                                    <p class="mb-0">Aucun type de transaction trouvé</p>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- JavaScript pour les filtres -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const filterLibelle = document.getElementById('filter-libelle');
            const filterDescription = document.getElementById('filter-description');
            const tableBody = document.getElementById('types-table-body');
            const filteredCount = document.getElementById('filtered-count');
            const noResultsRow = document.getElementById('no-results-row');
            
            function applyFilters() {
                const libelleValue = filterLibelle.value.toLowerCase();
                const descriptionValue = filterDescription.value.toLowerCase();
                
                const rows = document.querySelectorAll('.type-row');
                let visibleCount = 0;
                
                rows.forEach(row => {
                    const libelle = row.dataset.libelle || '';
                    const description = row.dataset.description || '';
                    
                    const matchesLibelle = libelleValue === '' || libelle.includes(libelleValue);
                    const matchesDescription = descriptionValue === '' || description.includes(descriptionValue);
                    
                    if (matchesLibelle && matchesDescription) {
                        row.style.display = '';
                        visibleCount++;
                    } else {
                        row.style.display = 'none';
                    }
                });
                
                filteredCount.textContent = visibleCount;
                
                // Afficher "Aucun résultat" si nécessaire
                if (visibleCount === 0 && (filterLibelle.value || filterDescription.value)) {
                    if (noResultsRow) noResultsRow.style.display = '';
                } else {
                    if (noResultsRow) noResultsRow.style.display = 'none';
                }
            }
            
            // Ajouter les event listeners
            filterLibelle.addEventListener('input', applyFilters);
            filterDescription.addEventListener('input', applyFilters);
        });
        
        function clearAllFilters() {
            document.getElementById('filter-libelle').value = '';
            document.getElementById('filter-description').value = '';
            
            // Réappliquer les filtres (vides)
            document.querySelectorAll('.type-row').forEach(row => {
                row.style.display = '';
            });
            
            document.getElementById('filtered-count').textContent = document.querySelectorAll('.type-row').length;
            const noResultsRow = document.getElementById('no-results-row');
            if (noResultsRow) noResultsRow.style.display = 'none';
        }
    </script>
{% endblock %}