{% extends 'base.html.twig' %}

{% block title %}{{ type_transaction.libelle }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-tags me-2"></i>{{ type_transaction.libelle }}
                    </h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <tr>
                                <th class="text-muted" style="width: 20%;">Libellé :</th>
                                <td><strong>{{ type_transaction.libelle }}</strong></td>
                            </tr>
                            {% if type_transaction.description %}
                            <tr>
                                <th class="text-muted">Description :</th>
                                <td>{{ type_transaction.description }}</td>
                            </tr>
                            {% endif %}
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-light">
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_type_transaction_edit', {'id_type': type_transaction.idType}) }}" class="btn btn-warning">
                            <i class="fas fa-edit me-1"></i>Modifier
                        </a>
                        <a href="{{ path('app_type_transaction_index') }}" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}