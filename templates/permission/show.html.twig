{% extends 'base.html.twig' %}

{% block title %}{{ permission.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <h1 class="mb-4">
        <i class="fas fa-key me-2 text-info"></i>{{ permission.name }}
    </h1>

    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Détails de la permission</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">Nom :</dt>
                                <dd class="col-sm-8">{{ permission.name }}</dd>
                                
                                <dt class="col-sm-4">Route :</dt>
                                <dd class="col-sm-8"><code>{{ permission.route }}</code></dd>
                                
                                <dt class="col-sm-4">Description :</dt>
                                <dd class="col-sm-8">{{ permission.description|default('Aucune description') }}</dd>
                                
                                <dt class="col-sm-4">Accès :</dt>
                                <dd class="col-sm-8">
                                    {% if permission.publicAccess %}
                                        <span class="badge bg-success">
                                            <i class="fas fa-globe me-1"></i>Public
                                        </span>
                                    {% else %}
                                        <span class="badge bg-warning">
                                            <i class="fas fa-lock me-1"></i>Authentifié
                                        </span>
                                    {% endif %}
                                </dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <h6>Rôles ayant cette permission :</h6>
                            {% if permission.roles|length > 0 %}
                                <div class="mt-2">
                                    {% for role in permission.roles %}
                                        <span class="badge bg-primary me-2 mb-1">
                                            <i class="fas fa-user-tag me-1"></i>{{ role.libelle }}
                                        </span>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <p class="text-muted">Aucun rôle n'a encore cette permission</p>
                            {% endif %}
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <div>
                            <a href="{{ path('app_permission_index') }}" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-list me-2"></i>Liste
                            </a>
                        </div>
                        <div>
                            <a href="{{ path('app_permission_edit', {'id': permission.id}) }}" class="btn btn-warning btn-lg">
                                <i class="fas fa-edit me-2"></i>Modifier
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}