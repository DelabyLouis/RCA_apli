{% extends 'base.html.twig' %}

{% block title %}Historique des clôtures{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="fas fa-history me-2"></i>Historique des clôtures
                    </h4>
                    <a href="{{ path('app_exercice_index') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Retour aux exercices
                    </a>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h5>Exercice : <span class="text-primary">{{ exercice.libelle }}</span></h5>
                        <p class="mb-0">État actuel : 
                            {% if exercice.clos %}
                                <span class="badge bg-danger"><i class="fas fa-lock me-1"></i>Clôturé</span>
                            {% else %}
                                <span class="badge bg-success"><i class="fas fa-unlock me-1"></i>Ouvert</span>
                            {% endif %}
                        </p>
                    </div>

                    {% if historiques is empty %}
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-inbox fa-3x mb-3"></i><br>
                            Aucun historique disponible
                        </div>
                    {% else %}
                        <div class="timeline">
                            {% for historique in historiques %}
                                {% set isClotured = historique.typeAction == 'CLOTURE' %}
                                {% set iconClass = isClotured ? 'fas fa-lock' : 'fas fa-unlock' %}
                                {% set badgeClass = isClotured ? 'bg-danger' : 'bg-success' %}
                                
                                <div class="d-flex mb-3">
                                    <div class="flex-shrink-0 me-3">
                                        <span class="badge {{ badgeClass }} rounded-pill p-2">
                                            <i class="{{ iconClass }}"></i>
                                        </span>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1">
                                            {{ isClotured ? 'Clôture' : 'Déclôture' }}
                                            <small class="text-muted ms-2">{{ historique.dateAction|date('d/m/Y H:i:s') }}</small>
                                        </h6>
                                        <p class="mb-1 text-muted">
                                            Par : {{ historique.user ? historique.user.username : 'Utilisateur inconnu' }}
                                        </p>
                                        {% if historique.commentaire %}
                                            <p class="mb-0">{{ historique.commentaire }}</p>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.timeline {
    position: relative;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 15px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #dee2e6;
}
</style>
{% endblock %}