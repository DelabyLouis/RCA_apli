{% extends 'base.html.twig' %}

{% block title %}Transaction{% endblock %}

{% block body %}
    <h1>Transaction</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id_transaction</th>
                <td>{{ transaction.idTransaction }}</td>
            </tr>
            <tr>
                <th>Libelle</th>
                <td>{{ transaction.libelle }}</td>
            </tr>
            <tr>
                <th>Numero_ordre</th>
                <td>{{ transaction.numeroOrdre }}</td>
            </tr>
            <tr>
                <th>Date_transaction</th>
                <td>{{ transaction.dateTransaction ? transaction.dateTransaction|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Montant</th>
                <td>{{ transaction.montant }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_transaction_index') }}">back to list</a>

    <a href="{{ path('app_transaction_edit', {'id_transaction': transaction.id_transaction}) }}">edit</a>

    {{ include('transaction/_delete_form.html.twig') }}
{% endblock %}
