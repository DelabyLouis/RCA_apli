{% extends 'base.html.twig' %}

{% block title %}Modifier transaction{% endblock %}

{% block body %}
<div class="container-fluid">
    <h1 class="mb-4">
        <i class="fas fa-edit me-2 text-warning"></i>Modifier la transaction
    </h1>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Modifier les informations de la transaction</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                    
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.numero_ordre, 'Numéro d\'ordre') }}
                                {{ form_widget(form.numero_ordre, {'attr': {'class': 'form-control', 'type': 'number'}}) }}
                                {{ form_errors(form.numero_ordre) }}
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="mb-3">
                                {{ form_label(form.libelle, 'Libelle') }}
                                {{ form_widget(form.libelle, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.libelle) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.montant, 'Montant') }}
                                <div class="input-group">
                                    {{ form_widget(form.montant, {'attr': {'class': 'form-control', 'id': 'montant', 'step': '0.01'}}) }}
                                    <span class="input-group-text">€</span>
                                </div>
                                {{ form_errors(form.montant) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.date_transaction, 'Date de transaction') }}
                                {{ form_widget(form.date_transaction, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.date_transaction) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.exercice, 'Exercice') }}
                                {{ form_widget(form.exercice, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.exercice) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.type_transaction, 'Type de transaction') }}
                                {{ form_widget(form.type_transaction, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.type_transaction) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.personne, 'Personne') }}
                                {{ form_widget(form.personne, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.personne) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.entreprise, 'Entreprise') }}
                                {{ form_widget(form.entreprise, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.entreprise) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.modeDePaiement, 'Mode de paiement') }}
                                {{ form_widget(form.modeDePaiement, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.modeDePaiement) }}
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <div>
                            <a href="{{ path('app_transaction_show', {'id_transaction': transaction.idTransaction}) }}" class="btn btn-secondary btn-lg me-2">
                                <i class="fas fa-eye me-2"></i>Voir
                            </a>
                            <a href="{{ path('app_transaction_index') }}" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-list me-2"></i>Liste
                            </a>
                        </div>
                        <div>
                            <button type="submit" class="btn btn-warning btn-lg">
                                <i class="fas fa-save me-2"></i>Modifier la transaction
                            </button>
                        </div>
                    </div>

                    {{ form_rest(form) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}