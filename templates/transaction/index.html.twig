{% extends 'base.html.twig' %}

{% block title %}Transactions{% endblock %}

{% block body %}
    {{ include('components/inline_edit_styles.html.twig') }}
    
    <div class="container-fluid mt-4">
        <h1 class="mb-4">Gestion des Transactions</h1>
        
        {% if exercice_filter %}
            <div class="alert alert-info">
                <i class="fas fa-filter me-2"></i>Transactions filtrées pour l'exercice : 
                <strong>{{ exercice_filter.libelle }}</strong>
                <a href="{{ path('app_transaction_index') }}" class="btn btn-outline-secondary btn-sm ms-3">
                    <i class="fas fa-times me-1"></i>Voir toutes les transactions
                </a>
            </div>
        {% endif %}
        
        <div class="row mb-3">
            <div class="col">
                <a href="{{ path('app_transaction_new') }}" class="btn btn-success">
                    <i class="fas fa-plus me-2"></i>Nouvelle Transaction
                </a>
            </div>
        </div>
        
        <!-- Filtres personnalisés -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filtres</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Filtre Libellé -->
                    <div class="col-md-2 mb-3">
                        <label for="filter-libelle" class="form-label">Libellé</label>
                        <input type="text" class="form-control" id="filter-libelle" placeholder="Rechercher par libellé...">
                    </div>
                    
                    <!-- Filtre Tiers avec cases à cocher -->
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Tiers</label>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" id="filter-tiers-dropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <span id="selected-tiers-text">Sélectionner des tiers...</span>
                            </button>
                            <div class="dropdown-menu p-3" style="min-width: 300px;" aria-labelledby="filter-tiers-dropdown">
                                <div class="mb-2">
                                    <strong>Personnes</strong>
                                </div>
                                {% for personne in personnes %}
                                <div class="form-check">
                                    <input class="form-check-input tiers-checkbox" type="checkbox" 
                                           value="personne_{{ personne.idPersonne }}" 
                                           id="tiers-personne-{{ personne.idPersonne }}">
                                    <label class="form-check-label" for="tiers-personne-{{ personne.idPersonne }}">
                                        {{ personne.prenom }} {{ personne.nom }}
                                    </label>
                                </div>
                                {% endfor %}
                                
                                <hr class="my-2">
                                
                                <div class="mb-2">
                                    <strong>Entreprises</strong>
                                </div>
                                {% for entreprise in entreprises %}
                                <div class="form-check">
                                    <input class="form-check-input tiers-checkbox" type="checkbox" 
                                           value="entreprise_{{ entreprise.idEntreprise }}" 
                                           id="tiers-entreprise-{{ entreprise.idEntreprise }}">
                                    <label class="form-check-label" for="tiers-entreprise-{{ entreprise.idEntreprise }}">
                                        {{ entreprise.nomEntreprise }}
                                    </label>
                                </div>
                                {% endfor %}
                                
                                <hr class="my-2">
                                
                                <div class="d-flex justify-content-between">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="clear-tiers-selection">
                                        Tout décocher
                                    </button>
                                    <button type="button" class="btn btn-sm btn-primary" id="apply-tiers-filter">
                                        Appliquer
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Filtre Débit/Crédit -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-type-montant" class="form-label"><i class="fas fa-exchange-alt me-1"></i>Type de montant</label>
                        <div class="input-group">
                            <select class="form-select" id="filter-type-montant" style="max-width: 160px;">
                                <option value="">Tous</option>
                                <option value="debit">🟢 Débit uniquement</option>
                                <option value="credit">🔴 Crédit uniquement</option>
                            </select>
                            <input type="number" class="form-control" id="filter-montant-min" placeholder="Min" step="0.01" style="max-width: 100px;">
                            <input type="number" class="form-control" id="filter-montant-max" placeholder="Max" step="0.01" style="max-width: 100px;">
                        </div>
                        <small class="text-muted">Filtre combiné : type + montant min/max</small>
                    </div>
                    
                    <!-- Filtre Date -->
                    <div class="col-md-4 mb-3">
                        <label for="filter-date" class="form-label">Date de transaction</label>
                        <div class="input-group">
                            <input type="date" class="form-control" id="filter-date-min" placeholder="Date min">
                            <input type="date" class="form-control" id="filter-date-max" placeholder="Date max">
                        </div>
                        <small class="text-muted">Période : date min/max</small>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-12">
                        <button type="button" class="btn btn-primary me-2" id="apply-filters">
                            <i class="fas fa-search me-1"></i>Filtrer
                        </button>
                        <button type="button" class="btn btn-outline-secondary" id="clear-filters">
                            <i class="fas fa-times me-1"></i>Effacer les filtres
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Libellé</th>
                        <th>N° Ordre</th>
                        <th>Date</th>
                        <th>Tiers</th>
                        <th>Débit</th>
                        <th>Crédit</th>
                        <th>Montant</th>
                        <th>Mode de paiement</th>
                        <th>Exercice</th>
                        <th>Type</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% if exercice_precedent_existe %}
                    <tr class="table-secondary">
                        <td colspan="8" class="text-muted fst-italic">
                            <i class="fas fa-level-up-alt me-2"></i>Solde de l'exercice précédent
                        </td>
                        <td class="text-end">
                            {% if solde_precedent >= 0 %}
                                <span class="text-success fw-bold">{{ solde_precedent|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-danger fw-bold">{{ solde_precedent|number_format(2, ',', ' ') }} €</span>
                            {% endif %}
                        </td>
                        <td colspan="3"></td>
                    </tr>
                {% endif %}
                {% for item in transactions_avec_montant %}
                    {% set transaction = item.transaction %}
                    {% set montant_cumule = item.montant_cumule %}
                    {% set is_exercice_clos = transaction.exercice and transaction.exercice.isClos %}
                    <tr data-id="{{ transaction.idTransaction }}">
                        <td>{{ transaction.idTransaction }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="libelle" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.libelleComplet }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="numero_ordre" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.numeroOrdre }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="date_transaction" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.dateTransaction ? transaction.dateTransaction|date('Y-m-d') : '' }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="tiers" data-current-personne="{{ transaction.personne ? transaction.personne.idPersonne : '' }}" data-current-entreprise="{{ transaction.entreprise ? transaction.entreprise.idEntreprise : '' }}" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>
                            {% if transaction.personne %}
                                <span class="badge bg-info">
                                    <i class="fas fa-user"></i> {{ transaction.personne.prenom }} {{ transaction.personne.nom }}
                                </span>
                            {% elseif transaction.entreprise %}
                                <span class="badge bg-warning">
                                    <i class="fas fa-building"></i> {{ transaction.entreprise.nomEntreprise }}
                                </span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        {% set display_montant = item.montant_compte_courant is defined ? item.montant_compte_courant : transaction.montant %}
                        <td class="montant-cell {% if not is_exercice_clos %}editable-field{% endif %} text-end" 
                            data-field="montant" 
                            data-type="debit" 
                            data-current-value="{{ transaction.montant }}"
                            {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>
                            {% if display_montant >= 0 %}
                                <span class="badge bg-success fs-6 fw-bold">{{ display_montant|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="montant-cell {% if not is_exercice_clos %}editable-field{% endif %} text-end" 
                            data-field="montant" 
                            data-type="credit" 
                            data-current-value="{{ transaction.montant }}"
                            {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>
                            {% if display_montant < 0 %}
                                <span class="badge bg-danger fs-6 fw-bold">{{ (display_montant * -1)|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="solde-cell text-end" {% if montant_cumule < 0 %}style="border: 3px solid #dc3545 !important; background-color: rgba(220, 53, 69, 0.1) !important;"{% endif %}>
                            {% if montant_cumule >= 0 %}
                                <span class="text-success fw-bold">{{ montant_cumule|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="fw-bold" style="color: #dc3545 !important;">
                                    <i class="fas fa-exclamation-triangle me-1" style="color: #dc3545 !important;"></i>{{ montant_cumule|number_format(2, ',', ' ') }} €
                                </span>
                            {% endif %}
                        </td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="mode_de_paiement" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.modeDePaiement ? transaction.modeDePaiement.libelle : '' }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="exercice" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.exercice ? transaction.exercice.libelle : '' }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="type_transaction" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.typeTransaction ? transaction.typeTransaction.libelle : '' }}</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_transaction_show', {'id_transaction': transaction.idTransaction}) }}" class="btn btn-info btn-sm" title="Voir les détails">
                                    <i class="fas fa-eye"></i>
                                </a>
                                {% if transaction.exercice and transaction.exercice.isClos %}
                                    <button class="btn btn-warning btn-sm" disabled title="Exercice clôturé - Modification impossible">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-danger btn-sm" disabled title="Exercice clôturé - Suppression impossible">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                {% else %}
                                    <a href="{{ path('app_transaction_edit', {'id_transaction': transaction.idTransaction}) }}" class="btn btn-warning btn-sm" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn btn-danger btn-sm delete-btn" data-id="{{ transaction.idTransaction }}" title="Supprimer">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="12" class="text-center">Aucune transaction trouvée</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Initialisation édition inline pour transactions (page principale)');
            
            // Gestion de l'édition inline simple
            document.querySelectorAll('.editable-field').forEach(function(element) {
                element.addEventListener('click', function() {
                    if (this.querySelector('input') || this.querySelector('select')) {
                        return;
                    }
                    
                    const field = this.dataset.field;
                    const currentValue = this.textContent.trim();
                    const transactionId = this.closest('tr').dataset.id;
                    
                    console.log('Édition de:', field, 'pour transaction:', transactionId);
                    
                    if (field === 'date_transaction') {
                        let isoValue = '';
                        if (currentValue && currentValue !== '') {
                            const parts = currentValue.split('/');
                            if (parts.length === 3) {
                                isoValue = parts[2] + '-' + parts[1].padStart(2, '0') + '-' + parts[0].padStart(2, '0');
                            }
                        }
                        
                        this.innerHTML = '<input type="date" class="form-control form-control-sm" value="' + isoValue + '" style="min-width: 150px;">';
                    } else if (field === 'exercice') {
                        let selectHtml = '<select class="form-control form-control-sm" style="min-width: 150px;">';
                        selectHtml += '<option value="">Aucun exercice</option>';
                        {% for exercice in exercices %}
                        selectHtml += '<option value="{{ exercice.idExercice }}">{{ exercice.libelle }}</option>';
                        {% endfor %}
                        selectHtml += '</select>';
                        this.innerHTML = selectHtml;
                        // Sélectionner la valeur actuelle
                        const select = this.querySelector('select');
                        const row = this.closest('tr');
                        const currentExerciceText = currentValue;
                        for (let option of select.options) {
                            if (option.text === currentExerciceText) {
                                option.selected = true;
                                break;
                            }
                        }
                    } else if (field === 'type_transaction') {
                        let selectHtml = '<select class="form-control form-control-sm" style="min-width: 150px;">';
                        selectHtml += '<option value="">Aucun type</option>';
                        {% for type in types_transaction %}
                        selectHtml += '<option value="{{ type.idType }}">{{ type.libelle }}</option>';
                        {% endfor %}
                        selectHtml += '</select>';
                        this.innerHTML = selectHtml;
                        // Sélectionner la valeur actuelle
                        const select2 = this.querySelector('select');
                        const currentTypeText = currentValue;
                        for (let option of select2.options) {
                            if (option.text === currentTypeText) {
                                option.selected = true;
                                break;
                            }
                        }
                    } else if (field === 'mode_de_paiement') {
                        let selectHtml = '<select class="form-control form-control-sm" style="min-width: 150px;">';
                        selectHtml += '<option value="">Aucun mode de paiement</option>';
                        {% for mode in modes_de_paiement %}
                        selectHtml += '<option value="{{ mode.id }}">{{ mode.libelle }}</option>';
                        {% endfor %}
                        selectHtml += '</select>';
                        this.innerHTML = selectHtml;
                        // Sélectionner la valeur actuelle
                        const select3 = this.querySelector('select');
                        const currentModeText = currentValue;
                        for (let option of select3.options) {
                            if (option.text === currentModeText) {
                                option.selected = true;
                                break;
                            }
                        }
                    } else {
                        this.innerHTML = '<input type="text" class="form-control form-control-sm" value="' + currentValue + '" style="min-width: 150px;">';
                    }
                    
                    const input = this.querySelector('input, select');
                    if (input) {
                        input.focus();
                        if (input.type !== 'date' && input.tagName === 'INPUT') {
                            input.select();
                        }
                        
                        // Sauvegarder au blur ou Entrée
                        function saveChanges() {
                            const newValue = input.value;
                            if (newValue !== currentValue) {
                                console.log('Sauvegarde:', field, '=', newValue);
                                
                                // Préparer les données
                                const formData = new FormData();
                                formData.append('field', field);
                                formData.append('value', newValue);
                                
                                // URL sans exercice_id pour la page principale
                                const url = '/transaction/' + transactionId + '/update-field';
                                
                                fetch(url, {
                                    method: 'POST',
                                    body: formData,
                                    headers: {
                                        'X-Requested-With': 'XMLHttpRequest'
                                    }
                                })
                                .then(response => response.json())
                                .then(data => {
                                    if (data.success) {
                                        element.textContent = data.display_value || newValue;
                                        element.classList.add('text-success');
                                        setTimeout(() => element.classList.remove('text-success'), 1000);
                                    } else {
                                        alert('Erreur: ' + (data.error || 'Impossible de sauvegarder'));
                                        element.textContent = currentValue;
                                    }
                                })
                                .catch(error => {
                                    console.error('Erreur:', error);
                                    element.textContent = currentValue;
                                });
                            } else {
                                element.textContent = currentValue;
                            }
                        }
                        
                        input.addEventListener('blur', saveChanges);
                        input.addEventListener('keydown', function(e) {
                            if (e.key === 'Enter') {
                                e.preventDefault();
                                saveChanges();
                            } else if (e.key === 'Escape') {
                                element.textContent = currentValue;
                            }
                        });
                    }
                });
            });
            
            // Gestion de la suppression
            document.querySelectorAll('.delete-btn').forEach(function(button) {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    if (!confirm('Êtes-vous sûr de vouloir supprimer cette transaction ?')) {
                        return;
                    }
                    
                    const transactionId = this.dataset.id;
                    const row = this.closest('tr');
                    
                    const url = '/transaction/' + transactionId + '/delete-ajax';
                    
                    fetch(url, {
                        method: 'DELETE',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            row.remove();
                            // Réafficher "Aucune transaction" si plus de lignes
                            const tbody = document.querySelector('tbody');
                            if (tbody.children.length === 0) {
                                location.reload(); // Recharger pour afficher le message "aucune transaction"
                            }
                        } else {
                            alert('Erreur: ' + (data.error || 'Impossible de supprimer'));
                        }
                    })
                    .catch(error => {
                        console.error('Erreur:', error);
                        alert('Erreur de connexion');
                    });
                });
            });
        });
    </script>
{% endblock %}
