{% extends 'base.html.twig' %}

{% block title %}Transaction index{% endblock %}

{% block body %}
    <h1>Transaction index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id_transaction</th>
                <th>Libelle</th>
                <th>Numero_ordre</th>
                <th>Date_transaction</th>
                <th>Montant</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for transaction in transactions %}
            <tr>
                <td>{{ transaction.idTransaction }}</td>
                <td>{{ transaction.libelle }}</td>
                <td>{{ transaction.numeroOrdre }}</td>
                <td>{{ transaction.dateTransaction ? transaction.dateTransaction|date('Y-m-d') : '' }}</td>
                <td>{{ transaction.montant }}</td>
                <td>
                    <a href="{{ path('app_transaction_show', {'id_transaction': transaction.idTransaction}) }}">show</a>
                    <a href="{{ path('app_transaction_edit', {'id_transaction': transaction.idTransaction}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_transaction_new') }}">Create new</a>
{% endblock %}
