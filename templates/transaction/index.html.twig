{% extends 'base.html.twig' %}

{% block title %}Transactions{% endblock %}

{% block body %}
    {{ include('components/inline_edit_styles.html.twig') }}
    
    <div class="container-fluid mt-4">
        <h1 class="mb-4">Gestion des Transactions</h1>
        
        {% if exercice_filter %}
            <div class="alert alert-info">
                <i class="fas fa-filter me-2"></i>Transactions filtrées pour l'exercice : 
                <strong>{{ exercice_filter.libelle }}</strong>
                <a href="{{ path('app_transaction_index') }}" class="btn btn-outline-secondary btn-sm ms-3">
                    <i class="fas fa-times me-1"></i>Voir toutes les transactions
                </a>
            </div>
        {% endif %}
        
        <div class="row mb-3">
            <div class="col">
                <a href="{{ path('app_transaction_new') }}" class="btn btn-success">
                    <i class="fas fa-plus me-2"></i>Nouvelle Transaction
                </a>
            </div>
        </div>
        
        {{ include('components/entity_filter_detailed.html.twig', {
            'filters': [
                {
                    'field': 'libelle',
                    'label': 'Libellé',
                    'type': 'text',
                    'placeholder': 'Rechercher par libellé...',
                    'width': 3
                },
                {
                    'field': 'tiers',
                    'label': 'Tiers',
                    'type': 'text',
                    'placeholder': 'Rechercher par tiers...',
                    'width': 3
                },
                {
                    'field': 'montant',
                    'label': 'Montant',
                    'type': 'number_with_type',
                    'width': 3,
                    'debit_column': 5,
                    'credit_column': 6
                },
                {
                    'field': 'date_creation',
                    'label': 'Date de création',
                    'type': 'date',
                    'width': 3
                }
            ]
        }) }}
        
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Libellé</th>
                        <th>N° Ordre</th>
                        <th>Date</th>
                        <th>Tiers</th>
                        <th>Débit</th>
                        <th>Crédit</th>
                        <th>Montant</th>
                        <th>Exercice</th>
                        <th>Type</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% if exercice_precedent_existe %}
                    <tr class="table-secondary">
                        <td colspan="7" class="text-muted fst-italic">
                            <i class="fas fa-level-up-alt me-2"></i>Solde de l'exercice précédent
                        </td>
                        <td class="text-end">
                            {% if solde_precedent >= 0 %}
                                <span class="text-success fw-bold">{{ solde_precedent|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-danger fw-bold">{{ solde_precedent|number_format(2, ',', ' ') }} €</span>
                            {% endif %}
                        </td>
                        <td colspan="3"></td>
                    </tr>
                {% endif %}
                {% for item in transactions_avec_montant %}
                    {% set transaction = item.transaction %}
                    {% set montant_cumule = item.montant_cumule %}
                    <tr data-id="{{ transaction.idTransaction }}">
                        <td>{{ transaction.idTransaction }}</td>
                        <td class="editable-field" data-field="libelle">{{ transaction.libelle }}</td>
                        <td class="editable-field" data-field="numero_ordre">{{ transaction.numeroOrdre }}</td>
                        <td class="editable-field" data-field="date_transaction">{{ transaction.dateTransaction ? transaction.dateTransaction|date('Y-m-d') : '' }}</td>
                        <td class="editable-field" data-field="tiers" data-current-personne="{{ transaction.personne ? transaction.personne.idPersonne : '' }}" data-current-entreprise="{{ transaction.entreprise ? transaction.entreprise.idEntreprise : '' }}">
                            {% if transaction.personne %}
                                <span class="badge bg-info">
                                    <i class="fas fa-user"></i> {{ transaction.personne.prenom }} {{ transaction.personne.nom }}
                                </span>
                            {% elseif transaction.entreprise %}
                                <span class="badge bg-warning">
                                    <i class="fas fa-building"></i> {{ transaction.entreprise.nomEntreprise }}
                                </span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="montant-cell editable-field text-end" 
                            data-field="montant" 
                            data-type="debit" 
                            data-current-value="{{ transaction.montant }}">
                            {% if transaction.montant >= 0 %}
                                <span class="badge bg-success fs-6 fw-bold">{{ transaction.montant|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="montant-cell editable-field text-end" 
                            data-field="montant" 
                            data-type="credit" 
                            data-current-value="{{ transaction.montant }}">
                            {% if transaction.montant < 0 %}
                                <span class="badge bg-danger fs-6 fw-bold">{{ (transaction.montant * -1)|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="solde-cell text-end" {% if montant_cumule < 0 %}style="border: 3px solid #dc3545 !important; background-color: rgba(220, 53, 69, 0.1) !important;"{% endif %}>
                            {% if montant_cumule >= 0 %}
                                <span class="text-success fw-bold">{{ montant_cumule|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="fw-bold" style="color: #dc3545 !important;">
                                    <i class="fas fa-exclamation-triangle me-1" style="color: #dc3545 !important;"></i>{{ montant_cumule|number_format(2, ',', ' ') }} €
                                </span>
                            {% endif %}
                        </td>
                        <td class="editable-field" data-field="exercice">{{ transaction.exercice ? transaction.exercice.libelle : '' }}</td>
                        <td class="editable-field" data-field="type_transaction">{{ transaction.typeTransaction ? transaction.typeTransaction.libelle : '' }}</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_transaction_show', {'id_transaction': transaction.idTransaction}) }}" class="btn btn-info btn-sm" title="Voir les détails">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('app_transaction_edit', {'id_transaction': transaction.idTransaction}) }}" class="btn btn-warning btn-sm" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button class="btn btn-danger btn-sm delete-btn" data-id="{{ transaction.idTransaction }}" title="Supprimer">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="11" class="text-center">Aucune transaction trouvée</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {{ include('components/inline_editor.html.twig') }}
    {{ include('components/montant_editor.html.twig') }}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Données pour les champs spéciaux
            const personnes = [
                {% for personne in personnes %}
                {
                    id: {{ personne.idPersonne }},
                    nom: "{{ personne.nom|e('js') }}",
                    prenom: "{{ personne.prenom|e('js') }}",
                    fullName: "{{ personne.prenom|e('js') }} {{ personne.nom|e('js') }}"
                }{{ not loop.last ? ',' : '' }}
                {% endfor %}
            ];
            
            const entreprises = [
                {% for entreprise in entreprises %}
                {
                    id: {{ entreprise.idEntreprise }},
                    nom: "{{ entreprise.nomEntreprise|e('js') }}"
                }{{ not loop.last ? ',' : '' }}
                {% endfor %}
            ];
            
            const exercices = [
                {% for exercice in exercices %}
                {
                    id: {{ exercice.idExercice }},
                    libelle: "{{ exercice.libelle|e('js') }}"
                }{{ not loop.last ? ',' : '' }}
                {% endfor %}
            ];
            
            const typesTransaction = [
                {% for type in types_transaction %}
                {
                    id: {{ type.idType }},
                    libelle: "{{ type.libelle|e('js') }}"
                }{{ not loop.last ? ',' : '' }}
                {% endfor %}
            ];
            
            // Configuration de l'éditeur pour les transactions avec gestion avancée des montants
            const editor = new MontantEditor({
                entityName: 'transaction',
                entityIdField: 'idTransaction',
                updateUrl: '/transaction/{id}/update-field',
                deleteUrl: '/transaction/{id}/delete-ajax',
                specialFields: {
                    tiers: {
                        type: 'select',
                        options: [
                            { value: '', text: 'Aucun tiers' },
                            ...personnes.map(p => ({ 
                                value: `personne_${p.id}`, 
                                text: `👤 ${p.fullName}` 
                            })),
                            ...entreprises.map(e => ({ 
                                value: `entreprise_${e.id}`, 
                                text: `🏢 ${e.nom}` 
                            }))
                        ]
                    },
                    exercice: {
                        type: 'select',
                        options: [
                            { value: '', text: 'Sélectionner un exercice' },
                            ...exercices.map(ex => ({ 
                                value: ex.id, 
                                text: ex.libelle 
                            }))
                        ]
                    },
                    type_transaction: {
                        type: 'select',
                        options: [
                            { value: '', text: 'Sélectionner un type' },
                            ...typesTransaction.map(type => ({ 
                                value: type.id, 
                                text: type.libelle 
                            }))
                        ]
                    }
                },
                soldeCalculationCallback: function() {
                    // Recalculer tous les soldes après modification d'un montant
                    const rows = document.querySelectorAll('tbody tr[data-id]');
                    let cumulativeSolde = 0;
                    
                    rows.forEach(row => {
                        const debitCell = row.querySelector('[data-type="debit"]');
                        if (debitCell) {
                            const montant = parseFloat(debitCell.dataset.currentValue) || 0;
                            cumulativeSolde += montant;
                            
                            const soldeCell = row.querySelector('.solde-cell');
                            if (soldeCell) {
                                const colorClass = cumulativeSolde >= 0 ? 'text-success' : 'text-danger';
                                const formattedSolde = new Intl.NumberFormat('fr-FR', {
                                    style: 'currency',
                                    currency: 'EUR'
                                }).format(cumulativeSolde);
                                soldeCell.innerHTML = `<span class="${colorClass} fw-bold">${formattedSolde}</span>`;
                            }
                        }
                    });
                }
            });
            
            console.log('Transaction MontantEditor initialisé avec gestion débit/crédit');
        });
    </script>
{% endblock %}