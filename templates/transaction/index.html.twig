{% extends 'base.html.twig' %}

{% block title %}Transactions{% endblock %}

{% block body %}
    {{ include('components/inline_edit_styles.html.twig') }}
    
    <div class="container-fluid mt-4">
        <h1 class="mb-4">Gestion des Transactions</h1>
        
        {% if exercice_filter %}
            <div class="alert alert-info">
                <i class="fas fa-filter me-2"></i>Transactions filtrées pour l'exercice : 
                <strong>{{ exercice_filter.libelle }}</strong>
                <a href="{{ path('app_transaction_index') }}" class="btn btn-outline-secondary btn-sm ms-3">
                    <i class="fas fa-times me-1"></i>Voir toutes les transactions
                </a>
            </div>
        {% endif %}
        
        <div class="row mb-3">
            <div class="col">
                <a href="{{ path('app_transaction_new') }}" class="btn btn-success">
                    <i class="fas fa-plus me-2"></i>Nouvelle Transaction
                </a>
            </div>
        </div>
        
        <!-- Filtres personnalisés -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filtres</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Filtre Libellé -->
                    <div class="col-md-2 mb-3">
                        <label for="filter-libelle" class="form-label">Libellé</label>
                        <input type="text" class="form-control" id="filter-libelle" placeholder="Rechercher par libellé...">
                    </div>
                    
                    <!-- Filtre Tiers avec cases à cocher -->
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Tiers</label>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" id="filter-tiers-dropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <span id="selected-tiers-text">Sélectionner des tiers...</span>
                            </button>
                            <div class="dropdown-menu p-3" style="min-width: 300px;" aria-labelledby="filter-tiers-dropdown">
                                <div class="mb-2">
                                    <strong>Personnes</strong>
                                </div>
                                {% for personne in personnes %}
                                <div class="form-check">
                                    <input class="form-check-input tiers-checkbox" type="checkbox" 
                                           value="personne_{{ personne.idPersonne }}" 
                                           id="tiers-personne-{{ personne.idPersonne }}">
                                    <label class="form-check-label" for="tiers-personne-{{ personne.idPersonne }}">
                                        {{ personne.prenom }} {{ personne.nom }}
                                    </label>
                                </div>
                                {% endfor %}
                                
                                <hr class="my-2">
                                
                                <div class="mb-2">
                                    <strong>Entreprises</strong>
                                </div>
                                {% for entreprise in entreprises %}
                                <div class="form-check">
                                    <input class="form-check-input tiers-checkbox" type="checkbox" 
                                           value="entreprise_{{ entreprise.idEntreprise }}" 
                                           id="tiers-entreprise-{{ entreprise.idEntreprise }}">
                                    <label class="form-check-label" for="tiers-entreprise-{{ entreprise.idEntreprise }}">
                                        {{ entreprise.nomEntreprise }}
                                    </label>
                                </div>
                                {% endfor %}
                                
                                <hr class="my-2">
                                
                                <div class="d-flex justify-content-between">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="clear-tiers-selection">
                                        Tout décocher
                                    </button>
                                    <button type="button" class="btn btn-sm btn-primary" id="apply-tiers-filter">
                                        Appliquer
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Filtre Débit/Crédit -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-type-montant" class="form-label"><i class="fas fa-exchange-alt me-1"></i>Type de montant</label>
                        <div class="input-group">
                            <select class="form-select" id="filter-type-montant" style="max-width: 160px;">
                                <option value="">Tous</option>
                                <option value="debit">🟢 Débit uniquement</option>
                                <option value="credit">🔴 Crédit uniquement</option>
                            </select>
                            <input type="number" class="form-control" id="filter-montant-min" placeholder="Min" step="0.01" style="max-width: 100px;">
                            <input type="number" class="form-control" id="filter-montant-max" placeholder="Max" step="0.01" style="max-width: 100px;">
                        </div>
                        <small class="text-muted">Filtre combiné : type + montant min/max</small>
                    </div>
                    
                    <!-- Filtre Date -->
                    <div class="col-md-4 mb-3">
                        <label for="filter-date" class="form-label">Date de transaction</label>
                        <div class="input-group">
                            <input type="date" class="form-control" id="filter-date-min" placeholder="Date min">
                            <input type="date" class="form-control" id="filter-date-max" placeholder="Date max">
                        </div>
                        <small class="text-muted">Période : date min/max</small>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-12">
                        <button type="button" class="btn btn-primary me-2" id="apply-filters">
                            <i class="fas fa-search me-1"></i>Filtrer
                        </button>
                        <button type="button" class="btn btn-outline-secondary" id="clear-filters">
                            <i class="fas fa-times me-1"></i>Effacer les filtres
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Libellé</th>
                        <th>N° Ordre</th>
                        <th>Date</th>
                        <th>Tiers</th>
                        <th>Débit</th>
                        <th>Crédit</th>
                        <th>Montant</th>
                        <th>Exercice</th>
                        <th>Type</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% if exercice_precedent_existe %}
                    <tr class="table-secondary">
                        <td colspan="7" class="text-muted fst-italic">
                            <i class="fas fa-level-up-alt me-2"></i>Solde de l'exercice précédent
                        </td>
                        <td class="text-end">
                            {% if solde_precedent >= 0 %}
                                <span class="text-success fw-bold">{{ solde_precedent|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-danger fw-bold">{{ solde_precedent|number_format(2, ',', ' ') }} €</span>
                            {% endif %}
                        </td>
                        <td colspan="3"></td>
                    </tr>
                {% endif %}
                {% for item in transactions_avec_montant %}
                    {% set transaction = item.transaction %}
                    {% set montant_cumule = item.montant_cumule %}
                    <tr data-id="{{ transaction.idTransaction }}">
                        <td>{{ transaction.idTransaction }}</td>
                        <td class="editable-field" data-field="libelle">{{ transaction.libelle }}</td>
                        <td class="editable-field" data-field="numero_ordre">{{ transaction.numeroOrdre }}</td>
                        <td class="editable-field" data-field="date_transaction">{{ transaction.dateTransaction ? transaction.dateTransaction|date('Y-m-d') : '' }}</td>
                        <td class="editable-field" data-field="tiers" data-current-personne="{{ transaction.personne ? transaction.personne.idPersonne : '' }}" data-current-entreprise="{{ transaction.entreprise ? transaction.entreprise.idEntreprise : '' }}">
                            {% if transaction.personne %}
                                <span class="badge bg-info">
                                    <i class="fas fa-user"></i> {{ transaction.personne.prenom }} {{ transaction.personne.nom }}
                                </span>
                            {% elseif transaction.entreprise %}
                                <span class="badge bg-warning">
                                    <i class="fas fa-building"></i> {{ transaction.entreprise.nomEntreprise }}
                                </span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="montant-cell editable-field text-end" 
                            data-field="montant" 
                            data-type="debit" 
                            data-current-value="{{ transaction.montant }}">
                            {% if transaction.montant >= 0 %}
                                <span class="badge bg-success fs-6 fw-bold">{{ transaction.montant|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="montant-cell editable-field text-end" 
                            data-field="montant" 
                            data-type="credit" 
                            data-current-value="{{ transaction.montant }}">
                            {% if transaction.montant < 0 %}
                                <span class="badge bg-danger fs-6 fw-bold">{{ (transaction.montant * -1)|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="solde-cell text-end" {% if montant_cumule < 0 %}style="border: 3px solid #dc3545 !important; background-color: rgba(220, 53, 69, 0.1) !important;"{% endif %}>
                            {% if montant_cumule >= 0 %}
                                <span class="text-success fw-bold">{{ montant_cumule|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="fw-bold" style="color: #dc3545 !important;">
                                    <i class="fas fa-exclamation-triangle me-1" style="color: #dc3545 !important;"></i>{{ montant_cumule|number_format(2, ',', ' ') }} €
                                </span>
                            {% endif %}
                        </td>
                        <td class="editable-field" data-field="exercice">{{ transaction.exercice ? transaction.exercice.libelle : '' }}</td>
                        <td class="editable-field" data-field="type_transaction">{{ transaction.typeTransaction ? transaction.typeTransaction.libelle : '' }}</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_transaction_show', {'id_transaction': transaction.idTransaction}) }}" class="btn btn-info btn-sm" title="Voir les détails">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('app_transaction_edit', {'id_transaction': transaction.idTransaction}) }}" class="btn btn-warning btn-sm" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button class="btn btn-danger btn-sm delete-btn" data-id="{{ transaction.idTransaction }}" title="Supprimer">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="11" class="text-center">Aucune transaction trouvée</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {{ include('components/inline_editor.html.twig') }}
    {{ include('components/montant_editor.html.twig') }}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Données pour les champs spéciaux
            const personnes = [
                {% for personne in personnes %}
                {
                    id: {{ personne.idPersonne }},
                    nom: "{{ personne.nom|e('js') }}",
                    prenom: "{{ personne.prenom|e('js') }}",
                    fullName: "{{ personne.prenom|e('js') }} {{ personne.nom|e('js') }}"
                }{{ not loop.last ? ',' : '' }}
                {% endfor %}
            ];
            
            const entreprises = [
                {% for entreprise in entreprises %}
                {
                    id: {{ entreprise.idEntreprise }},
                    nom: "{{ entreprise.nomEntreprise|e('js') }}"
                }{{ not loop.last ? ',' : '' }}
                {% endfor %}
            ];
            
            const exercices = [
                {% for exercice in exercices %}
                {
                    id: {{ exercice.idExercice }},
                    libelle: "{{ exercice.libelle|e('js') }}"
                }{{ not loop.last ? ',' : '' }}
                {% endfor %}
            ];
            
            const typesTransaction = [
                {% for type in types_transaction %}
                {
                    id: {{ type.idType }},
                    libelle: "{{ type.libelle|e('js') }}"
                }{{ not loop.last ? ',' : '' }}
                {% endfor %}
            ];
            
            // Configuration de l'éditeur pour les transactions avec gestion avancée des montants
            const editor = new MontantEditor({
                entityName: 'transaction',
                entityIdField: 'idTransaction',
                updateUrl: '/transaction/{id}/update-field',
                deleteUrl: '/transaction/{id}/delete-ajax',
                specialFields: {
                    tiers: {
                        type: 'select',
                        options: [
                            { value: '', text: 'Aucun tiers' },
                            ...personnes.map(p => ({ 
                                value: `personne_${p.id}`, 
                                text: `👤 ${p.fullName}` 
                            })),
                            ...entreprises.map(e => ({ 
                                value: `entreprise_${e.id}`, 
                                text: `🏢 ${e.nom}` 
                            }))
                        ]
                    },
                    exercice: {
                        type: 'select',
                        options: [
                            { value: '', text: 'Sélectionner un exercice' },
                            ...exercices.map(ex => ({ 
                                value: ex.id, 
                                text: ex.libelle 
                            }))
                        ]
                    },
                    type_transaction: {
                        type: 'select',
                        options: [
                            { value: '', text: 'Sélectionner un type' },
                            ...typesTransaction.map(type => ({ 
                                value: type.id, 
                                text: type.libelle 
                            }))
                        ]
                    }
                },
                soldeCalculationCallback: function() {
                    // Recalculer tous les soldes après modification d'un montant
                    const rows = document.querySelectorAll('tbody tr[data-id]');
                    let cumulativeSolde = 0;
                    
                    rows.forEach(row => {
                        const debitCell = row.querySelector('[data-type="debit"]');
                        if (debitCell) {
                            const montant = parseFloat(debitCell.dataset.currentValue) || 0;
                            cumulativeSolde += montant;
                            
                            const soldeCell = row.querySelector('.solde-cell');
                            if (soldeCell) {
                                const colorClass = cumulativeSolde >= 0 ? 'text-success' : 'text-danger';
                                const formattedSolde = new Intl.NumberFormat('fr-FR', {
                                    style: 'currency',
                                    currency: 'EUR'
                                }).format(cumulativeSolde);
                                soldeCell.innerHTML = `<span class="${colorClass} fw-bold">${formattedSolde}</span>`;
                            }
                        }
                    });
                }
            });
            
            console.log('Transaction MontantEditor initialisé avec gestion débit/crédit');
            
            // Gestion des filtres avec cases à cocher pour les tiers
            let selectedTiers = [];
            
            // Fonction pour mettre à jour le texte du bouton dropdown
            function updateTiersButtonText() {
                const button = document.getElementById('selected-tiers-text');
                if (selectedTiers.length === 0) {
                    button.textContent = 'Sélectionner des tiers...';
                } else if (selectedTiers.length === 1) {
                    const checkbox = document.querySelector(`input[value="${selectedTiers[0]}"]`);
                    const label = checkbox ? checkbox.nextElementSibling.textContent.trim() : 'Tiers sélectionné';
                    button.textContent = label;
                } else {
                    button.textContent = `${selectedTiers.length} tiers sélectionnés`;
                }
            }
            
            // Gestion des cases à cocher
            document.querySelectorAll('.tiers-checkbox').forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    if (this.checked) {
                        if (!selectedTiers.includes(this.value)) {
                            selectedTiers.push(this.value);
                        }
                    } else {
                        selectedTiers = selectedTiers.filter(value => value !== this.value);
                    }
                    updateTiersButtonText();
                });
            });
            
            // Bouton pour tout décocher
            document.getElementById('clear-tiers-selection').addEventListener('click', function() {
                document.querySelectorAll('.tiers-checkbox').forEach(checkbox => {
                    checkbox.checked = false;
                });
                selectedTiers = [];
                updateTiersButtonText();
            });
            
            // Empêcher la fermeture du dropdown quand on clique à l'intérieur
            document.querySelector('.dropdown-menu').addEventListener('click', function(e) {
                e.stopPropagation();
            });
            
            // Fonction de filtrage
            function applyFilters() {
                const libelleFilter = document.getElementById('filter-libelle').value.toLowerCase();
                const typeMontantFilter = document.getElementById('filter-type-montant').value;
                const montantMinFilter = parseFloat(document.getElementById('filter-montant-min').value) || null;
                const montantMaxFilter = parseFloat(document.getElementById('filter-montant-max').value) || null;
                const dateMinFilter = document.getElementById('filter-date-min').value;
                const dateMaxFilter = document.getElementById('filter-date-max').value;
                
                const rows = document.querySelectorAll('tbody tr[data-id]');
                
                rows.forEach(row => {
                    let showRow = true;
                    
                    // Filtre par libellé
                    if (libelleFilter) {
                        const libelle = row.cells[1].textContent.toLowerCase();
                        if (!libelle.includes(libelleFilter)) {
                            showRow = false;
                        }
                    }
                    
                    // Filtre par tiers
                    if (selectedTiers.length > 0) {
                        const tiersCell = row.cells[4].textContent.trim();
                        let tierMatch = false;
                        
                        selectedTiers.forEach(selectedTier => {
                            if (selectedTier.startsWith('personne_')) {
                                const personneId = selectedTier.replace('personne_', '');
                                const personne = personnes.find(p => p.id == personneId);
                                if (personne && tiersCell.includes(personne.fullName)) {
                                    tierMatch = true;
                                }
                            } else if (selectedTier.startsWith('entreprise_')) {
                                const entrepriseId = selectedTier.replace('entreprise_', '');
                                const entreprise = entreprises.find(e => e.id == entrepriseId);
                                if (entreprise && tiersCell.includes(entreprise.nom)) {
                                    tierMatch = true;
                                }
                            }
                        });
                        
                        if (!tierMatch) {
                            showRow = false;
                        }
                    }
                    
                    // Filtre par type de montant (débit/crédit) et montant min/max
                    if (typeMontantFilter || montantMinFilter !== null || montantMaxFilter !== null) {
                        const montantCell = row.cells[7];
                        const badge = montantCell.querySelector('.badge');
                        
                        if (badge) {
                            const isDebit = badge.classList.contains('bg-success');
                            const isCredit = badge.classList.contains('bg-danger');
                            
                            // Filtre par type (débit/crédit)
                            if (typeMontantFilter === 'debit' && !isDebit) {
                                showRow = false;
                            } else if (typeMontantFilter === 'credit' && !isCredit) {
                                showRow = false;
                            }
                            
                            // Filtre par montant min/max
                            const montantText = badge.textContent.trim().replace(/[^\d.,]/g, '').replace(',', '.');
                            const montantValue = parseFloat(montantText);
                            
                            if (!isNaN(montantValue)) {
                                if (montantMinFilter !== null && montantValue < montantMinFilter) {
                                    showRow = false;
                                }
                                if (montantMaxFilter !== null && montantValue > montantMaxFilter) {
                                    showRow = false;
                                }
                            }
                        }
                    }
                    
                    // Filtre par période de dates
                    if (dateMinFilter || dateMaxFilter) {
                        const dateText = row.cells[3].textContent.trim();
                        // Convertir la date affichée (format français) en format ISO pour la comparaison
                        const dateParts = dateText.split('/');
                        if (dateParts.length === 3) {
                            const dateISO = `${dateParts[2]}-${dateParts[1].padStart(2, '0')}-${dateParts[0].padStart(2, '0')}`;
                            
                            if (dateMinFilter && dateISO < dateMinFilter) {
                                showRow = false;
                            }
                            if (dateMaxFilter && dateISO > dateMaxFilter) {
                                showRow = false;
                            }
                        }
                        }
                    }
                    
                    row.style.display = showRow ? '' : 'none';
                });
                
                // Compter les résultats visibles
                const visibleRows = document.querySelectorAll('tbody tr[data-id]:not([style*="display: none"])').length;
                console.log(`Filtrage appliqué: ${visibleRows} transactions affichées`);
            }
            
            // Event listeners pour les boutons de filtre
            document.getElementById('apply-filters').addEventListener('click', applyFilters);
            document.getElementById('apply-tiers-filter').addEventListener('click', function() {
                // Fermer le dropdown
                const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('filter-tiers-dropdown'));
                if (dropdown) {
                    dropdown.hide();
                }
                applyFilters();
            });
            
            // Bouton pour effacer tous les filtres
            document.getElementById('clear-filters').addEventListener('click', function() {
                document.getElementById('filter-libelle').value = '';
                document.getElementById('filter-type-montant').value = '';
                document.getElementById('filter-montant-min').value = '';
                document.getElementById('filter-montant-max').value = '';
                document.getElementById('filter-date-min').value = '';
                document.getElementById('filter-date-max').value = '';
                
                document.querySelectorAll('.tiers-checkbox').forEach(checkbox => {
                    checkbox.checked = false;
                });
                selectedTiers = [];
                updateTiersButtonText();
                
                // Afficher toutes les lignes
                document.querySelectorAll('tbody tr[data-id]').forEach(row => {
                    row.style.display = '';
                });
                
                console.log('Tous les filtres ont été effacés');
            });
            
            // Appliquer les filtres en temps réel pour le libellé
            document.getElementById('filter-libelle').addEventListener('input', function() {
                if (this.value.length === 0 || this.value.length >= 2) {
                    applyFilters();
                }
            });
            
            // Appliquer les filtres en temps réel pour le type de montant
            document.getElementById('filter-type-montant').addEventListener('change', applyFilters);
            
            // Appliquer les filtres en temps réel pour les montants min/max
            document.getElementById('filter-montant-min').addEventListener('input', applyFilters);
            document.getElementById('filter-montant-max').addEventListener('input', applyFilters);
            
            // Appliquer les filtres en temps réel pour les dates min/max
            document.getElementById('filter-date-min').addEventListener('change', applyFilters);
            document.getElementById('filter-date-max').addEventListener('change', applyFilters);
        });
    </script>
{% endblock %}