{% extends 'base.html.twig' %}

{% block title %}Transactions{% endblock %}

{% block body %}
    {{ include('components/inline_edit_styles.html.twig') }}
    
    <div class="container-fluid mt-4">
        <h1 class="mb-4">Gestion des Transactions</h1>
        
        <!-- Zone de notifications pour les suppressions -->
        <div id="notifications" style="position: fixed; top: 20px; right: 20px; z-index: 9999; min-width: 300px;"></div>
        
        {% if exercice_filter %}
            <div class="alert alert-info">
                <i class="fas fa-filter me-2"></i>Transactions filtrées pour l'exercice : 
                <strong>{{ exercice_filter.libelle }}</strong>
                <a href="{{ path('app_transaction_index') }}" class="btn btn-outline-secondary btn-sm ms-3">
                    <i class="fas fa-times me-1"></i>Voir toutes les transactions
                </a>
            </div>
        {% endif %}
        
        <div class="row mb-3">
            <div class="col">
                <a href="{{ path('app_transaction_new') }}" class="btn btn-success">
                    <i class="fas fa-plus me-2"></i>Nouvelle Transaction
                </a>
                <a href="{{ path('app_transaction_export_excel') }}{% if exercice_filter %}?exercice_id={{ exercice_filter.idExercice }}{% endif %}" class="btn btn-primary ms-2">
                    <i class="fas fa-file-excel me-2"></i>Exporter Excel
                </a>
                
                <button class="btn btn-info ms-2" id="btn-sort-by-date" title="Trie les numéros d'ordre par date (la plus ancienne = 1)">
                    <i class="fas fa-sort-numeric-down me-1"></i>Trier par date
                </button>
            </div>
        </div>
        
        <!-- Filtres personnalisés -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filtres</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Filtre Libellé -->
                    <div class="col-md-2 mb-3">
                        <label for="filter-libelle" class="form-label">Libellé</label>
                        <input type="text" class="form-control" id="filter-libelle" placeholder="Rechercher par libellé..." value="{{ libelle_filter }}">
                    </div>

                    <!-- Bouton Filtre Tiers -->
                    <div class="col-md-2 mb-3">
                        <label for="toggle-tiers-filter" class="form-label"><i class="fas fa-users me-1"></i>Tiers</label>
                        <button type="button" class="btn btn-outline-secondary w-100" id="toggle-tiers-filter" style="text-align: left;">
                            <i class="fas fa-chevron-down me-2"></i><span id="tiers-button-text">Filtrer</span>
                            <span id="tiers-badge" class="badge bg-secondary ms-2" style="display: none;"></span>
                        </button>
                    </div>
                    
                    <!-- Filtre Débit/Crédit -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-type-montant" class="form-label"><i class="fas fa-exchange-alt me-1"></i>Type de montant</label>
                        <div class="input-group">
                            <select class="form-select" id="filter-type-montant" style="max-width: 160px;">
                                <option value="">Tous</option>
                                <option value="credit" {% if type_montant_filter == 'credit' %}selected{% endif %}>🟢 Crédit (Entrées)</option>
                                <option value="debit" {% if type_montant_filter == 'debit' %}selected{% endif %}>🔴 Débit (Sorties)</option>
                            </select>
                            <input type="number" class="form-control" id="filter-montant-min" placeholder="Min" step="0.01" style="max-width: 100px;" value="{{ montant_min_filter }}">
                            <input type="number" class="form-control" id="filter-montant-max" placeholder="Max" step="0.01" style="max-width: 100px;" value="{{ montant_max_filter }}">
                        </div>
                        <small class="text-muted">Filtre combiné : type + montant min/max</small>
                    </div>
                    
                    <!-- Filtre Date -->
                    <div class="col-md-4 mb-3">
                        <label for="filter-date" class="form-label">Date de transaction</label>
                        <div class="input-group">
                            <input type="date" class="form-control" id="filter-date-min" placeholder="Date min" value="{{ date_min_filter }}">
                            <input type="date" class="form-control" id="filter-date-max" placeholder="Date max" value="{{ date_max_filter }}">
                        </div>
                        <small class="text-muted">Période : date min/max</small>
                    </div>
                </div>

                <!-- Deuxième ligne de filtres -->
                <div class="row mt-2">
                    <!-- Bouton Filtre Type de Transaction -->
                    <div class="col-md-2 mb-3">
                        <label for="toggle-type-transaction-filter" class="form-label"><i class="fas fa-tag me-1"></i>Type Transaction</label>
                        <button type="button" class="btn btn-outline-secondary w-100" id="toggle-type-transaction-filter" style="text-align: left;">
                            <i class="fas fa-chevron-down me-2"></i><span id="type-transaction-button-text">Tous</span>
                            <span id="type-transaction-badge" class="badge bg-secondary ms-2" style="display: none;"></span>
                        </button>
                    </div>

                    <!-- Bouton Filtre Mode de Paiement -->
                    <div class="col-md-2 mb-3">
                        <label for="toggle-mode-paiement-filter" class="form-label"><i class="fas fa-credit-card me-1"></i>Mode Paiement</label>
                        <button type="button" class="btn btn-outline-secondary w-100" id="toggle-mode-paiement-filter" style="text-align: left;">
                            <i class="fas fa-chevron-down me-2"></i><span id="mode-paiement-button-text">Tous</span>
                            <span id="mode-paiement-badge" class="badge bg-secondary ms-2" style="display: none;"></span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filtre Tiers - PANNEAU COLLAPSIBLE -->
        <div id="tiers-filter-panel" class="card border-primary mt-4" style="display: none;">
            <div class="card-header bg-primary">
                <h6 class="mb-0 text-white"><i class="fas fa-users me-2"></i>Sélectionner les Tiers</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <!-- Personnes -->
                    <div class="col-12">
                        <h6 class="text-primary fw-bold mb-3">
                            <i class="fas fa-user-circle me-2"></i>PERSONNES
                            <span class="badge bg-info">{{ personnes|length }}</span>
                        </h6>
                        <div class="row g-2">
                            {% if personnes %}
                                {% for personne in personnes %}
                                <div class="col-md-6 col-lg-4">
                                    <div class="form-check">
                                        <input class="form-check-input tiers-checkbox" type="checkbox" 
                                               value="personne_{{ personne.idPersonne }}" 
                                               id="tiers-personne-{{ personne.idPersonne }}"
                                               {% if tiers_filter is defined and 'personne_' ~ personne.idPersonne in tiers_filter %}checked{% endif %}>
                                        <label class="form-check-label" for="tiers-personne-{{ personne.idPersonne }}">
                                            {{ personne.prenom }} {{ personne.nom }}
                                        </label>
                                    </div>
                                </div>
                                {% endfor %}
                            {% else %}
                                <p class="text-muted col-12">✓ Aucune personne enregistrée</p>
                            {% endif %}
                        </div>
                    </div>
                    
                    {% if entreprises|length > 0 %}
                    <div class="col-12">
                        <hr class="my-3">
                    </div>
                    
                    <!-- Entreprises -->
                    <div class="col-12">
                        <h6 class="text-success fw-bold mb-3">
                            <i class="fas fa-building me-2"></i>ENTREPRISES
                            <span class="badge bg-info">{{ entreprises|length }}</span>
                        </h6>
                        <div class="row g-2">
                            {% for entreprise in entreprises %}
                            <div class="col-md-6 col-lg-4">
                                <div class="form-check">
                                    <input class="form-check-input tiers-checkbox" type="checkbox" 
                                           value="entreprise_{{ entreprise.idEntreprise }}" 
                                           id="tiers-entreprise-{{ entreprise.idEntreprise }}"
                                           {% if tiers_filter is defined and 'entreprise_' ~ entreprise.idEntreprise in tiers_filter %}checked{% endif %}>
                                    <label class="form-check-label" for="tiers-entreprise-{{ entreprise.idEntreprise }}">
                                        {{ entreprise.nomEntreprise }}
                                    </label>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                </div>
                
                <!-- Boutons d'action -->
                <div class="mt-4 d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary" id="select-all-tiers">
                        <i class="fas fa-check-double me-1"></i>Tout sélectionner
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="clear-tiers-selection">
                        <i class="fas fa-redo me-1"></i>Réinitialiser
                    </button>
                </div>
            </div>
        </div>

        <!-- Filtre Type de Transaction - PANNEAU COLLAPSIBLE -->
        <div id="type-transaction-filter-panel" class="card border-info mt-4" style="display: none;">
            <div class="card-header bg-info">
                <h6 class="mb-0 text-white"><i class="fas fa-tag me-2"></i>Sélectionner les Types de Transaction</h6>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    {% if types_transaction %}
                        {% for type in types_transaction %}
                        <div class="col-md-6 col-lg-4">
                            <div class="form-check">
                                <input class="form-check-input type-transaction-checkbox" type="checkbox" 
                                       value="type-transaction_{{ type.idType }}" 
                                       id="type-transaction-{{ type.idType }}">
                                <label class="form-check-label" for="type-transaction-{{ type.idType }}">
                                    {{ type.libelle }}
                                </label>
                            </div>
                        </div>
                        {% endfor %}
                    {% else %}
                        <p class="text-muted col-12">✓ Aucun type de transaction</p>
                    {% endif %}
                </div>
                
                <!-- Boutons d'action -->
                <div class="mt-4 d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary" id="select-all-type-transaction">
                        <i class="fas fa-check-double me-1"></i>Tout sélectionner
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="clear-type-transaction-selection">
                        <i class="fas fa-redo me-1"></i>Réinitialiser
                    </button>
                </div>
            </div>
        </div>

        <!-- Filtre Mode de Paiement - PANNEAU COLLAPSIBLE -->
        <div id="mode-paiement-filter-panel" class="card border-success mt-4" style="display: none;">
            <div class="card-header bg-success">
                <h6 class="mb-0 text-white"><i class="fas fa-credit-card me-2"></i>Sélectionner les Modes de Paiement</h6>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    {% if modes_de_paiement %}
                        {% for mode in modes_de_paiement %}
                        <div class="col-md-6 col-lg-4">
                            <div class="form-check">
                                <input class="form-check-input mode-paiement-checkbox" type="checkbox" 
                                       value="mode-paiement_{{ mode.id }}" 
                                       id="mode-paiement-{{ mode.id }}">
                                <label class="form-check-label" for="mode-paiement-{{ mode.id }}">
                                    {{ mode.libelle }}
                                </label>
                            </div>
                        </div>
                        {% endfor %}
                    {% else %}
                        <p class="text-muted col-12">✓ Aucun mode de paiement</p>
                    {% endif %}
                </div>
                
                <!-- Boutons d'action -->
                <div class="mt-4 d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary" id="select-all-mode-paiement">
                        <i class="fas fa-check-double me-1"></i>Tout sélectionner
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="clear-mode-paiement-selection">
                        <i class="fas fa-redo me-1"></i>Réinitialiser
                    </button>
                </div>
            </div>
        </div>
                
                <div class="row">
                    <div class="col-12">
                        <button type="button" class="btn btn-primary me-2" id="apply-filters" onclick="applyFilters()">
                            <i class="fas fa-search me-1"></i>Filtrer
                        </button>
                        <button type="button" class="btn btn-outline-secondary" id="clear-filters" onclick="clearFilters()">
                            <i class="fas fa-times me-1"></i>Effacer les filtres
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="table table-striped table-hover transactions-table" style="table-layout: fixed;">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 5%;">N°</th>
                        <th style="width: 25%;">Libellé</th>
                        <th>Date</th>
                        <th>Tiers</th>
                        <th>Crédit (Entrée)</th>
                        <th>Débit (Sortie)</th>
                        <th>Montant</th>
                        <th>Mode de paiement</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="transactions-tbody">
                {% if exercice_precedent_existe %}
                    <tr class="table-secondary">
                        <td colspan="6" class="text-muted fst-italic">
                            <i class="fas fa-level-up-alt me-2"></i>Solde de l'exercice précédent
                        </td>
                        <td class="text-end">
                            {% if solde_precedent >= 0 %}
                                <span class="text-success fw-bold">{{ solde_precedent|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-danger fw-bold">{{ solde_precedent|number_format(2, ',', ' ') }} €</span>
                            {% endif %}
                        </td>
                        <td colspan="2"></td>
                    </tr>
                {% endif %}
                {% set current_exercice = null %}
                {% for item in transactions_avec_montant %}
                    {% set transaction = item.transaction %}
                    {% set montant_cumule = item.montant_cumule %}
                    {% set is_exercice_clos = transaction.exercice and transaction.exercice.isClos %}
                    
                    {# Affichage du séparateur d'exercice si changement #}
                    {% if transaction.exercice and current_exercice != transaction.exercice.idExercice %}
                        {% set current_exercice = transaction.exercice.idExercice %}
                        {% set montant_final_exercice = montants_par_exercice[transaction.exercice.idExercice] %}
                        <tr class="exercice-separator" data-exercice-id="{{ transaction.exercice.idExercice }}" title="Cliquer pour enrouler/dérouler les transactions de cet exercice">
                            <td class="exercice-title">
                                <i class="fas fa-calendar-alt me-2"></i>
                                {{ transaction.exercice.libelle }}
                                {% if transaction.exercice.isClos %}
                                    <span class="badge bg-danger ms-2">
                                        <i class="fas fa-lock me-1"></i>CLÔTURÉ
                                    </span>
                                {% else %}
                                    <span class="badge bg-success ms-2">
                                        <i class="fas fa-unlock me-1"></i>EN COURS
                                    </span>
                                {% endif %}
                            </td>
                            <td class="exercice-info"></td>
                            <td class="exercice-info"></td>
                            <td class="exercice-info"></td>
                            <td class="exercice-info"></td>
                            <td class="exercice-info"></td>
                            <td class="exercice-montant text-end">
                                <span class="exercice-montant-collapsed" style="display: none;">
                                    {% if montant_final_exercice >= 0 %}
                                        <span class="text-success fw-bold">{{ montant_final_exercice|number_format(2, ',', ' ') }} €</span>
                                    {% else %}
                                        <span class="fw-bold" style="color: #dc3545 !important;">
                                            <i class="fas fa-exclamation-triangle me-1" style="color: #dc3545 !important;"></i>{{ montant_final_exercice|number_format(2, ',', ' ') }} €
                                        </span>
                                    {% endif %}
                                </span>
                            </td>
                            <td class="exercice-info"></td>
                            <td class="exercice-actions text-end">
                                <span class="collapse-indicator">
                                    <i class="fas fa-chevron-up"></i>
                                </span>
                            </td>
                        </tr>
                    {% endif %}
                    
                    <tr data-id="{{ transaction.idTransaction }}" 
                        data-exercice-id="{{ transaction.exercice ? transaction.exercice.idExercice : '' }}" 
                        data-order="{{ transaction.numeroOrdre }}"
                        class="transaction-row">
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="numero_ordre" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>
                            {% if not is_exercice_clos %}<i class="fas fa-grip-vertical drag-handle me-2" style="cursor: move; color: #ccc;" title="Glisser pour réorganiser"></i>{% endif %}
                            {{ transaction.numeroOrdre }}
                        </td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="libelle" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.libelleComplet|raw }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="date_transaction" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.dateTransaction ? transaction.dateTransaction|date('Y-m-d') : '' }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="tiers" data-current-personne="{{ transaction.personne ? transaction.personne.idPersonne : '' }}" data-current-entreprise="{{ transaction.entreprise ? transaction.entreprise.idEntreprise : '' }}" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>
                            {% if transaction.personne %}
                                <span class="badge bg-info text-dark">
                                    <i class="fas fa-user"></i> {{ transaction.personne.prenom }} {{ transaction.personne.nom }}
                                </span>
                            {% elseif transaction.entreprise %}
                                <span class="badge bg-warning text-dark">
                                    <i class="fas fa-building"></i> {{ transaction.entreprise.nomEntreprise }}
                                </span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        {% set display_montant = item.montant_compte_courant is defined ? item.montant_compte_courant : transaction.montant %}
                        <td class="montant-cell {% if not is_exercice_clos and display_montant >= 0 %}editable-field{% endif %} text-end" 
                            data-field="montant" 
                            data-type="credit" 
                            data-current-value="{{ transaction.montant }}"
                            {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>
                            {% if display_montant >= 0 %}
                                <span class="badge bg-success text-dark fs-6 fw-bold">{{ display_montant|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="montant-cell {% if not is_exercice_clos and display_montant < 0 %}editable-field{% endif %} text-end" 
                            data-field="montant" 
                            data-type="debit" 
                            data-current-value="{{ transaction.montant }}"
                            {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>
                            {% if display_montant < 0 %}
                                <span class="badge bg-danger text-dark fs-6 fw-bold">{{ (display_montant * -1)|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="solde-cell text-end" {% if montant_cumule < 0 %}style="border: 3px solid #dc3545 !important; background-color: rgba(220, 53, 69, 0.1) !important;"{% endif %}>
                            {% if montant_cumule >= 0 %}
                                <span class="text-success fw-bold">{{ montant_cumule|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="fw-bold" style="color: #dc3545 !important;">
                                    <i class="fas fa-exclamation-triangle me-1" style="color: #dc3545 !important;"></i>{{ montant_cumule|number_format(2, ',', ' ') }} €
                                </span>
                            {% endif %}
                        </td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="mode_de_paiement" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.modeDePaiement ? transaction.modeDePaiement.libelle : '' }}</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_transaction_show', {'id_transaction': transaction.idTransaction}) }}" class="btn btn-info btn-sm" title="Voir les détails">
                                    <i class="fas fa-eye"></i>
                                </a>
                                {% if transaction.exercice and transaction.exercice.isClos %}
                                    <button class="btn btn-warning btn-sm" disabled title="Exercice clôturé - Modification impossible">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-danger btn-sm" disabled title="Exercice clôturé - Suppression impossible">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                {% else %}
                                    <a href="{{ path('app_transaction_edit', {'id_transaction': transaction.idTransaction}) }}" class="btn btn-warning btn-sm" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn btn-danger btn-sm delete-btn" data-id="{{ transaction.idTransaction }}" title="Supprimer">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="text-center">Aucune transaction trouvée</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <script src="{{ asset('js/transaction-drag-drop.js') }}"></script>
    <script src="{{ asset('js/transaction-page-scripts.js') }}"></script>
    <script>
        // Configuration simple comme pour les exercices
        function initializeTransactionConfig() {
            // Configuration URL pour drag & drop
            if (typeof setTransactionReorderUrl === 'function') {
                setTransactionReorderUrl('{{ path("app_transaction_bulk_update_order") }}');
            }
            
            // Configuration des données pour les selects
            window.transactionSelectData = {
                exercices: [
                    {% for exercice in exercices %}
                    { id: {{ exercice.idExercice }}, libelle: "{{ exercice.libelle }}" },
                    {% endfor %}
                ],
                types: [
                    {% for type in types_transaction %}
                    { id: {{ type.idType }}, libelle: "{{ type.libelle }}" },
                    {% endfor %}
                ],
                modes: [
                    {% for mode in modes_de_paiement %}
                    { id: {{ mode.id }}, libelle: "{{ mode.libelle }}" },
                    {% endfor %}
                ]
            };
        }
        
        // Vérifier si le DOM est déjà chargé
        if (document.readyState === "loading") {
            document.addEventListener('DOMContentLoaded', initializeTransactionConfig);
        } else {
            initializeTransactionConfig();
        }
        
        // Gestion du bouton de tri par date
        const btnSortByDate = document.getElementById('btn-sort-by-date');
        if (btnSortByDate) {
            btnSortByDate.addEventListener('click', sortTransactionsByDate);
        }
        
        function sortTransactionsByDate() {
            const confirmed = confirm('⚠️  Êtes-vous sûr ? Ceci va renumméroter les transactions selon l\'ordre chronologique (la plus ancienne = 1).\n\nLes exercices seront traités séparément.');
            
            if (!confirmed) return;
            
            const btn = document.getElementById('btn-sort-by-date');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Tri en cours...';
            
            // Récupérer l'exercice filtré depuis l'URL ou depuis le premier exercice-separator visible
            let exerciceId = null;
            
            // Chercher dans l'URL
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('exercice_id')) {
                exerciceId = parseInt(urlParams.get('exercice_id'));
            } else {
                // Récupérer depuis le premier élément exercice-separator
                const firstExerciceSeparator = document.querySelector('.exercice-separator');
                if (firstExerciceSeparator && firstExerciceSeparator.dataset.exerciceId) {
                    exerciceId = parseInt(firstExerciceSeparator.dataset.exerciceId);
                }
            }
            
            console.log('Tri par date - exerciceId:', exerciceId);
            
            fetch('{{ path("app_transaction_sort_by_date") }}', {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    exercice_id: exerciceId
                })
            })
            .then(response => {
                console.log('Réponse reçue:', response.status);
                return response.json();
            })
            .then(data => {
                console.log('Données reçues:', data);
                if (data.success) {
                    showNotification(`✅ ${data.message}`, 'success');
                    // Recharger la page après 2 secondes
                    setTimeout(() => location.reload(), 2000);
                } else {
                    showNotification(`❌ Erreur: ${data.error}`, 'danger');
                }
            })
            .catch(error => {
                console.error('Erreur:', error);
                showNotification('❌ Erreur de connexion au serveur', 'danger');
            })
            .finally(() => {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-sort-numeric-down me-1"></i>Trier par date';
            });
        }
    
    // Le drag & drop est maintenant géré par le fichier externe transaction-drag-drop.js
    </script>
    
