{% extends 'base.html.twig' %}

{% block title %}Transaction index{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .editable-field {
            cursor: pointer;
            padding: 5px;
            border: 1px solid transparent;
            border-radius: 3px;
            transition: all 0.2s;
        }
        
        .editable-field:hover {
            background-color: #f8f9fa;
            border-color: #dee2e6;
        }
        
        .editable-field.editing {
            background-color: #fff;
            border-color: #007bff;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
        }
        
        /* Cellules montant non-éditables */
        .montant-cell .montant-null {
            color: #6c757d;
        }
        
        .montant-cell.non-editable {
            cursor: not-allowed;
            opacity: 0.6;
        }
        
        .montant-cell.non-editable:hover {
            background-color: transparent;
            border-color: transparent;
        }
        
        .editable-input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            font-size: inherit;
            font-family: inherit;
        }
        
        .montant-editor {
            display: flex;
            align-items: center;
            gap: 5px;
            width: 100%;
        }
        
        .montant-input {
            flex: 1;
            border: none;
            outline: none;
            background: transparent;
            font-size: inherit;
            font-family: inherit;
        }
        
        .montant-toggle {
            background: #007bff;
            color: white;
            border: none;
            border-radius: 3px;
            padding: 2px 6px;
            cursor: pointer;
            font-size: 12px;
        }
        
        .montant-toggle:hover {
            background: #0056b3;
        }
        
        .saving {
            opacity: 0.6;
            pointer-events: none;
        }
        
        .alert {
            margin: 10px 0;
            padding: 10px;
            border-radius: 4px;
        }
        
        .alert-success {
            background-color: #d4edda;
            border-color: #c3e6cb;
            color: #155724;
        }
        
        .alert-danger {
            background-color: #f8d7da;
            border-color: #f5c6cb;
            color: #721c24;
        }
    </style>
{% endblock %}

{% block body %}
    <h1>Transaction index</h1>
    
    <div id="message-container"></div>

    <table class="table transaction-table" data-turbo="false">
        <thead>
            <tr>
                <th>Id_transaction</th>
                <th>Libelle</th>
                <th>Numero_ordre</th>
                <th>Date_transaction</th>
                <th>Tiers</th>
                <th>Débit</th>
                <th>Crédit</th>
                <th>Solde</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for item in transactions_avec_solde %}
            {% set transaction = item.transaction %}
            {% set solde = item.solde %}
            <tr data-id="{{ transaction.idTransaction }}">
                <td>{{ transaction.idTransaction }}</td>
                <td class="editable-field" data-field="libelle">{{ transaction.libelle }}</td>
                <td class="editable-field" data-field="numero_ordre">{{ transaction.numeroOrdre }}</td>
                <td class="editable-field" data-field="date_transaction">{{ transaction.dateTransaction ? transaction.dateTransaction|date('Y-m-d') : '' }}</td>
                <td class="editable-field" data-field="tiers" data-current-personne="{{ transaction.personne ? transaction.personne.idPersonne : '' }}" data-current-entreprise="{{ transaction.entreprise ? transaction.entreprise.idEntreprise : '' }}">
                    {% if transaction.personne %}
                        <span class="badge bg-info">
                            <i class="fas fa-user"></i> {{ transaction.personne.prenom }} {{ transaction.personne.nom }}
                        </span>
                    {% elseif transaction.entreprise %}
                        <span class="badge bg-warning">
                            <i class="fas fa-building"></i> {{ transaction.entreprise.nomEntreprise }}
                        </span>
                    {% else %}
                        <span class="text-muted">-</span>
                    {% endif %}
                </td>
                <td class="editable-field montant-cell" data-field="montant" data-type="debit" data-current-value="{{ transaction.montant }}">
                    {% if transaction.montant > 0 %}
                        <span class="montant-debit">{{ transaction.montant|number_format(2, ',', ' ') }} €</span>
                    {% else %}
                        <span class="montant-null">-</span>
                    {% endif %}
                </td>
                <td class="editable-field montant-cell" data-field="montant" data-type="credit" data-current-value="{{ transaction.montant }}">
                    {% if transaction.montant < 0 %}
                        <span class="montant-credit">{{ (transaction.montant * -1)|number_format(2, ',', ' ') }} €</span>
                    {% else %}
                        <span class="montant-null">-</span>
                    {% endif %}
                </td>
                <td>
                    <span class="montant-solde {% if solde > 0 %}solde-positif{% elseif solde < 0 %}solde-negatif{% else %}solde-nul{% endif %}">
                        {{ solde|number_format(2, ',', ' ') }} €
                    </span>
                </td>
                <td>
                    <a href="{{ path('app_transaction_show', {'id_transaction': transaction.idTransaction}) }}">show</a>
                    <a href="{{ path('app_transaction_edit', {'id_transaction': transaction.idTransaction}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="9">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_transaction_new') }}">Create new</a>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Données pour les listes déroulantes
            const personnes = [
                {% for personne in personnes %}
                {
                    id: {{ personne.idPersonne }},
                    nom: "{{ personne.nom|e('js') }}",
                    prenom: "{{ personne.prenom|e('js') }}",
                    fullName: "{{ personne.prenom|e('js') }} {{ personne.nom|e('js') }}"
                }{{ not loop.last ? ',' : '' }}
                {% endfor %}
            ];
            
            const entreprises = [
                {% for entreprise in entreprises %}
                {
                    id: {{ entreprise.idEntreprise }},
                    nom: "{{ entreprise.nomEntreprise|e('js') }}"
                }{{ not loop.last ? ',' : '' }}
                {% endfor %}
            ];
            
            let currentEditingCell = null;
            let originalValue = '';
            
            // Marquer les cellules montant non-éditables
            document.querySelectorAll('.montant-cell').forEach(cell => {
                const currentValue = parseFloat(cell.dataset.currentValue) || 0;
                const type = cell.dataset.type;
                
                if ((type === 'debit' && currentValue < 0) || (type === 'credit' && currentValue >= 0)) {
                    cell.classList.add('non-editable');
                }
            });
            
            function showMessage(message, type) {
                const container = document.getElementById('message-container');
                const alert = document.createElement('div');
                alert.className = `alert alert-${type}`;
                alert.textContent = message;
                container.appendChild(alert);
                
                setTimeout(() => {
                    alert.remove();
                }, 3000);
            }
            
            function saveField(cell, field, value, transactionId) {
                const row = cell.closest('tr');
                row.classList.add('saving');
                
                fetch(`/transaction/${transactionId}/update-field`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `field=${encodeURIComponent(field)}&value=${encodeURIComponent(value)}`
                })
                .then(response => response.json())
                .then(data => {
                    row.classList.remove('saving');
                    
                    if (data.success) {
                        updateCellDisplay(cell, field, value);
                        showMessage(data.message, 'success');
                        
                        // Recharger la page pour recalculer les soldes
                        setTimeout(() => {
                            location.reload();
                        }, 1000);
                    } else {
                        restoreOriginalContent(cell, field);
                        showMessage(data.message, 'danger');
                    }
                })
                .catch(error => {
                    row.classList.remove('saving');
                    restoreOriginalContent(cell, field);
                    showMessage('Erreur de communication avec le serveur', 'danger');
                    console.error('Error:', error);
                });
            }
            
            function updateCellDisplay(cell, field, value) {
                switch(field) {
                    case 'montant':
                        const type = cell.dataset.type;
                        const numValue = parseFloat(value);
                        
                        if (type === 'debit') {
                            if (numValue > 0) {
                                cell.innerHTML = `<span class="montant-debit">${numValue.toLocaleString('fr-FR', {minimumFractionDigits: 2})} €</span>`;
                                cell.classList.remove('non-editable');
                            } else {
                                cell.innerHTML = '<span class="montant-null">-</span>';
                                cell.classList.add('non-editable');
                            }
                            // Mettre à jour la cellule crédit correspondante
                            const creditCell = cell.parentNode.querySelector('[data-type="credit"]');
                            if (creditCell) {
                                if (numValue > 0) {
                                    creditCell.innerHTML = '<span class="montant-null">-</span>';
                                    creditCell.classList.add('non-editable');
                                } else {
                                    creditCell.classList.remove('non-editable');
                                }
                                creditCell.dataset.currentValue = value;
                            }
                        } else if (type === 'credit') {
                            if (numValue < 0) {
                                const positiveValue = Math.abs(numValue);
                                cell.innerHTML = `<span class="montant-credit">${positiveValue.toLocaleString('fr-FR', {minimumFractionDigits: 2})} €</span>`;
                                cell.classList.remove('non-editable');
                            } else {
                                cell.innerHTML = '<span class="montant-null">-</span>';
                                cell.classList.add('non-editable');
                            }
                            // Mettre à jour la cellule débit correspondante
                            const debitCell = cell.parentNode.querySelector('[data-type="debit"]');
                            if (debitCell) {
                                if (numValue < 0) {
                                    debitCell.innerHTML = '<span class="montant-null">-</span>';
                                    debitCell.classList.add('non-editable');
                                } else {
                                    debitCell.classList.remove('non-editable');
                                }
                                debitCell.dataset.currentValue = value;
                            }
                        }
                        cell.dataset.currentValue = value;
                        break;
                        
                    case 'tiers':
                        // La gestion du tiers sera complexe, pour l'instant on recharge
                        break;
                        
                    default:
                        cell.textContent = value;
                }
            }
            
            function startEditing(cell) {
                if (currentEditingCell && currentEditingCell !== cell) {
                    stopEditing(currentEditingCell, false);
                }
                
                currentEditingCell = cell;
                originalValue = cell.textContent;
                
                cell.classList.add('editing');
                
                const field = cell.dataset.field;
                let input;
                
                if (field === 'montant') {
                    // Éditeur spécial pour les montants avec bouton débit/crédit
                    const currentValue = parseFloat(cell.dataset.currentValue) || 0;
                    const isDebit = cell.dataset.type === 'debit';
                    const isCredit = cell.dataset.type === 'credit';
                    
                    const container = document.createElement('div');
                    container.className = 'montant-editor';
                    
                    input = document.createElement('input');
                    input.className = 'montant-input';
                    input.type = 'number';
                    input.step = '0.01';
                    input.min = '0';
                    
                    if ((isDebit && currentValue > 0) || (isCredit && currentValue < 0)) {
                        input.value = Math.abs(currentValue);
                    } else {
                        input.value = '';
                    }
                    
                    const toggleBtn = document.createElement('button');
                    toggleBtn.className = 'montant-toggle';
                    toggleBtn.type = 'button';
                    
                    // Variable pour stocker le type actuel
                    let currentType = isDebit ? 'debit' : 'credit';
                    toggleBtn.textContent = currentType === 'debit' ? 'D' : 'C';
                    
                    // Fonction pour mettre à jour l'affichage du bouton
                    const updateToggleButton = () => {
                        toggleBtn.textContent = currentType === 'debit' ? 'D' : 'C';
                        toggleBtn.style.backgroundColor = currentType === 'debit' ? '#28a745' : '#dc3545';
                    };
                    
                    updateToggleButton();
                    
                    toggleBtn.addEventListener('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        currentType = currentType === 'debit' ? 'credit' : 'debit';
                        updateToggleButton();
                        console.log('Toggle clicked, new type:', currentType);
                    });
                    
                    container.appendChild(input);
                    container.appendChild(toggleBtn);
                    
                    cell.textContent = '';
                    cell.appendChild(container);
                    
                    // Gestion de la validation
                    const validateMontant = () => {
                        const value = parseFloat(input.value) || 0;
                        if (value <= 0) {
                            showMessage('Le montant doit être supérieur à zéro', 'danger');
                            return false;
                        }
                        const finalValue = currentType === 'debit' ? value : -value;
                        console.log('Validating montant:', value, 'type:', currentType, 'final:', finalValue);
                        return finalValue;
                    };
                    
                    input.addEventListener('blur', function() {
                        const finalValue = validateMontant();
                        if (finalValue !== false) {
                            stopEditing(cell, true, finalValue);
                        } else {
                            stopEditing(cell, false);
                        }
                    });
                    
                    input.addEventListener('keydown', function(e) {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            const finalValue = validateMontant();
                            if (finalValue !== false) {
                                stopEditing(cell, true, finalValue);
                            }
                        } else if (e.key === 'Escape') {
                            e.preventDefault();
                            stopEditing(cell, false);
                        }
                    });
                    
                } else if (field === 'tiers') {
                    // Select pour choisir entre personne et entreprise
                    input = document.createElement('select');
                    input.className = 'editable-input';
                    
                    // Option vide
                    const emptyOption = document.createElement('option');
                    emptyOption.value = '';
                    emptyOption.textContent = 'Aucun tiers';
                    input.appendChild(emptyOption);
                    
                    // Groupe personnes
                    const personnesGroup = document.createElement('optgroup');
                    personnesGroup.label = 'Personnes';
                    personnes.forEach(personne => {
                        const option = document.createElement('option');
                        option.value = `personne_${personne.id}`;
                        option.textContent = personne.fullName;
                        personnesGroup.appendChild(option);
                    });
                    input.appendChild(personnesGroup);
                    
                    // Groupe entreprises
                    const entreprisesGroup = document.createElement('optgroup');
                    entreprisesGroup.label = 'Entreprises';
                    entreprises.forEach(entreprise => {
                        const option = document.createElement('option');
                        option.value = `entreprise_${entreprise.id}`;
                        option.textContent = entreprise.nom;
                        entreprisesGroup.appendChild(option);
                    });
                    input.appendChild(entreprisesGroup);
                    
                    // Sélectionner la valeur actuelle
                    if (cell.dataset.currentPersonne) {
                        input.value = `personne_${cell.dataset.currentPersonne}`;
                    } else if (cell.dataset.currentEntreprise) {
                        input.value = `entreprise_${cell.dataset.currentEntreprise}`;
                    }
                    
                    cell.textContent = '';
                    cell.appendChild(input);
                    
                } else {
                    // Input normal pour les autres champs
                    input = document.createElement('input');
                    input.className = 'editable-input';
                    
                    if (field === 'date_transaction') {
                        input.type = 'date';
                        input.value = originalValue;
                    } else if (field === 'numero_ordre') {
                        input.type = 'number';
                        input.min = '1';
                        input.value = originalValue;
                    } else {
                        input.type = 'text';
                        input.value = originalValue;
                    }
                    
                    cell.textContent = '';
                    cell.appendChild(input);
                }
                
                if (input && !input.classList.contains('montant-input')) {
                    input.focus();
                    if (input.tagName.toLowerCase() === 'input' && input.type === 'text') {
                        input.select();
                    }
                    
                    input.addEventListener('blur', function() {
                        stopEditing(cell, true);
                    });
                    
                    input.addEventListener('keydown', function(e) {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            stopEditing(cell, true);
                        } else if (e.key === 'Escape') {
                            e.preventDefault();
                            stopEditing(cell, false);
                        }
                    });
                }
                
                if (field === 'montant') {
                    input.focus();
                }
            }
            
            function stopEditing(cell, save, customValue = null) {
                if (!cell || !cell.classList.contains('editing')) return;
                
                const field = cell.dataset.field;
                let newValue;
                
                if (customValue !== null) {
                    newValue = customValue;
                } else {
                    const input = cell.querySelector('input, select');
                    if (field === 'tiers') {
                        newValue = input ? input.value : '';
                    } else {
                        newValue = input ? input.value.trim() : '';
                    }
                }
                
                cell.classList.remove('editing');
                
                if (save && shouldSave(field, newValue, cell)) {
                    const transactionId = cell.closest('tr').dataset.id;
                    
                    if (field === 'tiers') {
                        // Gérer le tiers spécialement
                        if (newValue.startsWith('personne_')) {
                            saveField(cell, 'personne', newValue.replace('personne_', ''), transactionId);
                        } else if (newValue.startsWith('entreprise_')) {
                            saveField(cell, 'entreprise', newValue.replace('entreprise_', ''), transactionId);
                        } else {
                            // Vider le tiers
                            saveField(cell, 'personne', '', transactionId);
                        }
                    } else {
                        saveField(cell, field, newValue, transactionId);
                    }
                } else {
                    restoreOriginalContent(cell, field);
                }
                
                currentEditingCell = null;
            }
            
            function shouldSave(field, newValue, cell) {
                if (field === 'montant') {
                    return newValue !== cell.dataset.currentValue;
                } else if (field === 'tiers') {
                    const currentPersonne = cell.dataset.currentPersonne;
                    const currentEntreprise = cell.dataset.currentEntreprise;
                    
                    if (newValue.startsWith('personne_')) {
                        return newValue.replace('personne_', '') !== currentPersonne;
                    } else if (newValue.startsWith('entreprise_')) {
                        return newValue.replace('entreprise_', '') !== currentEntreprise;
                    } else {
                        return currentPersonne || currentEntreprise;
                    }
                } else {
                    return newValue !== originalValue;
                }
            }
            
            function restoreOriginalContent(cell, field) {
                if (field === 'montant') {
                    const currentValue = parseFloat(cell.dataset.currentValue) || 0;
                    const type = cell.dataset.type;
                    
                    if (type === 'debit' && currentValue > 0) {
                        cell.innerHTML = `<span class="montant-debit">${currentValue.toLocaleString('fr-FR', {minimumFractionDigits: 2})} €</span>`;
                    } else if (type === 'credit' && currentValue < 0) {
                        const positiveValue = Math.abs(currentValue);
                        cell.innerHTML = `<span class="montant-credit">${positiveValue.toLocaleString('fr-FR', {minimumFractionDigits: 2})} €</span>`;
                    } else {
                        cell.innerHTML = '<span class="montant-null">-</span>';
                    }
                } else {
                    cell.textContent = originalValue;
                }
            }
            
            document.querySelectorAll('.editable-field').forEach(cell => {
                cell.addEventListener('click', function() {
                    if (!this.classList.contains('editing') && !this.classList.contains('non-editable')) {
                        startEditing(this);
                    }
                });
            });
            
            document.addEventListener('click', function(e) {
                if (currentEditingCell && !currentEditingCell.contains(e.target)) {
                    stopEditing(currentEditingCell, false);
                }
            });
        });
    </script>
{% endblock %}
