{% extends 'base.html.twig' %}

{% block title %}Modifier la transaction{% if exercice_filter %} - {{ exercice_filter.libelle }}{% endif %}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>
                    <i class="fas fa-edit me-2"></i>Modifier la transaction
                    {% if exercice_filter %}
                        <small class="text-muted">- {{ exercice_filter.libelle }}</small>
                    {% endif %}
                </h1>
                <div>
                    {% if exercice_filter %}
                        <a href="{{ path('app_transaction_index') }}?exercice_id={{ exercice_filter.idExercice }}" class="btn btn-secondary me-2">
                            <i class="fas fa-arrow-left me-1"></i>Retour à l'exercice
                        </a>
                    {% endif %}
                    <a href="{{ path('app_transaction_index') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-list me-1"></i>Toutes les transactions
                    </a>
                </div>
            </div>

            {% if exercice_filter %}
                <!-- Informations sur l'exercice -->
                <div class="card mb-4 border-primary">
                    <div class="card-header bg-primary text-white">
                        <h6 class="mb-0">
                            <i class="fas fa-calendar-alt me-2"></i>
                            Modification dans l'exercice : {{ exercice_filter.libelle }}
                            {% if exercice_filter.isClos %}
                                <span class="badge bg-danger ms-2">
                                    <i class="fas fa-lock me-1"></i>CLÔTURÉ
                                </span>
                            {% else %}
                                <span class="badge bg-success ms-2">
                                    <i class="fas fa-unlock me-1"></i>EN COURS
                                </span>
                            {% endif %}
                        </h6>
                    </div>
                    <div class="card-body py-2">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <small class="text-muted">Période :</small>
                                <strong>{{ exercice_filter.dateDebut ? exercice_filter.dateDebut|date('d/m/Y') : 'Non défini' }}</strong> - 
                                <strong>{{ exercice_filter.dateFin ? exercice_filter.dateFin|date('d/m/Y') : 'Non défini' }}</strong>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}

            <div class="card shadow-sm">
                <div class="card-body">
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.libelle, 'Libellé', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.libelle, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.libelle) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.exercice, 'Exercice', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.exercice, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.exercice) }}
                                {% if exercice_filter %}
                                    <div class="form-text">
                                        <i class="fas fa-info-circle me-1"></i>
                                        Cette transaction appartient à l'exercice {{ exercice_filter.libelle }}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.type_transaction, 'Type de transaction', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.type_transaction, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.type_transaction) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Montant et Type</label>
                                
                                <!-- Boutons radio pour Débit/Crédit -->
                                <div class="btn-group w-100 mb-2" role="group">
                                    <input type="radio" class="btn-check" name="debit_credit" id="debit" value="debit" 
                                           {% if transaction.montant < 0 %}checked{% endif %}>
                                    <label class="btn btn-outline-danger" for="debit">
                                        <i class="fas fa-minus me-1"></i>Débit (Sortie)
                                    </label>
                                    
                                    <input type="radio" class="btn-check" name="debit_credit" id="credit" value="credit" 
                                           {% if transaction.montant >= 0 %}checked{% endif %}>
                                    <label class="btn btn-outline-success" for="credit">
                                        <i class="fas fa-plus me-1"></i>Crédit (Entrée)
                                    </label>
                                </div>
                                
                                {{ form_widget(form.montant, {'attr': {'class': 'form-control', 'step': '0.01', 'min': '0'}}) }}
                                {{ form_errors(form.montant) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.date, 'Date', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.date) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.mode_de_paiement, 'Mode de paiement', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.mode_de_paiement, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.mode_de_paiement) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Type de tiers</label>
                                <div class="btn-group w-100 mb-2" role="group">
                                    <input type="radio" class="btn-check" name="tiers_type" id="personne_radio" value="personne" 
                                           {% if transaction.personne %}checked{% endif %}>
                                    <label class="btn btn-outline-info" for="personne_radio">
                                        <i class="fas fa-user me-1"></i>Personne
                                    </label>
                                    
                                    <input type="radio" class="btn-check" name="tiers_type" id="entreprise_radio" value="entreprise" 
                                           {% if transaction.entreprise %}checked{% endif %}>
                                    <label class="btn btn-outline-warning" for="entreprise_radio">
                                        <i class="fas fa-building me-1"></i>Entreprise
                                    </label>
                                    
                                    <input type="radio" class="btn-check" name="tiers_type" id="aucun_radio" value="aucun" 
                                           {% if not transaction.personne and not transaction.entreprise %}checked{% endif %}>
                                    <label class="btn btn-outline-secondary" for="aucun_radio">
                                        <i class="fas fa-ban me-1"></i>Aucun
                                    </label>
                                </div>
                                
                                <div id="personne-field" class="{% if not transaction.personne %}d-none{% endif %}">
                                    {{ form_widget(form.personne, {'attr': {'class': 'form-select'}}) }}
                                    {{ form_errors(form.personne) }}
                                </div>
                                
                                <div id="entreprise-field" class="{% if not transaction.entreprise %}d-none{% endif %}">
                                    {{ form_widget(form.entreprise, {'attr': {'class': 'form-select'}}) }}
                                    {{ form_errors(form.entreprise) }}
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.type_compte, 'Type de compte', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.type_compte, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.type_compte) }}
                                <div class="form-text">
                                    <small>
                                        <strong>Compte courant :</strong> transactions normales<br>
                                        <strong>Livret :</strong> montants inversés (débit → crédit et vice versa)
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <div class="mb-4">
                                {{ form_label(form.description, 'Description (optionnelle)', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '3'}}) }}
                                {{ form_errors(form.description) }}
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <div>
                            {% if exercice_filter %}
                                <a href="{{ path('app_transaction_index') }}?exercice_id={{ exercice_filter.idExercice }}" class="btn btn-outline-secondary">
                                    <i class="fas fa-times me-1"></i>Annuler
                                </a>
                            {% else %}
                                <a href="{{ path('app_transaction_index') }}" class="btn btn-outline-secondary">
                                    <i class="fas fa-times me-1"></i>Annuler
                                </a>
                            {% endif %}
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>Enregistrer les modifications
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const personneRadio = document.getElementById('personne_radio');
    const entrepriseRadio = document.getElementById('entreprise_radio');
    const aucunRadio = document.getElementById('aucun_radio');
    const personneField = document.getElementById('personne-field');
    const entrepriseField = document.getElementById('entreprise-field');
    
    function updateTiersFields() {
        if (personneRadio.checked) {
            personneField.classList.remove('d-none');
            entrepriseField.classList.add('d-none');
        } else if (entrepriseRadio.checked) {
            entrepriseField.classList.remove('d-none');
            personneField.classList.add('d-none');
        } else {
            personneField.classList.add('d-none');
            entrepriseField.classList.add('d-none');
        }
    }
    
    personneRadio.addEventListener('change', updateTiersFields);
    entrepriseRadio.addEventListener('change', updateTiersFields);
    aucunRadio.addEventListener('change', updateTiersFields);
    
    // Gestion du montant avec débit/crédit
    const debitRadio = document.getElementById('debit');
    const creditRadio = document.getElementById('credit');
    const montantField = document.querySelector('input[name="transaction[montant]"]');
    
    function updateMontantSign() {
        let montant = Math.abs(parseFloat(montantField.value) || 0);
        if (debitRadio.checked) {
            montantField.value = -montant;
        } else {
            montantField.value = montant;
        }
    }
    
    debitRadio.addEventListener('change', updateMontantSign);
    creditRadio.addEventListener('change', updateMontantSign);
    montantField.addEventListener('input', function() {
        // S'assurer que l'affichage reste cohérent
        let montant = parseFloat(this.value) || 0;
        if (montant < 0) {
            debitRadio.checked = true;
            creditRadio.checked = false;
        } else {
            creditRadio.checked = true;
            debitRadio.checked = false;
        }
    });
});
</script>

{% endblock %}