<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}RCA Application{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        <!-- Bootstrap CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- Font Awesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}
    </head>
    <body>
        <!-- Navigation -->
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid" style="overflow: visible !important;">
                <a class="navbar-brand fw-bold" href="{{ path('app_home') }}" style="color: var(--primary-color);">
                    <img src="{{ asset('images/RCA logo.png') }}" alt="RCA Logo" class="ms-3 me-3" style="height: 90px; width: auto;">RCA
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav" style="overflow: visible !important;">
                    <ul class="navbar-nav me-auto" style="overflow: visible !important;">
                        {% if has_access('app_exercice_index') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_exercice_index') }}">
                                <i class="fas fa-calendar-alt me-1"></i>Exercices
                            </a>
                        </li>
                        {% endif %}
                        
                        {% if has_access('app_transaction_index') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_transaction_index') }}">
                                <i class="fas fa-exchange-alt me-1"></i>Transactions
                            </a>
                        </li>
                        {% endif %}
                        
                        {% if has_access('app_livret_index') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_livret_index') }}">
                                <i class="fas fa-piggy-bank me-1"></i>Livret
                            </a>
                        </li>
                        {% endif %}
                        
                        {% if has_access('app_attestation_fiscale_index') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_attestation_fiscale_index') }}">
                                <i class="fas fa-file-invoice me-1"></i>Attestations Fiscales
                            </a>
                        </li>
                        {% endif %}
                        
                        {# Menu Gestion - Ne s'affiche que si l'utilisateur a accès à au moins une section #}
                        {% set has_gestion_access = false %}
                        {% if has_access('app_personne_index') or has_access('app_entreprise_index') or has_access('app_user_index') or has_access('app_role_index') or has_access('app_type_transaction_index') or has_access('app_mode_de_paiement_index') %}
                            {% set has_gestion_access = true %}
                        {% endif %}
                        
                        {% if has_gestion_access %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" id="gestionDropdown">
                                <i class="fas fa-cogs me-1"></i>Gestion
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="gestionDropdown">
                                {% if has_access('app_personne_index') %}
                                <li><a class="dropdown-item" href="{{ path('app_personne_index') }}">
                                    <i class="fas fa-users me-1"></i>Personnes
                                </a></li>
                                {% endif %}
                                
                                {% if has_access('app_entreprise_index') %}
                                <li><a class="dropdown-item" href="{{ path('app_entreprise_index') }}">
                                    <i class="fas fa-building me-1"></i>Entreprises
                                </a></li>
                                {% endif %}
                                
                                {% if has_access('app_user_index') or has_access('app_role_index') %}
                                    {% if has_access('app_personne_index') or has_access('app_entreprise_index') %}
                                    <li><hr class="dropdown-divider"></li>
                                    {% endif %}
                                {% endif %}
                                
                                {% if has_access('app_user_index') %}
                                <li><a class="dropdown-item" href="{{ path('app_user_index') }}">
                                    <i class="fas fa-user-cog me-1"></i>Utilisateurs
                                </a></li>
                                {% endif %}
                                
                                {% if has_access('app_role_index') %}
                                <li><a class="dropdown-item" href="{{ path('app_role_index') }}">
                                    <i class="fas fa-user-tag me-1"></i>Rôles
                                </a></li>
                                {% endif %}
                                
                                {% if has_access('app_type_transaction_index') or has_access('app_mode_de_paiement_index') %}
                                    {% if has_access('app_user_index') or has_access('app_role_index') or has_access('app_personne_index') or has_access('app_entreprise_index') %}
                                    <li><hr class="dropdown-divider"></li>
                                    {% endif %}
                                {% endif %}
                                
                                {% if has_access('app_type_transaction_index') %}
                                <li><a class="dropdown-item" href="{{ path('app_type_transaction_index') }}">
                                    <i class="fas fa-tags me-1"></i>Types de Transaction
                                </a></li>
                                {% endif %}
                                
                                {% if has_access('app_mode_de_paiement_index') %}
                                <li><a class="dropdown-item" href="{{ path('app_mode_de_paiement_index') }}">
                                    <i class="fas fa-credit-card me-1"></i>Modes de Paiement
                                </a></li>
                                {% endif %}
                            </ul>
                        </li>
                        {% endif %}

                    </ul>
                    
                    <!-- User menu -->
                    <ul class="navbar-nav">
                        {% if app.user %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" id="userDropdown">
                                    <i class="fas fa-user-circle me-1"></i>{{ app.user.userIdentifier }}
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" href="{{ path('app_my_data') }}">
                                        <i class="fas fa-user-cog me-2"></i>Mes données
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                        <i class="fas fa-sign-out-alt me-2"></i>Se déconnecter
                                    </a></li>
                                </ul>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">
                                    <i class="fas fa-sign-in-alt me-1"></i>Se connecter
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_register') }}">
                                    <i class="fas fa-user-plus me-1"></i>S'inscrire
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Main content -->
        <main>
            <!-- Flash Messages -->
            <div class="container-fluid mt-3">
                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ type == 'error' ? 'danger' : (type == 'notice' ? 'info' : type) }} alert-dismissible fade show" role="alert">
                            {% if type == 'success' %}
                                <i class="fas fa-check-circle me-2"></i>
                            {% elseif type == 'error' or type == 'danger' %}
                                <i class="fas fa-exclamation-circle me-2"></i>
                            {% elseif type == 'warning' %}
                                <i class="fas fa-exclamation-triangle me-2"></i>
                            {% else %}
                                <i class="fas fa-info-circle me-2"></i>
                            {% endif %}
                            {{ message|raw }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
            
            {% block body %}{% endblock %}
        </main>

        <!-- Footer RGPD -->
        <footer class="bg-light border-top mt-5 py-3">
            <div class="container-fluid">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <small class="text-muted">
                            © {{ "now"|date("Y") }} Rugby Club Audomarois - Tous droits réservés
                        </small>
                    </div>
                    <div class="col-md-6 text-end">
                        <small>
                            <a href="{{ path('app_privacy_policy') }}" class="text-decoration-none text-muted me-3">
                                <i class="fas fa-shield-alt me-1"></i>Politique de confidentialité
                            </a>
                            {% if app.user %}
                                <a href="{{ path('app_my_data') }}" class="text-decoration-none text-muted">
                                    <i class="fas fa-user-cog me-1"></i>Mes données
                                </a>
                            {% endif %}
                        </small>
                    </div>
                </div>
            </div>
        </footer>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        
        <!-- Bootstrap JavaScript AVANT les autres scripts -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        
        <!-- Auto-dismiss flash messages -->
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                // Vérifier que Bootstrap est bien chargé
                if (typeof bootstrap === 'undefined') {
                    console.error('Bootstrap JavaScript n\'est pas chargé');
                    return;
                }
                
                // Auto-fermeture des messages success et info après 5 secondes
                const successAlerts = document.querySelectorAll('.alert-success, .alert-info');
                successAlerts.forEach(function(alert) {
                    setTimeout(function() {
                        const bsAlert = new bootstrap.Alert(alert);
                        bsAlert.close();
                    }, 5000);
                });
                
                // Auto-fermeture des messages warning après 8 secondes
                const warningAlerts = document.querySelectorAll('.alert-warning');
                warningAlerts.forEach(function(alert) {
                    setTimeout(function() {
                        const bsAlert = new bootstrap.Alert(alert);
                        bsAlert.close();
                    }, 8000);
                });
                
                // Debug: vérifier la présence des éléments dropdown
                const dropdownElements = document.querySelectorAll('.dropdown-toggle');
                console.log('Éléments dropdown trouvés:', dropdownElements.length);
                
                // Initialiser manuellement les dropdowns
                dropdownElements.forEach(function(element) {
                    console.log('Initialisation du dropdown:', element.id || 'sans ID');
                    try {
                        new bootstrap.Dropdown(element);
                    } catch (e) {
                        console.error('Erreur lors de l\'initialisation du dropdown:', e);
                    }
                });
                
                // Test alternatif : ajouter un event listener sur le dropdown "Gestion"
                const gestionDropdown = document.getElementById('gestionDropdown');
                if (gestionDropdown) {
                    gestionDropdown.addEventListener('click', function(e) {
                        e.preventDefault();
                        console.log('Click sur le dropdown Gestion détecté');
                        const dropdownMenu = this.nextElementSibling;
                        if (dropdownMenu) {
                            dropdownMenu.classList.toggle('show');
                            this.setAttribute('aria-expanded', dropdownMenu.classList.contains('show'));
                        }
                    });
                }
            });
        </script>
        


        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </body>
</html>
