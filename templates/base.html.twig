<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}RCA Application{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        <!-- Bootstrap CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- Font Awesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}
    </head>
    <body>
        <!-- Navigation -->
        <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: var(--secondary-color);">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="{{ path('app_home') }}" style="color: var(--primary-color);">
                    <i class="fas fa-calculator me-2"></i>RCA Application
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home') }}">
                                <i class="fas fa-home me-1"></i>Accueil
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_exercice_index') }}">
                                <i class="fas fa-calendar-alt me-1"></i>Exercices
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_transaction_index') }}">
                                <i class="fas fa-exchange-alt me-1"></i>Transactions
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_livret_index') }}">
                                <i class="fas fa-piggy-bank me-1"></i>Livret
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-users me-1"></i>Gestion
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('app_entreprise_index') }}">
                                    <i class="fas fa-building me-1"></i>Entreprises
                                </a></li>
                                <li><a class="dropdown-item" href="{{ path('app_personne_index') }}">
                                    <i class="fas fa-user me-1"></i>Personnes
                                </a></li>
                                <li><a class="dropdown-item" href="{{ path('app_type_transaction_index') }}">
                                    <i class="fas fa-tags me-1"></i>Types de Transaction
                                </a></li>
                                <li><a class="dropdown-item" href="{{ path('app_mode_de_paiement_index') }}">
                                    <i class="fas fa-credit-card me-1"></i>Modes de Paiement
                                </a></li>
                            </ul>
                        </li>
                        {% if app.user and is_granted('ROLE_ADMIN') %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-cog me-1"></i>Administration
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('app_user_index') }}">
                                    <i class="fas fa-users-cog me-1"></i>Utilisateurs
                                </a></li>
                                <li><a class="dropdown-item" href="{{ path('app_role_index') }}">
                                    <i class="fas fa-user-tag me-1"></i>Rôles
                                </a></li>
                            </ul>
                        </li>
                        {% endif %}
                    </ul>
                    
                    <!-- User menu -->
                    <ul class="navbar-nav">
                        {% if app.user %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle me-1"></i>{{ app.user.userIdentifier }}
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="{{ path('app_logout') }}">
                                        <i class="fas fa-sign-out-alt me-1"></i>Se déconnecter
                                    </a></li>
                                </ul>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">
                                    <i class="fas fa-sign-in-alt me-1"></i>Se connecter
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_register') }}">
                                    <i class="fas fa-user-plus me-1"></i>S'inscrire
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Main content -->
        <main>
            <!-- Flash Messages -->
            <div class="container-fluid mt-3">
                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ type == 'error' ? 'danger' : (type == 'notice' ? 'info' : type) }} alert-dismissible fade show" role="alert">
                            {% if type == 'success' %}
                                <i class="fas fa-check-circle me-2"></i>
                            {% elseif type == 'error' or type == 'danger' %}
                                <i class="fas fa-exclamation-circle me-2"></i>
                            {% elseif type == 'warning' %}
                                <i class="fas fa-exclamation-triangle me-2"></i>
                            {% else %}
                                <i class="fas fa-info-circle me-2"></i>
                            {% endif %}
                            {{ message|raw }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
            
            {% block body %}{% endblock %}
        </main>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        
        <!-- Auto-dismiss flash messages -->
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                // Auto-fermeture des messages success et info après 5 secondes
                const successAlerts = document.querySelectorAll('.alert-success, .alert-info');
                successAlerts.forEach(function(alert) {
                    setTimeout(function() {
                        const bsAlert = new bootstrap.Alert(alert);
                        bsAlert.close();
                    }, 5000);
                });
                
                // Auto-fermeture des messages warning après 8 secondes
                const warningAlerts = document.querySelectorAll('.alert-warning');
                warningAlerts.forEach(function(alert) {
                    setTimeout(function() {
                        const bsAlert = new bootstrap.Alert(alert);
                        bsAlert.close();
                    }, 8000);
                });
            });
        </script>
        
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </body>
</html>
