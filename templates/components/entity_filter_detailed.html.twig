{# Composant de filtrage détaillé pour les listes d'entités #}
{% set filter_id = filter_id|default('entity-filter') %}
{% set placeholder = placeholder|default('Rechercher...') %}

<div class="mb-3">
    {% if filters is defined and filters is not empty %}
        {# Filtres détaillés par colonne #}
        <div class="card">
            <div class="card-header py-2">
                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">
                        <i class="fas fa-filter me-2"></i>Filtres
                    </h6>
                    <div>
                        <button class="btn btn-sm btn-outline-secondary me-2" type="button" id="toggleFilters">
                            <i class="fas fa-chevron-up"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger" type="button" id="clearAllFilters">
                            <i class="fas fa-times me-1"></i>Effacer tout
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body py-2" id="filtersContainer">
                <div class="row g-2">
                    {% for filter in filters %}
                        <div class="col-md-{{ filter.width|default(3) }}">
                            <label class="form-label small mb-1" for="filter_{{ filter.field }}">
                                {{ filter.label }}
                            </label>
                            {% if filter.type == 'select' %}
                                <select class="form-select form-select-sm entity-filter-field" 
                                        id="filter_{{ filter.field }}" 
                                        data-field="{{ filter.field }}">
                                    <option value="">Tous</option>
                                    {% for option in filter.options %}
                                        <option value="{{ option.value }}">{{ option.label }}</option>
                                    {% endfor %}
                                </select>
                            {% elseif filter.type == 'number' %}
                                <div class="input-group input-group-sm">
                                    <input type="number" 
                                           class="form-control entity-filter-field" 
                                           id="filter_{{ filter.field }}_min"
                                           data-field="{{ filter.field }}"
                                           data-operator="min"
                                           placeholder="Min">
                                    <span class="input-group-text">-</span>
                                    <input type="number" 
                                           class="form-control entity-filter-field" 
                                           id="filter_{{ filter.field }}_max"
                                           data-field="{{ filter.field }}"
                                           data-operator="max"
                                           placeholder="Max">
                                </div>
                            {% elseif filter.type == 'date' %}
                                <div class="input-group input-group-sm">
                                    <input type="date" 
                                           class="form-control entity-filter-field" 
                                           id="filter_{{ filter.field }}_from"
                                           data-field="{{ filter.field }}"
                                           data-operator="from">
                                    <span class="input-group-text">-</span>
                                    <input type="date" 
                                           class="form-control entity-filter-field" 
                                           id="filter_{{ filter.field }}_to"
                                           data-field="{{ filter.field }}"
                                           data-operator="to">
                                </div>
                            {% elseif filter.type == 'number_with_type' %}
                                <div class="mb-2">
                                    <div class="input-group input-group-sm">
                                        <input type="number" 
                                               class="form-control entity-filter-field" 
                                               id="filter_{{ filter.field }}_min"
                                               data-field="{{ filter.field }}"
                                               data-operator="min"
                                               data-debit-column="{{ filter.debit_column }}"
                                               data-credit-column="{{ filter.credit_column }}"
                                               placeholder="Min">
                                        <span class="input-group-text">-</span>
                                        <input type="number" 
                                               class="form-control entity-filter-field" 
                                               id="filter_{{ filter.field }}_max"
                                               data-field="{{ filter.field }}"
                                               data-operator="max"
                                               data-debit-column="{{ filter.debit_column }}"
                                               data-credit-column="{{ filter.credit_column }}"
                                               placeholder="Max">
                                    </div>
                                </div>
                                <div class="form-check-inline">
                                    <input class="form-check-input entity-filter-field" 
                                           type="radio" 
                                           name="filter_{{ filter.field }}_type" 
                                           id="filter_{{ filter.field }}_debit"
                                           data-field="{{ filter.field }}"
                                           data-operator="type"
                                           value="debit">
                                    <label class="form-check-label small" for="filter_{{ filter.field }}_debit">
                                        Débit
                                    </label>
                                </div>
                                <div class="form-check-inline">
                                    <input class="form-check-input entity-filter-field" 
                                           type="radio" 
                                           name="filter_{{ filter.field }}_type" 
                                           id="filter_{{ filter.field }}_credit"
                                           data-field="{{ filter.field }}"
                                           data-operator="type"
                                           value="credit">
                                    <label class="form-check-label small" for="filter_{{ filter.field }}_credit">
                                        Crédit
                                    </label>
                                </div>
                                <div class="form-check-inline">
                                    <input class="form-check-input entity-filter-field" 
                                           type="radio" 
                                           name="filter_{{ filter.field }}_type" 
                                           id="filter_{{ filter.field }}_both"
                                           data-field="{{ filter.field }}"
                                           data-operator="type"
                                           value="both"
                                           checked>
                                    <label class="form-check-label small" for="filter_{{ filter.field }}_both">
                                        Tous
                                    </label>
                                </div>
                            {% else %}
                                <input type="text" 
                                       class="form-control form-control-sm entity-filter-field" 
                                       id="filter_{{ filter.field }}"
                                       data-field="{{ filter.field }}"
                                       placeholder="{{ filter.placeholder|default('Rechercher...') }}">
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% else %}
        {# Filtre simple par défaut #}
        <div class="row align-items-end">
            <div class="col-md-6">
                <label for="{{ filter_id }}" class="form-label">
                    <i class="fas fa-search me-1"></i>Filtrer la liste
                </label>
                <input type="text" 
                       id="{{ filter_id }}" 
                       class="form-control" 
                       placeholder="{{ placeholder }}"
                       autocomplete="off">
            </div>
            <div class="col-md-3">
                <button type="button" id="{{ filter_id }}-clear" class="btn btn-outline-secondary">
                    <i class="fas fa-times me-1"></i>Effacer
                </button>
            </div>
            <div class="col-md-3">
                <div id="{{ filter_id }}-stats" class="text-muted small">
                    <!-- Statistiques de filtrage -->
                </div>
            </div>
        </div>
    {% endif %}
    
    <small class="text-muted mt-1 d-block">
        <span id="filter-stats"></span>
        <span class="ms-2">
            <kbd>Ctrl+F</kbd> pour rechercher, <kbd>Échap</kbd> pour effacer
        </span>
    </small>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Variables pour filtrage simple
    const filterInput = document.getElementById('{{ filter_id }}');
    const clearButton = document.getElementById('{{ filter_id }}-clear');
    const statsDiv = document.getElementById('{{ filter_id }}-stats');
    
    // Variables pour filtrage détaillé
    const detailedFilters = document.querySelectorAll('.entity-filter-field');
    const toggleFiltersBtn = document.getElementById('toggleFilters');
    const clearAllFiltersBtn = document.getElementById('clearAllFilters');
    const filtersContainer = document.getElementById('filtersContainer');
    
    const table = document.querySelector('{{ tableSelector|default("table") }}');
    
    if (!table) return;
    
    const tbody = table.querySelector('tbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    const totalRows = rows.length;
    
    // Stockage des filtres actifs
    let activeFilters = {};
    
    function updateStats(visibleCount) {
        const statsElement = document.getElementById('filter-stats') || statsDiv;
        if (statsElement) {
            if (visibleCount === totalRows) {
                statsElement.innerHTML = `<i class="fas fa-list me-1"></i>${totalRows} élément(s)`;
            } else {
                statsElement.innerHTML = `<i class="fas fa-filter me-1"></i>${visibleCount}/${totalRows} élément(s)`;
            }
        }
    }
    
    function normalizeText(text) {
        return text.toLowerCase()
                  .normalize('NFD')
                  .replace(/[\u0300-\u036f]/g, '')
                  .trim();
    }
    
    function matchesFilter(cellText, filterValue, operator = null, element = null) {
        const normalizedCell = normalizeText(cellText);
        const normalizedFilter = normalizeText(filterValue);
        
        if (operator === 'min') {
            // Extraire le nombre du texte (enlever €, espaces, etc.)
            const numText = cellText.replace(/[^\d,.-]/g, '').replace(',', '.');
            const num = parseFloat(numText);
            const filterNum = parseFloat(filterValue);
            return !isNaN(num) && !isNaN(filterNum) && num >= filterNum;
        } else if (operator === 'max') {
            const numText = cellText.replace(/[^\d,.-]/g, '').replace(',', '.');
            const num = parseFloat(numText);
            const filterNum = parseFloat(filterValue);
            return !isNaN(num) && !isNaN(filterNum) && num <= filterNum;
        } else if (operator === 'from') {
            const cellDate = new Date(cellText);
            const filterDate = new Date(filterValue);
            return cellDate >= filterDate;
        } else if (operator === 'to') {
            const cellDate = new Date(cellText);
            const filterDate = new Date(filterValue);
            return cellDate <= filterDate;
        } else if (operator === 'type') {
            // Pour les filtres de type crédit/débit, on gère ça dans filterTable
            return true;
        }
        
        return normalizedCell.includes(normalizedFilter);
    }
    
    function filterTable() {
        let visibleCount = 0;
        
        rows.forEach(row => {
            // Ignorer les lignes spéciales
            if (row.classList.contains('table-secondary') || row.querySelector('.fst-italic')) {
                return;
            }
            
            let isVisible = true;
            
            // Filtrage simple
            if (filterInput && filterInput.value.trim()) {
                const filterValue = filterInput.value.trim();
                const text = row.textContent;
                isVisible = matchesFilter(text, filterValue);
            }
            
            // Filtrage détaillé
            if (Object.keys(activeFilters).length > 0) {
                const cells = row.querySelectorAll('td');
                
                for (const [field, filterData] of Object.entries(activeFilters)) {
                    if (field === 'montant' && filterData.type) {
                        // Filtrage spécial pour montant avec type crédit/débit
                        const debitColumn = filterData.debitColumn || 5;
                        const creditColumn = filterData.creditColumn || 6;
                        
                        let matchesAmount = true;
                        let matchesType = true;
                        
                        // Debug: log des cellules
                        const debitCell = cells[debitColumn];
                        const creditCell = cells[creditColumn];
                        const debitText = debitCell ? debitCell.textContent.trim() : '';
                        const creditText = creditCell ? creditCell.textContent.trim() : '';
                        
                        // Vérifier le type (crédit/débit)
                        if (filterData.type === 'debit') {
                            // Une ligne est un débit si la colonne débit ne contient pas "text-muted" (donc pas le "-")
                            const debitHTML = debitCell ? debitCell.innerHTML : '';
                            matchesType = debitHTML && !debitHTML.includes('text-muted');
                        } else if (filterData.type === 'credit') {
                            // Une ligne est un crédit si la colonne crédit ne contient pas "text-muted" (donc pas le "-")
                            const creditHTML = creditCell ? creditCell.innerHTML : '';
                            matchesType = creditHTML && !creditHTML.includes('text-muted');
                        }
                        // Si type === 'both', matchesType reste true
                        
                        // Vérifier le montant
                        if (filterData.amounts && filterData.amounts.length > 0) {
                            if (filterData.type === 'both') {
                                // Pour "tous", vérifier dans les deux colonnes
                                const debitHTML = cells[debitColumn] ? cells[debitColumn].innerHTML : '';
                                const creditHTML = cells[creditColumn] ? cells[creditColumn].innerHTML : '';
                                
                                matchesAmount = filterData.amounts.some(filter => {
                                    return (debitHTML && !debitHTML.includes('text-muted') && matchesFilter(debitText, filter.value, filter.operator)) ||
                                           (creditHTML && !creditHTML.includes('text-muted') && matchesFilter(creditText, filter.value, filter.operator));
                                });
                            } else {
                                const targetColumn = filterData.type === 'credit' ? creditColumn : debitColumn;
                                if (cells[targetColumn]) {
                                    const cellHTML = cells[targetColumn].innerHTML;
                                    const cellText = cells[targetColumn].textContent.trim();
                                    if (cellHTML && !cellHTML.includes('text-muted')) {
                                        matchesAmount = filterData.amounts.some(filter => 
                                            matchesFilter(cellText, filter.value, filter.operator)
                                        );
                                    } else {
                                        matchesAmount = false;
                                    }
                                } else {
                                    matchesAmount = false;
                                }
                            }
                        }
                        
                        if (!matchesAmount || !matchesType) {
                            isVisible = false;
                            break;
                        }
                    } else {
                        // Filtrage normal pour les autres champs
                        const fieldIndex = getFieldIndex(field);
                        if (fieldIndex >= 0 && cells[fieldIndex]) {
                            const cellText = cells[fieldIndex].textContent.trim();
                            
                            if (Array.isArray(filterData)) {
                                // Filtres numériques ou de date avec min/max
                                const hasMatch = filterData.some(filter => 
                                    matchesFilter(cellText, filter.value, filter.operator)
                                );
                                if (!hasMatch) {
                                    isVisible = false;
                                    break;
                                }
                            } else {
                                // Filtre simple
                                if (!matchesFilter(cellText, filterData)) {
                                    isVisible = false;
                                    break;
                                }
                            }
                        }
                    }
                }
            }
            
            row.style.display = isVisible ? '' : 'none';
            if (isVisible) visibleCount++;
        });
        
        updateStats(visibleCount);
        highlightTerms();
    }
    
    function getFieldIndex(fieldName) {
        // Mapper les noms de champs aux index de colonnes selon le contexte
        const fieldMapping = {
            // Transactions: ID, Libellé, N° Ordre, Date, Tiers, Débit, Crédit, Montant
            'libelle': 1,
            'tiers': 4,
            'debit': 5,
            'credit': 6,
            'montant': 7,
            'date_creation': 3,
            // Personnes: ID, Civilité, Nom, Prénom, Email, Téléphone, Adresse, Ville
            'nom': 2,
            'prenom': 3,
            'email': 4,
            'ville': 7,
            // Entreprises: ID, Nom, SIRET, SIREN, N° Voie, Rue, Complément, Ville, Code Postal, Pays, Téléphone, Email, Actions
            'nom': 1,
            'siret': 2,
            'siren': 3,
            'ville': 7,
            // Exercices: N°, Libellé, Début, Fin, Statut
            'annee': 1,
            'statut': 4,
            // Utilisateurs: ID, Username, Personne, Roles, Password
            'username': 1,
            // Roles: ID, Libellé, Description
            'description': 2
        };
        
        return fieldMapping[fieldName] || -1;
    }
    
    function highlightTerms() {
        removeHighlights();
        
        const searchTerms = [];
        
        // Collecter les termes du filtre simple
        if (filterInput && filterInput.value.trim()) {
            searchTerms.push(filterInput.value.trim());
        }
        
        // Collecter les termes des filtres détaillés
        Object.values(activeFilters).forEach(filterData => {
            if (Array.isArray(filterData)) {
                filterData.forEach(filter => {
                    if (filter.value && !['min', 'max', 'from', 'to'].includes(filter.operator)) {
                        searchTerms.push(filter.value);
                    }
                });
            } else if (filterData) {
                searchTerms.push(filterData);
            }
        });
        
        if (searchTerms.length === 0) return;
        
        rows.forEach(row => {
            if (row.style.display !== 'none') {
                searchTerms.forEach(term => {
                    highlightInElement(row, term);
                });
            }
        });
    }
    
    function highlightInElement(element, term) {
        const walker = document.createTreeWalker(
            element,
            NodeFilter.SHOW_TEXT,
            null,
            false
        );
        
        const textNodes = [];
        let node;
        
        while (node = walker.nextNode()) {
            if (node.parentElement.tagName !== 'MARK') {
                textNodes.push(node);
            }
        }
        
        textNodes.forEach(textNode => {
            const text = textNode.textContent;
            const normalizedText = normalizeText(text);
            const normalizedTerm = normalizeText(term);
            
            if (normalizedText.includes(normalizedTerm)) {
                const regex = new RegExp(`(${term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
                const highlightedText = text.replace(regex, '<mark>$1</mark>');
                
                if (highlightedText !== text) {
                    const wrapper = document.createElement('span');
                    wrapper.innerHTML = highlightedText;
                    textNode.parentNode.replaceChild(wrapper, textNode);
                }
            }
        });
    }
    
    function removeHighlights() {
        table.querySelectorAll('mark').forEach(mark => {
            const parent = mark.parentNode;
            parent.replaceChild(document.createTextNode(mark.textContent), mark);
            parent.normalize();
        });
    }
    
    // Event listeners pour filtrage simple
    if (filterInput) {
        filterInput.addEventListener('input', filterTable);
        filterInput.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                filterInput.value = '';
                filterTable();
            }
        });
    }
    
    if (clearButton) {
        clearButton.addEventListener('click', function() {
            filterInput.value = '';
            filterTable();
            filterInput.focus();
        });
    }
    
    // Event listeners pour filtrage détaillé
    detailedFilters.forEach(filter => {
        filter.addEventListener('input', function() {
            updateActiveFilters();
            filterTable();
        });
        
        filter.addEventListener('change', function() {
            updateActiveFilters();
            filterTable();
        });
    });
    
    function updateActiveFilters() {
        activeFilters = {};
        
        detailedFilters.forEach(filter => {
            const field = filter.dataset.field;
            const operator = filter.dataset.operator;
            const value = filter.value.trim();
            
            if (value || (operator === 'type' && filter.checked)) {
                if (field === 'montant' && operator === 'type') {
                    // Gérer les filtres de type pour montant
                    if (!activeFilters[field]) {
                        activeFilters[field] = {
                            type: 'both',
                            amounts: [],
                            debitColumn: parseInt(filter.dataset.debitColumn),
                            creditColumn: parseInt(filter.dataset.creditColumn)
                        };
                    }
                    if (filter.checked) {
                        activeFilters[field].type = value;
                    }
                } else if (field === 'montant' && (operator === 'min' || operator === 'max')) {
                    // Gérer les filtres de montant min/max
                    if (!activeFilters[field]) {
                        activeFilters[field] = {
                            type: 'both',
                            amounts: [],
                            debitColumn: parseInt(filter.dataset.debitColumn),
                            creditColumn: parseInt(filter.dataset.creditColumn)
                        };
                    }
                    if (value) {
                        activeFilters[field].amounts.push({ value, operator });
                    }
                } else if (operator && operator !== 'type') {
                    // Filtres avec opérateurs normaux (min/max, from/to)
                    if (!activeFilters[field]) {
                        activeFilters[field] = [];
                    }
                    if (value) {
                        activeFilters[field].push({ value, operator });
                    }
                } else if (!operator) {
                    // Filtres simples
                    if (value) {
                        activeFilters[field] = value;
                    }
                }
            }
        });
        
        // Nettoyer les filtres vides
        Object.keys(activeFilters).forEach(key => {
            const filter = activeFilters[key];
            if (Array.isArray(filter) && filter.length === 0) {
                delete activeFilters[key];
            } else if (typeof filter === 'object' && filter.type === 'both' && filter.amounts.length === 0) {
                delete activeFilters[key];
            }
        });
    }
    
    // Toggle des filtres
    if (toggleFiltersBtn && filtersContainer) {
        toggleFiltersBtn.addEventListener('click', function() {
            const isCollapsed = filtersContainer.style.display === 'none';
            filtersContainer.style.display = isCollapsed ? '' : 'none';
            
            const icon = this.querySelector('i');
            if (isCollapsed) {
                icon.className = 'fas fa-chevron-up';
            } else {
                icon.className = 'fas fa-chevron-down';
            }
        });
    }
    
    // Effacer tous les filtres
    if (clearAllFiltersBtn) {
        clearAllFiltersBtn.addEventListener('click', function() {
            detailedFilters.forEach(filter => {
                filter.value = '';
            });
            activeFilters = {};
            filterTable();
        });
    }
    
    // Raccourcis clavier globaux
    document.addEventListener('keydown', function(e) {
        if (e.ctrlKey && e.key === 'f') {
            e.preventDefault();
            if (filterInput) {
                filterInput.focus();
                filterInput.select();
            } else if (detailedFilters.length > 0) {
                detailedFilters[0].focus();
            }
        }
        
        if (e.key === 'Escape') {
            if (filterInput) {
                filterInput.value = '';
            }
            detailedFilters.forEach(filter => {
                filter.value = '';
            });
            activeFilters = {};
            filterTable();
        }
    });
    
    // Initialisation
    updateStats(totalRows);
});
</script>

<style>
.entity-filter-field {
    transition: all 0.2s ease;
}

.entity-filter-field:focus {
    box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
}

mark {
    background-color: #fff3cd;
    color: #856404;
    padding: 0;
    border-radius: 2px;
}

.card-header .btn {
    padding: 0.25rem 0.5rem;
}

#filtersContainer {
    transition: all 0.3s ease;
}

.form-label.small {
    font-weight: 600;
    color: #495057;
}
</style>