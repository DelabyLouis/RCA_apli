{% extends 'base.html.twig' %}

{% block title %}Modifier - Transaction Livret #{{ transaction.idTransaction }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="fas fa-edit me-2"></i>
                        Modifier la transaction livret #{{ transaction.idTransaction }}
                    </h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label for="libelle" class="form-label">Libellé *</label>
                            <input type="text" class="form-control" id="libelle" name="libelle" 
                                   required value="{{ transaction.libelle }}">
                        </div>
                        
                        <div class="mb-3">
                            <label for="date_transaction" class="form-label">Date de transaction *</label>
                            <input type="datetime-local" class="form-control" id="date_transaction" name="date_transaction" 
                                   required value="{{ transaction.dateTransaction|date('Y-m-d\\TH:i') }}">
                        </div>
                        
                        <div class="mb-3">
                            <label for="montant" class="form-label">Montant *</label>
                            <div class="input-group">
                                <input type="number" step="0.01" class="form-control" id="montant" name="montant" 
                                       required value="{{ transaction.montant }}" placeholder="0.00">
                                <span class="input-group-text">€</span>
                            </div>
                            <div class="form-text">
                                <i class="fas fa-info-circle me-1"></i>
                                Montant positif = Dépôt (entrée) | Montant négatif = Retrait (sortie)
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="exercice" class="form-label">Exercice *</label>
                            <select class="form-select" id="exercice" name="exercice" required>
                                <option value="">Choisir un exercice</option>
                                {% for exercice in exercices %}
                                    <option value="{{ exercice.idExercice }}" 
                                            {{ transaction.exercice and transaction.exercice.idExercice == exercice.idExercice ? 'selected' : '' }}>
                                        {{ exercice.libelle }}
                                        {% if exercice.isClos %}
                                            (CLÔTURÉ)
                                        {% endif %}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        
                        <!-- Informations non modifiables -->
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h6 class="card-title">Informations non modifiables</h6>
                                <div class="row">
                                    <div class="col-md-6">
                                        <p class="mb-1"><strong>N° Ordre :</strong> {{ transaction.numeroOrdre }}</p>
                                        <p class="mb-1"><strong>Type de compte :</strong> 
                                            <span class="badge bg-info">Livret</span>
                                        </p>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="mb-1"><strong>Tiers :</strong> 
                                            <span class="badge bg-secondary">
                                                <i class="fas fa-piggy-bank"></i> Livret d'épargne
                                            </span>
                                        </p>
                                        <p class="mb-0"><strong>Type de transaction :</strong>
                                            <span class="badge bg-info">
                                                <i class="fas fa-piggy-bank"></i> Livret d'épargne
                                            </span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="alert alert-warning">
                            <i class="fas fa-sync-alt me-2"></i>
                            <strong>Note importante :</strong> Cette modification affectera également la transaction liée sur le compte courant. 
                            Les changements seront synchronisés entre le livret et le compte courant.
                        </div>
                        
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>Modifications autorisées :</strong> Libellé, montant, date, exercice<br>
                            <strong>Non modifiables :</strong> Type de transaction (spécifique au livret), tiers
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_livret_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save"></i> Enregistrer les modifications
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}