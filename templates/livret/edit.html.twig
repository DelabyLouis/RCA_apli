{% extends 'base.html.twig' %}

{% block title %}Modifier - Transaction Livret #{{ transaction.idTransaction }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="fas fa-edit me-2"></i>
                        Modifier la transaction livret #{{ transaction.idTransaction }}
                    </h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label for="libelle" class="form-label">Libellé *</label>
                            <input type="text" class="form-control" id="libelle" name="libelle" 
                                   required value="{{ transaction.libelle }}">
                        </div>
                        
                        <div class="mb-3">
                            <label for="date_transaction" class="form-label">Date de transaction *</label>
                            <input type="datetime-local" class="form-control" id="date_transaction" name="date_transaction" 
                                   required value="{{ transaction.dateTransaction|date('Y-m-d\\TH:i') }}">
                        </div>
                        
                        <div class="mb-3">
                            <label for="description" class="form-label">Description</label>
                            <textarea class="form-control" id="description" name="description" 
                                      rows="3" placeholder="Description optionnelle...">{{ transaction.description ?? '' }}</textarea>
                        </div>
                        
                        <!-- Informations non modifiables -->
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h6 class="card-title">Informations non modifiables</h6>
                                <div class="row">
                                    <div class="col-md-6">
                                        <p class="mb-1"><strong>N° Ordre :</strong> {{ transaction.numeroOrdre }}</p>
                                        <p class="mb-1"><strong>Type de compte :</strong> 
                                            <span class="badge bg-info">Livret</span>
                                        </p>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="mb-1"><strong>Montant :</strong> 
                                            <span class="badge bg-{{ transaction.montant >= 0 ? 'success' : 'danger' }}">
                                                {{ transaction.montant|number_format(2, ',', ' ') }} €
                                            </span>
                                        </p>
                                        <p class="mb-1"><strong>Type d'opération :</strong>
                                            {% if transaction.montant >= 0 %}
                                                <span class="badge bg-success">
                                                    <i class="fas fa-arrow-down"></i> Dépôt
                                                </span>
                                            {% else %}
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-arrow-up"></i> Retrait
                                                </span>
                                            {% endif %}
                                        </p>
                                        <p class="mb-0"><strong>Exercice :</strong> {{ transaction.exercice ? transaction.exercice.libelle : 'Non défini' }}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>Note :</strong> Cette modification affectera uniquement la transaction du livret. 
                            La transaction liée sur le compte courant ne sera pas modifiée.
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_livret_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save"></i> Enregistrer les modifications
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}