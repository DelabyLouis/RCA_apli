{% extends 'base.html.twig' %}

{% block title %}Modifier Livret {{ livret.nom }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0">
                        <i class="fas fa-edit me-2"></i>
                        Modifier le livret {{ livret.nom }}
                    </h4>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_label(form.nom) }}
                            {{ form_widget(form.nom) }}
                            {{ form_errors(form.nom) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_label(form.date_creation) }}
                            {{ form_widget(form.date_creation) }}
                            {{ form_errors(form.date_creation) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_label(form.solde_initial) }}
                            {{ form_widget(form.solde_initial) }}
                            {{ form_errors(form.solde_initial) }}
                            <div class="form-text">
                                <i class="fas fa-exclamation-triangle text-warning"></i>
                                Attention : modifier le solde initial affectera le calcul du solde actuel
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Exercice</label>
                            <div class="input-group">
                                <input type="text" class="form-control" value="{{ livret.exercice.libelle }}" readonly>
                                <span class="input-group-text">
                                    <i class="fas fa-lock text-warning" title="Exercice verrouillé"></i>
                                </span>
                            </div>
                            <div class="form-text">L'exercice ne peut pas être modifié après création</div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        {{ form_label(form.description) }}
                        {{ form_widget(form.description) }}
                        {{ form_errors(form.description) }}
                    </div>
                    
                    <!-- Informations actuelles du livret -->
                    <div class="alert alert-light">
                        <h6><i class="fas fa-info-circle me-1"></i> Informations actuelles :</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <strong>Solde actuel :</strong> 
                                <span class="badge bg-{{ livret.soldeActuel >= 0 ? 'success' : 'danger' }}">
                                    {{ livret.soldeActuel|number_format(2, ',', ' ') }} €
                                </span>
                            </div>
                            <div class="col-md-6">
                                <strong>Nombre de transactions :</strong> {{ livret.transactionsLivret|length }}
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-between">
                        <a href="{{ path('app_livret_show', {'id_livret': livret.idLivret}) }}" 
                           class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Retour
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>Enregistrer les modifications
                        </button>
                    </div>
                    
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}