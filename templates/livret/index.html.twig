{% extends 'base.html.twig' %}

{% block title %}Livret d'épargne{% endblock %}

{% block body %}
    {{ include('components/inline_edit_styles.html.twig') }}
    
    <div class="container-fluid mt-4">
        <h1 class="mb-4">Gestion du Livret d'épargne</h1>
        
        {% if exercice_filter %}
            <div class="alert alert-info">
                <i class="fas fa-filter me-2"></i>Transactions du livret filtrées pour l'exercice : 
                <strong>{{ exercice_filter.libelle }}</strong>
                <a href="{{ path('app_livret_index') }}" class="btn btn-outline-secondary btn-sm ms-3">
                    <i class="fas fa-times me-1"></i>Voir toutes les transactions
                </a>
            </div>
        {% endif %}
        
        <div class="row mb-3">
            <div class="col">
                <a href="{{ path('app_livret_transfert') }}" class="btn btn-success">
                    <i class="fas fa-exchange-alt me-2"></i>Nouveau transfert
                </a>
            </div>
        </div>
        
        <!-- Informations du livret -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-piggy-bank me-2"></i>Informations du livret</h5>
            </div>
            <div class="card-body">
                <!-- Solde actuel en gros -->
                <div class="row mb-4">
                    <div class="col-12 text-center">
                        <h2 class="mb-2">Solde actuel</h2>
                        <h1 class="display-4 fw-bold text-{{ livret.solde_actuel >= 0 ? 'success' : 'danger' }}">
                            {{ livret.solde_actuel|number_format(2, ',', ' ') }} €
                        </h1>
                    </div>
                </div>
                
                <!-- Filtres -->
                <hr class="my-4">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="filter-libelle" class="form-label">Libellé</label>
                        <input type="text" class="form-control" id="filter-libelle" placeholder="Rechercher par libellé...">
                    </div>
                    
                    <div class="col-md-3 mb-3">
                        <label for="filter-type-montant" class="form-label"><i class="fas fa-exchange-alt me-1"></i>Type d'opération</label>
                        <select class="form-select" id="filter-type-montant">
                            <option value="">Toutes</option>
                            <option value="depot">🟢 Dépôts uniquement</option>
                            <option value="retrait">🔴 Retraits uniquement</option>
                        </select>
                    </div>
                    
                    <div class="col-md-3 mb-3">
                        <label for="filter-date" class="form-label">Date de transaction</label>
                        <div class="input-group">
                            <input type="date" class="form-control" id="filter-date-min" placeholder="Date min">
                            <input type="date" class="form-control" id="filter-date-max" placeholder="Date max">
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-12">
                        <button type="button" class="btn btn-primary me-2" id="apply-filters">
                            <i class="fas fa-search me-1"></i>Filtrer
                        </button>
                        <button type="button" class="btn btn-outline-secondary" id="clear-filters">
                            <i class="fas fa-times me-1"></i>Effacer les filtres
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Libellé</th>
                        <th>N° Ordre</th>
                        <th>Date</th>
                        <th>Dépôt</th>
                        <th>Retrait</th>
                        <th>Solde</th>
                        <th>Exercice</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for item in transactions_avec_solde %}
                    {% set transaction = item.transaction %}
                    {% set solde_cumule = item.solde_cumule %}
                    {% set is_exercice_clos = transaction.exercice and transaction.exercice.isClos %}
                    <tr data-id="{{ transaction.idTransaction }}">
                        <td>{{ transaction.idTransaction }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="libelle" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.libelleComplet }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="numero_ordre" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.numeroOrdre }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="date_transaction" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.dateTransaction ? transaction.dateTransaction|date('Y-m-d') : '' }}</td>
                        <td class="montant-cell {% if not is_exercice_clos %}editable-field{% endif %} text-end" 
                            data-field="montant" 
                            data-type="debit" 
                            data-current-value="{{ transaction.montant }}"
                            {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>
                            {% if transaction.montant >= 0 %}
                                <span class="badge bg-success fs-6 fw-bold">{{ transaction.montant|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="montant-cell {% if not is_exercice_clos %}editable-field{% endif %} text-end" 
                            data-field="montant" 
                            data-type="credit" 
                            data-current-value="{{ transaction.montant }}"
                            {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>
                            {% if transaction.montant < 0 %}
                                <span class="badge bg-danger fs-6 fw-bold">{{ (transaction.montant * -1)|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="solde-cell text-end" {% if solde_cumule < 0 %}style="border: 3px solid #dc3545 !important; background-color: rgba(220, 53, 69, 0.1) !important;"{% endif %}>
                            {% if solde_cumule >= 0 %}
                                <span class="text-success fw-bold">{{ solde_cumule|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="fw-bold" style="color: #dc3545 !important;">
                                    <i class="fas fa-exclamation-triangle me-1" style="color: #dc3545 !important;"></i>{{ solde_cumule|number_format(2, ',', ' ') }} €
                                </span>
                            {% endif %}
                        </td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="exercice" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.exercice ? transaction.exercice.libelle : '' }}</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_livret_show', {'id': transaction.idTransaction}) }}" class="btn btn-info btn-sm" title="Voir les détails">
                                    <i class="fas fa-eye"></i>
                                </a>
                                {% if transaction.exercice and transaction.exercice.isClos %}
                                    <button class="btn btn-warning btn-sm" disabled title="Exercice clôturé - Modification impossible">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-danger btn-sm" disabled title="Exercice clôturé - Suppression impossible">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                {% else %}
                                    <a href="{{ path('app_livret_edit', {'id': transaction.idTransaction}) }}" class="btn btn-warning btn-sm" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn btn-danger btn-sm delete-btn" data-id="{{ transaction.idTransaction }}" title="Supprimer">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                {% endif %}
                            </div>
                        </td>
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="11" class="text-center">Aucune transaction trouvée</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Initialisation édition inline pour livret (page principale)');
            
            // Gestion de l'édition inline simple
            document.querySelectorAll('.editable-field').forEach(function(element) {
                element.addEventListener('click', function() {
                    if (this.querySelector('input') || this.querySelector('select') || this.querySelector('textarea')) {
                        return;
                    }
                    
                    const field = this.dataset.field;
                    const currentValue = this.textContent.trim();
                    const transactionId = this.closest('tr').dataset.id;
                    
                    console.log('Édition de:', field, 'pour transaction livret:', transactionId);
                    
                    if (field === 'date_transaction') {
                        let isoValue = '';
                        if (currentValue && currentValue !== '') {
                            const parts = currentValue.split('/');
                            if (parts.length === 3) {
                                isoValue = parts[2] + '-' + parts[1].padStart(2, '0') + '-' + parts[0].padStart(2, '0');
                            } else {
                                isoValue = currentValue; // Déjà au format YYYY-MM-DD
                            }
                        }
                        
                        this.innerHTML = '<input type="date" class="form-control form-control-sm" value="' + isoValue + '" style="min-width: 150px;">';
                    } else if (field === 'description') {
                        this.innerHTML = '<textarea class="form-control form-control-sm" style="min-width: 200px; height: 60px;">' + currentValue + '</textarea>';
                    } else {
                        this.innerHTML = '<input type="text" class="form-control form-control-sm" value="' + currentValue + '" style="min-width: 150px;">';
                    }
                    
                    const input = this.querySelector('input, textarea');
                    if (input) {
                        input.focus();
                        if (input.tagName === 'INPUT') {
                            input.select();
                        }
                        
                        // Sauvegarder au blur ou Entrée
                        function saveChanges() {
                            const newValue = input.value;
                            if (newValue !== currentValue) {
                                console.log('Sauvegarde:', field, '=', newValue);
                                
                                // Préparer les données
                                const formData = new FormData();
                                formData.append('field', field);
                                formData.append('value', newValue);
                                
                                // URL pour le livret
                                const url = '/livret/' + transactionId + '/update-field';
                                
                                fetch(url, {
                                    method: 'POST',
                                    body: formData,
                                    headers: {
                                        'X-Requested-With': 'XMLHttpRequest'
                                    }
                                })
                                .then(response => response.json())
                                .then(data => {
                                    if (data.success) {
                                        element.textContent = data.display_value || newValue;
                                        element.classList.add('text-success');
                                        setTimeout(() => element.classList.remove('text-success'), 1000);
                                    } else {
                                        alert('Erreur: ' + (data.error || 'Impossible de sauvegarder'));
                                        element.textContent = currentValue;
                                    }
                                })
                                .catch(error => {
                                    console.error('Erreur:', error);
                                    element.textContent = currentValue;
                                });
                            } else {
                                element.textContent = currentValue;
                            }
                        }
                        
                        input.addEventListener('blur', saveChanges);
                        input.addEventListener('keydown', function(e) {
                            if (e.key === 'Enter' && !e.shiftKey) {
                                e.preventDefault();
                                saveChanges();
                            } else if (e.key === 'Escape') {
                                element.textContent = currentValue;
                            }
                        });
                    }
                });
            });
            
            // Gestion de la suppression
            document.querySelectorAll('.delete-btn').forEach(function(button) {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    if (!confirm('Êtes-vous sûr de vouloir supprimer cette transaction ?\\nCela supprimera aussi la transaction associée sur le compte courant.')) {
                        return;
                    }
                    
                    const transactionId = this.dataset.id;
                    const row = this.closest('tr');
                    
                    const url = '/livret/' + transactionId + '/delete-ajax';
                    
                    fetch(url, {
                        method: 'DELETE',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            row.remove();
                            // Réafficher "Aucune transaction" si plus de lignes
                            const tbody = document.querySelector('tbody');
                            if (tbody.children.length === 0) {
                                location.reload(); // Recharger pour afficher le message "aucune transaction"
                            }
                        } else {
                            alert('Erreur: ' + (data.error || 'Impossible de supprimer'));
                        }
                    })
                    .catch(error => {
                        console.error('Erreur:', error);
                        alert('Erreur de connexion');
                    });
                });
            });
            
            // Filtres (logique de base)
            document.getElementById('apply-filters')?.addEventListener('click', function() {
                const libelle = document.getElementById('filter-libelle').value.toLowerCase();
                const type = document.getElementById('filter-type-montant').value;
                const dateMin = document.getElementById('filter-date-min').value;
                const dateMax = document.getElementById('filter-date-max').value;
                
                const rows = document.querySelectorAll('tbody tr[data-id]');
                
                rows.forEach(function(row) {
                    let visible = true;
                    
                    // Filtre libellé
                    if (libelle) {
                        const libelleCell = row.querySelector('td:nth-child(2)').textContent.toLowerCase();
                        if (!libelleCell.includes(libelle)) {
                            visible = false;
                        }
                    }
                    
                    // Filtre type
                    if (type) {
                        const debitCell = row.querySelector('td:nth-child(6)');
                        const creditCell = row.querySelector('td:nth-child(7)');
                        const hasDebit = !debitCell.textContent.includes('-');
                        const hasCredit = !creditCell.textContent.includes('-');
                        
                        if (type === 'depot' && !hasCredit) {
                            visible = false;
                        } else if (type === 'retrait' && !hasDebit) {
                            visible = false;
                        }
                    }
                    
                    // Filtre date
                    if (dateMin || dateMax) {
                        const dateCell = row.querySelector('td:nth-child(4)').textContent;
                        if (dateMin && dateCell < dateMin) visible = false;
                        if (dateMax && dateCell > dateMax) visible = false;
                    }
                    
                    row.style.display = visible ? '' : 'none';
                });
            });
            
            document.getElementById('clear-filters')?.addEventListener('click', function() {
                document.getElementById('filter-libelle').value = '';
                document.getElementById('filter-type-montant').value = '';
                document.getElementById('filter-date-min').value = '';
                document.getElementById('filter-date-max').value = '';
                
                document.querySelectorAll('tbody tr[data-id]').forEach(function(row) {
                    row.style.display = '';
                });
            });
        });
    </script>

{% endblock %}