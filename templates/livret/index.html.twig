{% extends 'base.html.twig' %}

{% block title %}
    {% if exercice_filter %}
        Livret - {{ exercice_filter.libelle }}
    {% else %}
        Livret d'épargne
    {% endif %}
{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <!-- En-tête -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">
                <i class="fas fa-piggy-bank me-2"></i>
                {% if exercice_filter %}
                    Livret - {{ exercice_filter.libelle }}
                {% else %}
                    Livret d'épargne
                {% endif %}
            </h1>
            {% if exercice_filter %}
                <p class="text-muted small mb-0">
                    Période : {{ exercice_filter.dateDebut|date('d/m/Y') }} - {{ exercice_filter.dateFin|date('d/m/Y') }}
                </p>
            {% endif %}
        </div>
        <div>
            <a href="{{ path('app_livret_transfert') }}" class="btn btn-success me-2">
                <i class="fas fa-exchange-alt"></i> Nouveau transfert
            </a>
            {% if exercice_filter %}
                <a href="{{ path('app_livret_index') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-list"></i> Toutes les transactions
                </a>
            {% else %}
                <div class="dropdown d-inline-block">
                    <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="fas fa-filter"></i> Filtrer par exercice
                    </button>
                    <ul class="dropdown-menu">
                        {% for exercice in exercices %}
                            <li>
                                <a class="dropdown-item" href="{{ path('app_livret_index', {exercice_id: exercice.idExercice}) }}">
                                    {{ exercice.libelle }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Informations du livret -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h5 class="card-title">Solde initial</h5>
                    <h3 class="text-info">{{ livret.solde_initial|number_format(2, ',', ' ') }} €</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h5 class="card-title">Solde actuel</h5>
                    <h3 class="text-{{ livret.solde_actuel >= 0 ? 'success' : 'danger' }}">
                        {{ livret.solde_actuel|number_format(2, ',', ' ') }} €
                    </h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h5 class="card-title">Nombre d'opérations</h5>
                    <h3 class="text-primary">{{ transactions_avec_solde|length }}</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h5 class="card-title">Variation totale</h5>
                    {% set variation = livret.solde_actuel - livret.solde_initial %}
                    <h3 class="text-{{ variation >= 0 ? 'success' : 'danger' }}">
                        {% if variation >= 0 %}+{% endif %}{{ variation|number_format(2, ',', ' ') }} €
                    </h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Historique des transactions -->
    <div class="card">
        <div class="card-body">
            {% if transactions_avec_solde|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Libellé</th>
                                <th>Description</th>
                                <th>Date</th>
                                <th>Type</th>
                                <th>Montant</th>
                                <th>Solde après opération</th>
                                <th>Transaction compte courant</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for transaction_data in transactions_avec_solde %}
                                {% set transaction = transaction_data.transaction %}
                                {% set solde = transaction_data.solde_cumule %}
                                <tr data-id="{{ transaction.idTransaction }}">
                                    <td>{{ transaction.idTransaction }}</td>
                                    <td class="editable-field" data-field="libelle">{{ transaction.libelle }}</td>
                                    <td class="editable-field" data-field="description">
                                        {{ transaction.description ?? '' }}
                                    </td>
                                    <td class="editable-field" data-field="date_transaction">
                                        {{ transaction.dateTransaction|date('Y-m-d') }}
                                    </td>
                                    <td>
                                        {% if transaction.montant|number_format > 0 %}
                                            <span class="badge bg-success">
                                                <i class="fas fa-arrow-down"></i> Dépôt
                                            </span>
                                        {% else %}
                                            <span class="badge bg-danger">
                                                <i class="fas fa-arrow-up"></i> Retrait
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="badge bg-{{ transaction.montant|number_format >= 0 ? 'success' : 'danger' }}">
                                            {{ transaction.montant|number_format(2, ',', ' ') }} €
                                        </span>
                                    </td>
                                    <td>
                                        <strong class="text-{{ solde >= 0 ? 'success' : 'danger' }}">
                                            {{ solde|number_format(2, ',', ' ') }} €
                                        </strong>
                                    </td>
                                    <td>
                                        {% if transaction.isTransfert %}
                                            <a href="{{ path('app_transaction_show', {'id_transaction': transaction.transactionLieeId}) }}" 
                                               class="btn btn-sm btn-outline-info">
                                                <i class="fas fa-link"></i> 
                                                #{{ transaction.transactionLieeId }}
                                            </a>
                                        {% else %}
                                            <span class="text-muted">Non liée</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-danger delete-transaction" 
                                                    data-id="{{ transaction.idTransaction }}" title="Supprimer">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                
                <div class="mt-3 text-muted">
                    <small>Total : {{ transactions_avec_solde|length }} transaction{{ transactions_avec_solde|length > 1 ? 's' : '' }}</small>
                </div>
            {% else %}
                <div class="text-center py-5">
                    <i class="fas fa-piggy-bank fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">Aucune transaction sur le livret</h5>
                    <p class="text-muted">Le livret contient uniquement le solde initial.</p>
                    <a href="{{ path('app_livret_transfert') }}" class="btn btn-success">
                        <i class="fas fa-exchange-alt"></i> Effectuer un transfert
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    console.log('Initialisation édition inline pour livret');
    
    // Gestion de l'édition inline simple
    document.querySelectorAll('.editable-field').forEach(function(element) {
        element.addEventListener('click', function() {
            if (this.querySelector('input') || this.querySelector('textarea')) {
                return;
            }
            
            const field = this.dataset.field;
            const currentValue = this.textContent.trim();
            const transactionId = this.closest('tr').dataset.id;
            
            console.log('Édition de:', field, 'pour transaction livret:', transactionId);
            
            if (field === 'date_transaction') {
                let isoValue = '';
                if (currentValue && currentValue !== '') {
                    isoValue = currentValue; // Déjà au format YYYY-MM-DD
                }
                
                this.innerHTML = '<input type="date" class="form-control form-control-sm" value="' + isoValue + '" style="min-width: 150px;">';
            } else if (field === 'description') {
                this.innerHTML = '<textarea class="form-control form-control-sm" style="min-width: 200px; height: 60px;">' + currentValue + '</textarea>';
            } else {
                this.innerHTML = '<input type="text" class="form-control form-control-sm" value="' + currentValue + '" style="min-width: 150px;">';
            }
            
            const input = this.querySelector('input, textarea');
            if (input) {
                input.focus();
                if (input.tagName === 'INPUT') {
                    input.select();
                }
                
                function saveChanges() {
                    const newValue = input.value;
                    if (newValue !== currentValue) {
                        console.log('Sauvegarde:', field, '=', newValue);
                        
                        const formData = new FormData();
                        formData.append('field', field);
                        formData.append('value', newValue);
                        
                        const url = '/livret/' + transactionId + '/update-field';
                        
                        fetch(url, {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                element.textContent = data.display_value || newValue;
                                element.classList.add('text-success');
                                setTimeout(() => element.classList.remove('text-success'), 1000);
                            } else {
                                alert('Erreur: ' + (data.error || 'Impossible de sauvegarder'));
                                element.textContent = currentValue;
                            }
                        })
                        .catch(error => {
                            console.error('Erreur:', error);
                            element.textContent = currentValue;
                        });
                    } else {
                        element.textContent = currentValue;
                    }
                }
                
                input.addEventListener('blur', saveChanges);
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        saveChanges();
                    } else if (e.key === 'Escape') {
                        element.textContent = currentValue;
                    }
                });
            }
        });
    });
    
    // Gestion de la suppression
    document.querySelectorAll('.delete-transaction').forEach(function(button) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            
            if (!confirm('Êtes-vous sûr de vouloir supprimer cette transaction ?\\nCela supprimera aussi la transaction associée sur le compte courant.')) {
                return;
            }
            
            const transactionId = this.dataset.id;
            const row = this.closest('tr');
            
            fetch('/livret/' + transactionId + '/delete-ajax', {
                method: 'DELETE',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    row.remove();
                    const tbody = document.querySelector('tbody');
                    if (tbody.children.length === 0) {
                        location.reload();
                    }
                } else {
                    alert('Erreur: ' + (data.error || 'Impossible de supprimer'));
                }
            })
            .catch(error => {
                console.error('Erreur:', error);
                alert('Erreur de connexion');
            });
        });
    });
});
</script>

{% endblock %}