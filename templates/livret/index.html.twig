{% extends 'base.html.twig' %}

{% block title %}Livret d'épargne{% endblock %}

{% block body %}
    {{ include('components/inline_edit_styles.html.twig') }}
    
    <div class="container-fluid mt-4">
        <h1 class="mb-4">Gestion du Livret d'épargne</h1>
        
        <!-- Zone de notifications pour les suppressions -->
        <div id="notifications" style="position: fixed; top: 20px; right: 20px; z-index: 9999; min-width: 300px;"></div>
        
        {% if exercice_filter %}
            <div class="alert alert-info">
                <i class="fas fa-filter me-2"></i>Transactions du livret filtrées pour l'exercice : 
                <strong>{{ exercice_filter.libelle }}</strong>
                <a href="{{ path('app_livret_index') }}" class="btn btn-outline-secondary btn-sm ms-3">
                    <i class="fas fa-times me-1"></i>Voir toutes les transactions
                </a>
            </div>
        {% endif %}
        
        <div class="row mb-3">
            <div class="col">
                <a href="{{ path('app_livret_transfert') }}" class="btn btn-success">
                    <i class="fas fa-exchange-alt me-2"></i>Nouveau transfert
                </a>
            </div>
        </div>
        
        <!-- Informations du livret -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-piggy-bank me-2"></i>Informations du livret</h5>
            </div>
            <div class="card-body">
                <!-- Solde actuel en gros -->
                <div class="row mb-4">
                    <div class="col-12 text-center">
                        <h2 class="mb-2 text-muted">Solde actuel</h2>
                        <h1 class="display-4 fw-bold text-{{ livret.solde_actuel >= 0 ? 'success' : 'danger' }}">
                            <i class="fas fa-piggy-bank me-3"></i>{{ livret.solde_actuel|number_format(2, ',', ' ') }} €
                        </h1>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Filtres personnalisés -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filtres</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Filtre Libellé -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-libelle" class="form-label">Libellé</label>
                        <input type="text" class="form-control" id="filter-libelle" placeholder="Rechercher par libellé...">
                    </div>
                    
                    <!-- Filtre Type d'opération -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-type-montant" class="form-label"><i class="fas fa-exchange-alt me-1"></i>Type d'opération</label>
                        <div class="input-group">
                            <select class="form-select" id="filter-type-montant" style="max-width: 160px;">
                                <option value="">Toutes</option>
                                <option value="depot">🟢 Dépôts (Entrées)</option>
                                <option value="retrait">🔴 Retraits (Sorties)</option>
                            </select>
                            <input type="number" class="form-control" id="filter-montant-min" placeholder="Min" step="0.01" style="max-width: 100px;">
                            <input type="number" class="form-control" id="filter-montant-max" placeholder="Max" step="0.01" style="max-width: 100px;">
                        </div>
                        <small class="text-muted">Filtre combiné : type + montant min/max</small>
                    </div>
                    
                    <!-- Filtre Date -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-date" class="form-label">Date de transaction</label>
                        <div class="input-group">
                            <input type="date" class="form-control" id="filter-date-min" placeholder="Date min">
                            <input type="date" class="form-control" id="filter-date-max" placeholder="Date max">
                        </div>
                        <small class="text-muted">Période : date min/max</small>
                    </div>
                    
                    <!-- Filtre Exercice -->
                    <div class="col-md-3 mb-3">
                        <label for="filter-exercice" class="form-label">Exercice</label>
                        <select class="form-select" id="filter-exercice">
                            <option value="">Tous les exercices</option>
                            {% for exercice in exercices %}
                                <option value="{{ exercice.idExercice }}">{{ exercice.libelle }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-12">
                        <button type="button" class="btn btn-primary me-2" id="apply-filters">
                            <i class="fas fa-search me-1"></i>Filtrer
                        </button>
                        <button type="button" class="btn btn-outline-secondary" id="clear-filters">
                            <i class="fas fa-times me-1"></i>Effacer les filtres
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="table table-striped table-hover transactions-table">
                <thead class="table-dark">
                    <tr>
                        <th>Libellé</th>
                        <th>N° Ordre</th>
                        <th>Date</th>
                        <th>Dépôt (Entrée)</th>
                        <th>Retrait (Sortie)</th>
                        <th>Solde</th>
                        <th>Exercice</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% set current_exercice = null %}
                {% for item in transactions_avec_solde %}
                    {% set transaction = item.transaction %}
                    {% set solde_cumule = item.solde_cumule %}
                    {% set is_exercice_clos = transaction.exercice and transaction.exercice.isClos %}
                    
                    {# Affichage du séparateur d'exercice si changement #}
                    {% if transaction.exercice and current_exercice != transaction.exercice.idExercice %}
                        {% set current_exercice = transaction.exercice.idExercice %}
                        <tr class="exercice-separator" data-exercice-id="{{ transaction.exercice.idExercice }}" title="Cliquer pour enrouler/dérouler les transactions de cet exercice">
                            <td class="exercice-title">
                                <i class="fas fa-calendar-alt me-2"></i>
                                {{ transaction.exercice.libelle }}
                                {% if transaction.exercice.isClos %}
                                    <span class="badge bg-danger ms-2">
                                        <i class="fas fa-lock me-1"></i>CLÔTURÉ
                                    </span>
                                {% else %}
                                    <span class="badge bg-success ms-2">
                                        <i class="fas fa-unlock me-1"></i>EN COURS
                                    </span>
                                {% endif %}
                            </td>
                            <td class="exercice-info"></td>
                            <td class="exercice-info"></td>
                            <td class="exercice-info"></td>
                            <td class="exercice-info"></td>
                            <td class="exercice-montant text-end">
                                <span class="exercice-montant-collapsed" style="display: none;">
                                    {% if solde_cumule >= 0 %}
                                        <span class="text-success fw-bold">{{ solde_cumule|number_format(2, ',', ' ') }} €</span>
                                    {% else %}
                                        <span class="fw-bold" style="color: #dc3545 !important;">
                                            <i class="fas fa-exclamation-triangle me-1" style="color: #dc3545 !important;"></i>{{ solde_cumule|number_format(2, ',', ' ') }} €
                                        </span>
                                    {% endif %}
                                </span>
                            </td>
                            <td class="exercice-info"></td>
                            <td class="exercice-actions text-end">
                                <span class="collapse-indicator">
                                    <i class="fas fa-chevron-up"></i>
                                </span>
                            </td>
                        </tr>
                    {% endif %}
                    
                    <tr data-id="{{ transaction.idTransaction }}" data-exercice-id="{{ transaction.exercice ? transaction.exercice.idExercice : '' }}" class="transaction-row">
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="libelle" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.libelle }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="numero_ordre" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.numeroOrdre }}</td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="date_transaction" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.dateTransaction ? transaction.dateTransaction|date('Y-m-d') : '' }}</td>
                        <td class="montant-cell {% if not is_exercice_clos and transaction.montant >= 0 %}editable-field{% endif %} text-end" 
                            data-field="montant" 
                            data-type="depot" 
                            data-current-value="{{ transaction.montant }}"
                            {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>
                            {% if transaction.montant >= 0 %}
                                <span class="badge bg-success text-dark fs-6 fw-bold">{{ transaction.montant|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="montant-cell {% if not is_exercice_clos and transaction.montant < 0 %}editable-field{% endif %} text-end" 
                            data-field="montant" 
                            data-type="retrait" 
                            data-current-value="{{ transaction.montant }}"
                            {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>
                            {% if transaction.montant < 0 %}
                                <span class="badge bg-danger text-dark fs-6 fw-bold">{{ (transaction.montant * -1)|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="solde-cell text-end" {% if solde_cumule < 0 %}style="border: 3px solid #dc3545 !important; background-color: rgba(220, 53, 69, 0.1) !important;"{% endif %}>
                            {% if solde_cumule >= 0 %}
                                <span class="text-success fw-bold">{{ solde_cumule|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="fw-bold" style="color: #dc3545 !important;">
                                    <i class="fas fa-exclamation-triangle me-1" style="color: #dc3545 !important;"></i>{{ solde_cumule|number_format(2, ',', ' ') }} €
                                </span>
                            {% endif %}
                        </td>
                        <td class="{% if not is_exercice_clos %}editable-field{% endif %}" data-field="exercice" {% if is_exercice_clos %}title="Exercice clôturé - Modification impossible"{% endif %}>{{ transaction.exercice ? transaction.exercice.libelle : '' }}</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_livret_show', {'id': transaction.idTransaction}) }}" class="btn btn-info btn-sm" title="Voir les détails">
                                    <i class="fas fa-eye"></i>
                                </a>
                                {% if transaction.exercice and transaction.exercice.isClos %}
                                    <button class="btn btn-warning btn-sm" disabled title="Exercice clôturé - Modification impossible">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-danger btn-sm" disabled title="Exercice clôturé - Suppression impossible">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                {% else %}
                                    <a href="{{ path('app_livret_edit', {'id': transaction.idTransaction}) }}" class="btn btn-warning btn-sm" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn btn-danger btn-sm delete-btn" data-id="{{ transaction.idTransaction }}" title="Supprimer">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center">Aucune transaction trouvée</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <script>
        // Fonction pour afficher une notification
        function showNotification(message, type = 'danger') {
            const notificationsContainer = document.getElementById('notifications');
            
            const notification = document.createElement('div');
            notification.className = `alert alert-${type} alert-dismissible fade show`;
            notification.innerHTML = `
                <strong>${type === 'success' ? '✅ Succès:' : '❌ Erreur:'}</strong> ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            
            notificationsContainer.appendChild(notification);
            
            // Supprimer automatiquement après 5 secondes
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.remove();
                }
            }, 5000);
        }

        document.addEventListener('DOMContentLoaded', function() {
            console.log('Initialisation de la page livret');
            
            // Gestion des filtres avancés
            const filterLibelle = document.getElementById('filter-libelle');
            const filterTypeMontant = document.getElementById('filter-type-montant');
            const filterMontantMin = document.getElementById('filter-montant-min');
            const filterMontantMax = document.getElementById('filter-montant-max');
            const filterDateMin = document.getElementById('filter-date-min');
            const filterDateMax = document.getElementById('filter-date-max');
            const filterExercice = document.getElementById('filter-exercice');
            const applyFiltersBtn = document.getElementById('apply-filters');
            const clearFiltersBtn = document.getElementById('clear-filters');
            
            function applyFilters() {
                console.log('Application des filtres');
                
                const libelle = filterLibelle.value.toLowerCase().trim();
                const typeMontant = filterTypeMontant.value;
                const montantMin = parseFloat(filterMontantMin.value) || null;
                const montantMax = parseFloat(filterMontantMax.value) || null;
                const dateMin = filterDateMin.value;
                const dateMax = filterDateMax.value;
                const exerciceId = filterExercice.value;
                
                const allRows = document.querySelectorAll('tbody tr');
                let visibleCount = 0;
                
                allRows.forEach(function(row) {
                    if (row.classList.contains('exercice-separator')) {
                        row.style.display = '';
                        return;
                    }
                    
                    if (!row.dataset.id) {
                        return;
                    }
                    
                    let visible = true;
                    
                    // Filtre libellé
                    if (libelle) {
                        const libelleCell = row.querySelector('td:first-child').textContent.toLowerCase();
                        if (!libelleCell.includes(libelle)) {
                            visible = false;
                        }
                    }
                    
                    // Filtre type de montant
                    if (typeMontant) {
                        const depotCell = row.querySelector('td:nth-child(4)');
                        const retraitCell = row.querySelector('td:nth-child(5)');
                        const hasDepot = !depotCell.textContent.includes('-');
                        const hasRetrait = !retraitCell.textContent.includes('-');
                        
                        if (typeMontant === 'depot' && !hasDepot) {
                            visible = false;
                        } else if (typeMontant === 'retrait' && !hasRetrait) {
                            visible = false;
                        }
                    }
                    
                    // Filtre montant min/max
                    if (visible && (montantMin !== null || montantMax !== null)) {
                        const depotText = row.querySelector('td:nth-child(4)').textContent;
                        const retraitText = row.querySelector('td:nth-child(5)').textContent;
                        
                        let montant = 0;
                        if (!depotText.includes('-')) {
                            montant = parseFloat(depotText.replace(/[^0-9.-]/g, ''));
                        } else if (!retraitText.includes('-')) {
                            montant = parseFloat(retraitText.replace(/[^0-9.-]/g, ''));
                        }
                        
                        if (montantMin !== null && montant < montantMin) {
                            visible = false;
                        }
                        if (montantMax !== null && montant > montantMax) {
                            visible = false;
                        }
                    }
                    
                    // Filtre date
                    if (visible && (dateMin || dateMax)) {
                        const dateText = row.querySelector('td:nth-child(3)').textContent;
                        if (dateText) {
                            if (dateMin && dateText < dateMin) {
                                visible = false;
                            }
                            if (dateMax && dateText > dateMax) {
                                visible = false;
                            }
                        }
                    }
                    
                    // Filtre exercice
                    if (visible && exerciceId) {
                        if (row.dataset.exerciceId !== exerciceId) {
                            visible = false;
                        }
                    }
                    
                    row.style.display = visible ? '' : 'none';
                    if (visible) visibleCount++;
                });
                
                console.log('Transactions visibles:', visibleCount);
            }
            
            function clearFilters() {
                filterLibelle.value = '';
                filterTypeMontant.value = '';
                filterMontantMin.value = '';
                filterMontantMax.value = '';
                filterDateMin.value = '';
                filterDateMax.value = '';
                filterExercice.value = '';
                
                document.querySelectorAll('tbody tr').forEach(function(row) {
                    row.style.display = '';
                });
            }
            
            applyFiltersBtn.addEventListener('click', applyFilters);
            clearFiltersBtn.addEventListener('click', clearFilters);
            
            // Gestion des séparateurs d'exercices (collapse/expand)
            document.querySelectorAll('.exercice-separator').forEach(function(separator) {
                separator.addEventListener('click', function() {
                    const exerciceId = this.dataset.exerciceId;
                    const indicator = this.querySelector('.collapse-indicator i');
                    const transactionRows = document.querySelectorAll(`tr[data-exercice-id="${exerciceId}"].transaction-row`);
                    
                    const isCollapsed = indicator.classList.contains('fa-chevron-down');
                    
                    transactionRows.forEach(function(row) {
                        row.style.display = isCollapsed ? '' : 'none';
                    });
                    
                    if (isCollapsed) {
                        indicator.classList.remove('fa-chevron-down');
                        indicator.classList.add('fa-chevron-up');
                        this.querySelector('.exercice-montant-collapsed').style.display = 'none';
                    } else {
                        indicator.classList.remove('fa-chevron-up');
                        indicator.classList.add('fa-chevron-down');
                        this.querySelector('.exercice-montant-collapsed').style.display = '';
                    }
                });
            });
            
            // Gestion de la suppression
            document.querySelectorAll('.delete-btn').forEach(function(button) {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    if (!confirm('Êtes-vous sûr de vouloir supprimer cette transaction du livret ?')) {
                        return;
                    }
                    
                    const transactionId = this.dataset.id;
                    const row = this.closest('tr');
                    
                    fetch(`/livret/${transactionId}/delete-ajax`, {
                        method: 'DELETE',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showNotification('Transaction du livret supprimée avec succès !', 'success');
                            row.remove();
                            location.reload(); // Recharger pour mettre à jour les soldes
                        } else {
                            showNotification(data.error || 'Erreur lors de la suppression de la transaction du livret', 'danger');
                        }
                    })
                    .catch(error => {
                        console.error('Erreur:', error);
                        showNotification('Erreur de connexion ou serveur indisponible', 'danger');
                    });
                });
            });
                        const debitCell = row.querySelector('td:nth-child(6)');
                        const creditCell = row.querySelector('td:nth-child(7)');
                        const hasDebit = !debitCell.textContent.includes('-');
                        const hasCredit = !creditCell.textContent.includes('-');
                        
                        if (type === 'depot' && !hasCredit) {
                            visible = false;
                        } else if (type === 'retrait' && !hasDebit) {
                            visible = false;
                        }
                    }
                    
                    // Filtre date
                    if (dateMin || dateMax) {
                        const dateCell = row.querySelector('td:nth-child(4)').textContent;
                        if (dateMin && dateCell < dateMin) visible = false;
                        if (dateMax && dateCell > dateMax) visible = false;
                    }
                    
                    row.style.display = visible ? '' : 'none';
                });
            });
            
            document.getElementById('clear-filters')?.addEventListener('click', function() {
                document.getElementById('filter-libelle').value = '';
                document.getElementById('filter-type-montant').value = '';
                document.getElementById('filter-date-min').value = '';
                document.getElementById('filter-date-max').value = '';
                
                document.querySelectorAll('tbody tr[data-id]').forEach(function(row) {
                    row.style.display = '';
                });
            });
        });
    </script>

{% endblock %}