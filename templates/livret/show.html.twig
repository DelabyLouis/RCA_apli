{% extends 'base.html.twig' %}

{% block title %}Détails - Transaction Livret #{{ transaction.idTransaction }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-piggy-bank me-2"></i>
                        Détails de la transaction livret #{{ transaction.idTransaction }}
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="fw-bold">Informations générales</h6>
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>Libellé :</strong></td>
                                    <td>{{ transaction.libelle }}</td>
                                </tr>
                                <tr>
                                    <td><strong>N° Ordre :</strong></td>
                                    <td>{{ transaction.numeroOrdre }}</td>
                                </tr>
                                <tr>
                                    <td><strong>Date :</strong></td>
                                    <td>{{ transaction.dateTransaction|date('d/m/Y H:i') }}</td>
                                </tr>
                                <tr>
                                    <td><strong>Type de compte :</strong></td>
                                    <td>
                                        <span class="badge bg-info">
                                            <i class="fas fa-piggy-bank"></i> Livret
                                        </span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-bold">Montant et type</h6>
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>Type d'opération :</strong></td>
                                    <td>
                                        {% if transaction.montant >= 0 %}
                                            <span class="badge bg-success">
                                                <i class="fas fa-arrow-down"></i> Dépôt
                                            </span>
                                        {% else %}
                                            <span class="badge bg-danger">
                                                <i class="fas fa-arrow-up"></i> Retrait
                                            </span>
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Montant :</strong></td>
                                    <td>
                                        <span class="badge bg-{{ transaction.montant >= 0 ? 'success' : 'danger' }} fs-5">
                                            {{ transaction.montant|number_format(2, ',', ' ') }} €
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Exercice :</strong></td>
                                    <td>{{ transaction.exercice ? transaction.exercice.libelle : 'Non défini' }}</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    
                    {% if transaction_liee %}
                        <div class="row mt-3">
                            <div class="col-12">
                                <h6 class="fw-bold">Transaction liée (Compte courant)</h6>
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <strong>Libellé :</strong> {{ transaction_liee.libelle }}<br>
                                                <strong>Date :</strong> {{ transaction_liee.dateTransaction|date('d/m/Y H:i') }}
                                            </div>
                                            <div class="col-md-6">
                                                <strong>Montant :</strong> 
                                                <span class="badge bg-{{ transaction_liee.montant >= 0 ? 'success' : 'danger' }}">
                                                    {{ transaction_liee.montant|number_format(2, ',', ' ') }} €
                                                </span><br>
                                                <a href="{{ path('app_transaction_show', {'id_transaction': transaction_liee.idTransaction}) }}" 
                                                   class="btn btn-sm btn-outline-primary mt-2">
                                                    <i class="fas fa-external-link-alt"></i> Voir détails
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between">
                        <a href="{{ path('app_livret_index') }}" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Retour à la liste
                        </a>
                        <div>
                            <a href="{{ path('app_livret_edit', {'id': transaction.idTransaction}) }}" 
                               class="btn btn-warning">
                                <i class="fas fa-edit"></i> Modifier
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}