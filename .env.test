# Configuration pour l'environnement de test
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

###> doctrine/doctrine-bundle ###
# Base de données SQLite pour les tests (recommandé)
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data/test.db"

# Alternative MySQL pour les tests (nécessite des permissions admin)
# DATABASE_URL="mysql://root:@127.0.0.1:3306/RCA_appli_test?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Messenger en mode synchrone pour les tests
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# Mailer de test (n'envoie pas vraiment d'emails)
MAILER_DSN=null://null
###< symfony/mailer ###
