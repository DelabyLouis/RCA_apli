# Example production local environment file
# Copy this file to .env.prod.local and update with your actual production values
# NEVER commit .env.prod.local to version control

###> Production Database ###
# Update with your actual production database credentials
DATABASE_URL="mysql://your_prod_user:your_secure_password@your_prod_host:3306/your_prod_database?serverVersion=8.0.32&charset=utf8mb4"

###> Production Mailer ###
# Configure with your actual SMTP server
MAILER_DSN=smtp://smtp.your-provider.com:587?username=your-email@domain.com&password=your-smtp-password

###> Production Domain ###
# Your actual production domain
DEFAULT_URI=https://your-actual-domain.com

###> Optional: Override production secret if needed ###
# APP_SECRET=your_production_secret_key_here